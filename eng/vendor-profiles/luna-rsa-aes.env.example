# Example environment contract for the optional Thales Luna vendor regression profile.
#
# Copy this file to a local untracked path, fill in the placeholders, then run:
#   set -a
#   source /path/to/your/luna-rsa-aes.env
#   set +a
#   ./eng/run-regression-tests.sh --use-existing-env
#
# This profile intentionally drives the existing standard PKCS#11 vendor lane.
# It does not add Luna-only CA_* extension coverage.

export PKCS11_USE_EXISTING_ENV=1
export PKCS11_VENDOR_PROFILE=luna-rsa-aes

# Point at the Luna PKCS#11 library visible on the machine running the tests.
export PKCS11_MODULE_PATH='/path/to/luna/libCryptoki2_64.so'

# Use a prepared Luna partition/keyring label plus a normal user PIN.
export PKCS11_TOKEN_LABEL='your-luna-token-label'
export PKCS11_USER_PIN='your-user-pin'

# Existing AES key used for the AES encrypt/decrypt regression contract.
export PKCS11_FIND_LABEL='existing-aes-label'
# export PKCS11_FIND_ID_HEX='A1'

# Existing RSA private key used for CKM_RSA_PKCS sign coverage.
export PKCS11_SIGN_FIND_LABEL='existing-rsa-private-label'
# export PKCS11_SIGN_FIND_ID_HEX='B1'

# Optional if your verify key uses a distinct label/id. When omitted, the test lane
# falls back to the sign-key label/id defaults.
# export PKCS11_VERIFY_FIND_LABEL='existing-rsa-public-label'
# export PKCS11_VERIFY_FIND_ID_HEX='B1'

# The profile defaults already set CKM_RSA_PKCS for sign/verify.
# export PKCS11_SIGN_MECHANISM='0x00000040'

# Leave provisioning disabled unless you intentionally want InitToken coverage and
# the target slot/policy is appropriate for it.
# export PKCS11_PROVISIONING_REGRESSION=1
# export PKCS11_SO_PIN='your-so-pin'
