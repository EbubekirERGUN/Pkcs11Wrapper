# Copy this file to an operator-controlled path and pass it to your
# process supervisor, container runtime, or orchestrator.
#
# IMPORTANT: the repository does not ship a supported Crypto API Dockerfile yet.
# This template is for an operator-built wrapper around:
#   src/Pkcs11Wrapper.CryptoApi
#
# Use the same CryptoApiSharedPersistence connection string in every Crypto API
# instance and in the admin dashboard when you want the dashboard to manage the
# shared Crypto API control plane.

ASPNETCORE_URLS=http://+:8080
CryptoApiHost__ServiceName=Pkcs11Wrapper.CryptoApi
CryptoApiHost__ApiBasePath=/api/v1

# Keep true when TLS terminates upstream and the service only serves private HTTP.
# Change only if you intentionally configure container-local HTTPS.
CryptoApiRuntime__DisableHttpsRedirection=true

# Required for readiness and request execution.
# IMPORTANT: ModulePath must be the in-container path, not the host path.
CryptoApiRuntime__ModulePath=/opt/pkcs11/lib/libvendorpkcs11.so

# Treat this as secret material. Prefer secret-manager/orchestrator injection.
CryptoApiRuntime__UserPin=ChangeMe

# PostgreSQL is the supported shared-state backend for the Crypto API control
# plane. Every API instance and the admin dashboard should point at the same
# database when they are meant to share one control plane.
CryptoApiSharedPersistence__Provider=Postgres
CryptoApiSharedPersistence__ConnectionString=Host=db.internal;Port=5432;Database=pkcs11wrapper_cryptoapi;Username=cryptoapi;Password=ChangeMe;SSL Mode=Require
CryptoApiSharedPersistence__AutoInitialize=true

# Optional Redis-backed hot-path acceleration.
# This remains a disposable cache/lease layer only: PostgreSQL stays the source
# of truth for clients, keys, aliases, policies, and bindings.
CryptoApiRequestPathCaching__Redis__Enabled=false
CryptoApiRequestPathCaching__Redis__Configuration=
CryptoApiRequestPathCaching__Redis__InstanceName=pkcs11wrapper:cryptoapi:
CryptoApiRequestPathCaching__Redis__ConnectTimeoutMilliseconds=5000
CryptoApiRequestPathCaching__Redis__OperationTimeoutMilliseconds=1000
CryptoApiRequestPathCaching__Redis__ReconnectCooldownSeconds=5
CryptoApiRequestPathCaching__Redis__AuthStateRevisionTtlSeconds=300
# 0 means "follow CryptoApiRequestPathCaching__EntryTtlSeconds".
CryptoApiRequestPathCaching__Redis__AuthenticationEntryTtlSeconds=0
CryptoApiRequestPathCaching__Redis__AuthorizationEntryTtlSeconds=0

# Keep verbose auth/shared-state diagnostics disabled on exposed deployments.
# Enable only for tightly controlled internal troubleshooting.
CryptoApiSecurity__ExposeDetailedErrors=false
CryptoApiSecurity__ExposeSharedStateDetails=false

# Prometheus scraping endpoint. Keep it on a private network segment or behind
# an authenticated metrics gateway/reverse proxy.
Observability__EnablePrometheusScrapingEndpoint=true
Observability__MetricsPath=/metrics
