# Copy this file to an operator-controlled path and pass it to your
# process supervisor, container runtime, or orchestrator.
#
# IMPORTANT: the repository currently ships the gateway host project but not a
# supported gateway Dockerfile/image. This template is for an operator-built
# wrapper around:
#   src/Pkcs11Wrapper.CryptoApi.Gateway
#
# Point the gateway at multiple healthy/stateless Crypto API instances that all
# expose the same machine-facing API base path.

ASPNETCORE_URLS=http://+:8090
CryptoApiGateway__ServiceName=Pkcs11Wrapper.CryptoApi.Gateway
CryptoApiGateway__ClusterId=crypto-api-fleet
CryptoApiGateway__ApiBasePath=/api/v1
CryptoApiGateway__LoadBalancingPolicy=RoundRobin
CryptoApiGateway__CorrelationIdHeaderName=X-Correlation-Id
CryptoApiGateway__MaxRequestBodySizeBytes=1048576

# Upstream request timeout and TLS behavior.
CryptoApiGateway__HttpClient__ActivityTimeoutSeconds=30
CryptoApiGateway__HttpClient__DangerousAcceptAnyServerCertificate=false

# Active health checks remove unhealthy Crypto API destinations from selection.
CryptoApiGateway__HealthChecks__Active__Enabled=true
CryptoApiGateway__HealthChecks__Active__IntervalSeconds=5
CryptoApiGateway__HealthChecks__Active__TimeoutSeconds=2
CryptoApiGateway__HealthChecks__Active__ConsecutiveFailuresThreshold=2
CryptoApiGateway__HealthChecks__Active__Path=/health/ready

# Destination list. Add or remove entries to match your fleet.
CryptoApiGateway__Destinations__0__Name=crypto-api-a
CryptoApiGateway__Destinations__0__Address=http://crypto-api-a.internal:8080/
CryptoApiGateway__Destinations__0__Health=http://crypto-api-a.internal:8080/
CryptoApiGateway__Destinations__0__Enabled=true

CryptoApiGateway__Destinations__1__Name=crypto-api-b
CryptoApiGateway__Destinations__1__Address=http://crypto-api-b.internal:8080/
CryptoApiGateway__Destinations__1__Health=http://crypto-api-b.internal:8080/
CryptoApiGateway__Destinations__1__Enabled=true
