# Copy this file to .env before running the compose lab stack.
# The defaults intentionally match the repository's SoftHSM fixture labels/PINs
# so local demos and troubleshooting line up with existing docs/tests.

PKCS11WRAPPER_ADMIN_PORT=8080
PKCS11WRAPPER_ADMIN_USER=admin
PKCS11WRAPPER_ADMIN_PASSWORD=ChangeMe!123456
PKCS11WRAPPER_ADMIN_DEVICE_NAME=SoftHSM lab
PKCS11WRAPPER_ADMIN_DEVICE_NOTES=Local/dev/lab SoftHSM compose stack. Not production orchestrated.

SOFTHSM_AUTO_SEED=1
SOFTHSM_TOKEN_LABEL=Pkcs11Wrapper CI Token
SOFTHSM_USER_PIN=123456
SOFTHSM_SO_PIN=12345678
SOFTHSM_AES_LABEL=ci-aes
SOFTHSM_AES_ID_HEX=A1
SOFTHSM_RSA_LABEL=ci-rsa
SOFTHSM_RSA_ID_HEX=B2
