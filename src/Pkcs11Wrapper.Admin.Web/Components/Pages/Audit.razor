@page "/audit"
@attribute [Authorize(Policy = AdminRoles.Viewer)]
@inject HsmAdminService Admin

<PageTitle>Audit Logs</PageTitle>

<section class="page-hero page-hero-audit">
    <div class="page-hero-copy">
        <div class="page-eyebrow">Traceability</div>
        <h1>Audit Logs</h1>
        <p class="page-lead">Yönetim panelinde yapılan işlemlerin audit kaydı. Buradan son olayları filtrele, başarısız operasyonları ayır ve audit chain sağlığını takip et. Ekran artık gözle okunur ve doğrulama odaklı bir operasyon kaydı yüzeyi gibi hissettirmeli.</p>
        <div class="page-hero-tags">
            <span class="page-tag">Audit integrity</span>
            <span class="page-tag">Failure isolation</span>
            <span class="page-tag">Actor trace</span>
            <span class="page-tag">Paged review</span>
        </div>
    </div>
    <div class="page-hero-side">
        <div class="hero-panel">
            <div class="hero-panel-title">Review mode</div>
            <div class="hero-panel-value">Recent + filterable</div>
            <div class="hero-panel-copy">Use the search window to isolate suspicious actions, non-success outcomes, or a specific actor/target trail quickly.</div>
        </div>
        <div class="hero-panel">
            <div class="hero-panel-title">Chain posture</div>
            <div class="hero-panel-value">Integrity aware</div>
            <div class="hero-panel-copy">The chain summary stays visible so audit review feels trustworthy before users rely on the entries.</div>
        </div>
    </div>
</section>

@if (_integrity is not null)
{
    <div class="alert @(_integrity.IsValid ? "alert-success" : "alert-danger")">
        <div class="fw-semibold">Audit integrity</div>
        <div>@_integrity.Summary</div>
        @if (!string.IsNullOrWhiteSpace(_integrity.FailureReason))
        {
            <div class="small">@_integrity.FailureReason</div>
        }
    </div>
}

<div class="row g-3 mb-3">
    <div class="col-xl-3 col-md-4 col-sm-6">
        <div class="card shadow-sm h-100 metric-card">
            <div class="card-body">
                <div class="metric-label">Loaded entries</div>
                <div class="display-6 metric-meta">@_logs.Count</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-4 col-sm-6">
        <div class="card shadow-sm h-100 metric-card">
            <div class="card-body">
                <div class="metric-label">Filtered entries</div>
                <div class="display-6 metric-meta">@GetFilteredLogs().Count</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-4 col-sm-6">
        <div class="card shadow-sm h-100 metric-card">
            <div class="card-body">
                <div class="metric-label">Failure outcomes</div>
                <div class="display-6 metric-meta">@GetFilteredLogs().Count(log => !string.Equals(log.Outcome, "Success", StringComparison.OrdinalIgnoreCase))</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-4 col-sm-6">
        <div class="card shadow-sm h-100 metric-card">
            <div class="card-body">
                <div class="metric-label">Categories in window</div>
                <div class="display-6 metric-meta">@AvailableCategories.Count</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4 panel-toolbar-card feature-card">
    <div class="card-body row g-3 align-items-end">
        <div class="col-xl-2 col-lg-3 col-md-6">
            <button class="btn btn-primary" @onclick="() => LoadAsync(true)">Refresh + Verify</button>
        </div>
        <div class="col-xl-4 col-lg-5 col-md-6">
            <label class="form-label">Search</label>
            <input class="form-control" @bind="_searchText" @bind:event="oninput" @bind:after="OnFiltersChanged" placeholder="actor, action, target, details..." />
        </div>
        <div class="col-xl-2 col-lg-4 col-md-6">
            <label class="form-label">Category</label>
            <select class="form-select" @bind="_categoryFilter" @bind:after="OnFiltersChanged">
                <option value="">All categories</option>
                @foreach (string category in AvailableCategories)
                {
                    <option value="@category">@category</option>
                }
            </select>
        </div>
        <div class="col-xl-2 col-lg-4 col-md-6">
            <label class="form-label">Outcome</label>
            <select class="form-select" @bind="_outcomeFilter" @bind:after="OnFiltersChanged">
                <option value="all">All outcomes</option>
                <option value="success">Success only</option>
                <option value="failure">Non-success only</option>
            </select>
        </div>
        <div class="col-xl-2 col-lg-4 col-md-6">
            <label class="form-label">Page size</label>
            <select class="form-select" @bind="_pageSize" @bind:after="OnPageSizeChanged">
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="200">200</option>
            </select>
        </div>
    </div>
</div>

@if (_logs.Count == 0)
{
    <div class="empty-state">No audit entries yet.</div>
}
else if (GetFilteredLogs().Count == 0)
{
    <div class="empty-state">No audit entries matched the current filters.</div>
}
else
{
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
        <div class="small text-muted">
            Showing @CurrentRangeStart-@CurrentRangeEnd of @GetFilteredLogs().Count filtered entry(s) from the latest @_logs.Count loaded item(s).
        </div>
        <div class="small text-muted">Page @CurrentPageIndex of @TotalPages</div>
    </div>

    <div class="table-responsive table-shell">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>When</th>
                    <th>Actor</th>
                    <th>Roles</th>
                    <th>Category</th>
                    <th>Action</th>
                    <th>Target</th>
                    <th>Outcome</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (AdminAuditLogEntry log in CurrentPageLogs)
                {
                    <tr>
                        <td><span class="table-pill table-pill-code">@log.TimestampUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span></td>
                        <td>
                            <div>@log.Actor</div>
                            @if (!string.IsNullOrWhiteSpace(log.SessionId))
                            {
                                <div class="small text-muted">trace @log.SessionId</div>
                            }
                        </td>
                        <td>@string.Join(", ", log.ActorRoles)</td>
                        <td><span class="table-pill">@log.Category</span></td>
                        <td>@log.Action</td>
                        <td>@log.Target</td>
                        <td>
                            <span class="badge @(string.Equals(log.Outcome, "Success", StringComparison.OrdinalIgnoreCase) ? "text-bg-success" : "text-bg-danger")">@log.Outcome</span>
                        </td>
                        <td>@log.Details</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-3">
        <button class="btn btn-outline-secondary" @onclick="PreviousPage" disabled="@(CurrentPageIndex <= 1)">Previous</button>
        <div class="small text-muted">Page @CurrentPageIndex / @TotalPages</div>
        <button class="btn btn-outline-secondary" @onclick="NextPage" disabled="@(CurrentPageIndex >= TotalPages)">Next</button>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "q")]
    public string? QueryText { get; set; }

    private IReadOnlyList<AdminAuditLogEntry> _logs = [];
    private AuditIntegrityStatus? _integrity;
    private string _appliedQueryText = string.Empty;
    private string _searchText = string.Empty;
    private string _categoryFilter = string.Empty;
    private string _outcomeFilter = "all";
    private int _pageSize = 25;
    private int _pageIndex = 1;

    private IReadOnlyList<string> AvailableCategories => _logs
        .Select(log => log.Category)
        .Distinct(StringComparer.Ordinal)
        .OrderBy(category => category, StringComparer.Ordinal)
        .ToArray();

    private IReadOnlyList<AdminAuditLogEntry> CurrentPageLogs
    {
        get
        {
            IReadOnlyList<AdminAuditLogEntry> filtered = GetFilteredLogs();
            int pageIndex = GetSafePageIndex(filtered.Count);
            return filtered.Skip((pageIndex - 1) * _pageSize).Take(_pageSize).ToArray();
        }
    }

    private int CurrentPageIndex => GetSafePageIndex(GetFilteredLogs().Count);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(GetFilteredLogs().Count / (double)_pageSize));

    private int CurrentRangeStart => GetFilteredLogs().Count == 0 ? 0 : ((CurrentPageIndex - 1) * _pageSize) + 1;

    private int CurrentRangeEnd => Math.Min(CurrentPageIndex * _pageSize, GetFilteredLogs().Count);

    protected override Task OnInitializedAsync() => LoadAsync();

    protected override void OnParametersSet()
        => ApplyQueryText();

    private async Task LoadAsync(bool forceVerify = false)
    {
        _logs = await Admin.GetAuditLogsAsync();
        _integrity = await Admin.GetAuditIntegrityAsync(forceVerify);
        ApplyQueryText();
        _pageIndex = 1;
    }

    private Task OnFiltersChanged()
    {
        _pageIndex = 1;
        return Task.CompletedTask;
    }

    private Task OnPageSizeChanged()
    {
        _pageIndex = 1;
        return Task.CompletedTask;
    }

    private void PreviousPage()
    {
        if (_pageIndex > 1)
        {
            _pageIndex--;
        }
    }

    private void NextPage()
    {
        if (_pageIndex < TotalPages)
        {
            _pageIndex++;
        }
    }

    private IReadOnlyList<AdminAuditLogEntry> GetFilteredLogs()
    {
        IEnumerable<AdminAuditLogEntry> query = _logs;

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            string term = _searchText.Trim();
            query = query.Where(log =>
                Contains(log.Actor, term)
                || Contains(log.Category, term)
                || Contains(log.Action, term)
                || Contains(log.Target, term)
                || Contains(log.Outcome, term)
                || Contains(log.Details, term)
                || Contains(log.SessionId, term)
                || Contains(log.RemoteIp, term)
                || Contains(log.UserAgent, term));
        }

        if (!string.IsNullOrWhiteSpace(_categoryFilter))
        {
            query = query.Where(log => string.Equals(log.Category, _categoryFilter, StringComparison.Ordinal));
        }

        query = _outcomeFilter switch
        {
            "success" => query.Where(log => string.Equals(log.Outcome, "Success", StringComparison.OrdinalIgnoreCase)),
            "failure" => query.Where(log => !string.Equals(log.Outcome, "Success", StringComparison.OrdinalIgnoreCase)),
            _ => query
        };

        return query.ToArray();
    }

    private void ApplyQueryText()
    {
        string queryText = QueryText?.Trim() ?? string.Empty;
        if (string.Equals(_appliedQueryText, queryText, StringComparison.Ordinal))
        {
            return;
        }

        _appliedQueryText = queryText;
        _searchText = queryText;
        _pageIndex = 1;
    }

    private int GetSafePageIndex(int filteredCount)
    {
        int totalPages = Math.Max(1, (int)Math.Ceiling(filteredCount / (double)_pageSize));
        if (_pageIndex < 1)
        {
            _pageIndex = 1;
        }
        else if (_pageIndex > totalPages)
        {
            _pageIndex = totalPages;
        }

        return _pageIndex;
    }

    private static bool Contains(string? value, string term)
        => value?.Contains(term, StringComparison.OrdinalIgnoreCase) == true;
}
