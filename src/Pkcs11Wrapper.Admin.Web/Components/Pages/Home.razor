@page "/"
@attribute [Authorize(Policy = AdminRoles.Viewer)]
@inject HsmAdminService Admin

<PageTitle>Pkcs11Wrapper Admin</PageTitle>

<h1>Pkcs11Wrapper Admin Dashboard</h1>
<p class="text-muted">Cihaz, session, audit ve recovery görünürlüğünü tek ekranda topla; sonra cihaz yönetimi, PKCS#11 Lab ve güvenlik operasyonlarına hızlı geçiş yap.</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_summary is null)
{
    <p>Loading dashboard...</p>
}
else
{
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div class="small text-muted">
            Last refresh: @(_lastLoadedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")
        </div>
        <button class="btn btn-outline-secondary" @onclick="LoadAsync">Refresh dashboard</button>
    </div>

    @if (!_summary.AuditIntegrityValid || _summary.InvalidatedSessionCount > 0 || _summary.RecentAuditFailureCount > 0)
    {
        <div class="alert @(!_summary.AuditIntegrityValid ? "alert-danger" : "alert-warning")">
            <div class="fw-semibold">Operational attention needed</div>
            <ul class="mb-0 ps-3 small">
                @if (!_summary.AuditIntegrityValid)
                {
                    <li>Audit integrity needs review: @_summary.AuditIntegritySummary</li>
                }
                @if (_summary.InvalidatedSessionCount > 0)
                {
                    <li>@_summary.InvalidatedSessionCount invalidated tracked session(s) should be reviewed and closed from the Sessions page.</li>
                }
                @if (_summary.RecentAuditFailureCount > 0)
                {
                    <li>@_summary.RecentAuditFailureCount recent audit event(s) ended in failure. Check the Audit page for the exact operations.</li>
                }
            </ul>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <div class="fw-semibold">Operational health looks clean</div>
            <div class="small">Audit integrity is valid, no tracked session is marked invalidated, and the recent audit window contains no failure outcome.</div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Configured devices</div>
                    <div class="display-6">@_summary.DeviceCount</div>
                    <div class="small text-muted">Enabled: @_summary.EnabledDeviceCount / Disabled: @_summary.DisabledDeviceCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Tracked sessions</div>
                    <div class="display-6">@_summary.ActiveSessionCount</div>
                    <div class="small text-muted">Healthy: @_summary.HealthySessionCount / Invalidated: @_summary.InvalidatedSessionCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Recent audit window</div>
                    <div class="display-6">@_summary.RecentAuditCount</div>
                    <div class="small text-muted">Failures: @_summary.RecentAuditFailureCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Audit integrity</div>
                    <div class="display-6">@(_summary.AuditIntegrityValid ? "OK" : "WARN")</div>
                    <div class="small text-muted text-truncate">@_summary.AuditIntegritySummary</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Device readiness</div>
                    <div class="display-6">@(_summary.EnabledDeviceCount == 0 ? "0" : "Ready")</div>
                    <div class="small text-muted">Use Devices / Slots to validate module paths and token visibility.</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Next operator step</div>
                    <div class="display-6">@(_summary.ActiveSessionCount == 0 ? "Lab" : "Sessions")</div>
                    <div class="small text-muted">Start diagnostics in the Lab or review tracked-session health.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-7">
            <div class="card shadow-sm h-100">
                <div class="card-header">Quick actions</div>
                <div class="card-body d-flex flex-column gap-4">
                    <div>
                        <div class="fw-semibold mb-2">Core operator flow</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary" href="devices">Devices</a>
                            <a class="btn btn-outline-primary" href="slots">Slots</a>
                            <a class="btn btn-outline-primary" href="keys">Keys / Objects</a>
                            <AuthorizeView Roles="operator,admin">
                                <Authorized>
                                    <a class="btn btn-outline-dark" href="lab">PKCS#11 Lab</a>
                                </Authorized>
                            </AuthorizeView>
                            <a class="btn btn-outline-secondary" href="sessions">Sessions</a>
                            <a class="btn btn-outline-secondary" href="audit">Audit Logs</a>
                        </div>
                    </div>

                    <AuthorizeView Roles="admin">
                        <Authorized>
                            <div>
                                <div class="fw-semibold mb-2">Admin recovery / maintenance</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <a class="btn btn-outline-warning" href="configuration">Configuration Transfer</a>
                                    <a class="btn btn-outline-warning" href="users">Users</a>
                                </div>
                                <div class="small text-muted mt-2">Use Configuration for backup/migration and Users for bootstrap notice retirement, password rotation, and local role changes.</div>
                            </div>
                        </Authorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="card shadow-sm h-100">
                <div class="card-header">Ops / recovery checklist</div>
                <div class="card-body">
                    <ol class="small ps-3 mb-0 d-flex flex-column gap-2">
                        <li>Before risky changes, export the current device-profile bundle from <a href="configuration">Configuration</a>.</li>
                        <li>If tracked sessions show as invalidated or broken, open <a href="sessions">Sessions</a>, inspect the reason, then close stale tracked entries.</li>
                        <li>If audit integrity shows warning state, open <a href="audit">Audit Logs</a> and review the chain summary before continuing write operations.</li>
                        <AuthorizeView Roles="admin">
                            <Authorized>
                                <li>Rotate local passwords and retire the bootstrap notice from <a href="users">Users</a> after initial setup is complete.</li>
                            </Authorized>
                        </AuthorizeView>
                        <AuthorizeView Roles="operator,admin">
                            <Authorized>
                                <li>Use <a href="lab">PKCS#11 Lab</a> for diagnostics and controlled experiments instead of ad-hoc raw PKCS#11 shelling.</li>
                            </Authorized>
                        </AuthorizeView>
                    </ol>
                </div>
            </div>
        </div>
    </div>
}

@if (_recentLogs.Count != 0)
{
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Recent audit events</span>
            <a class="btn btn-sm btn-outline-secondary" href="audit">Open full audit view</a>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Category</th>
                        <th>Action</th>
                        <th>Target</th>
                        <th>Outcome</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (AdminAuditLogEntry log in _recentLogs)
                    {
                        <tr>
                            <td>@log.TimestampUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@log.Category</td>
                            <td>@log.Action</td>
                            <td>@log.Target</td>
                            <td>
                                <span class="badge @(string.Equals(log.Outcome, "Success", StringComparison.OrdinalIgnoreCase) ? "text-bg-success" : "text-bg-danger")">@log.Outcome</span>
                            </td>
                            <td>@log.Details</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private DashboardSummary? _summary;
    private IReadOnlyList<AdminAuditLogEntry> _recentLogs = [];
    private string? _error;
    private DateTimeOffset? _lastLoadedUtc;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            _summary = await Admin.GetDashboardAsync();
            _recentLogs = await Admin.GetAuditLogsAsync(10);
            _lastLoadedUtc = DateTimeOffset.UtcNow;
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
