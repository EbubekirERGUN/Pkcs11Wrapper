@page "/"
@using Pkcs11Wrapper.Admin.Web.Lab
@using Pkcs11Wrapper.Admin.Web.Security
@attribute [Authorize(Policy = AdminRoles.Viewer)]
@inject HsmAdminService Admin
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject LocalAdminSecurityService Security
@inject Pkcs11LabTemplateStore TemplateStore

<PageTitle>Pkcs11Wrapper Admin</PageTitle>

<section class="page-hero page-hero-dashboard">
    <div class="page-hero-copy">
        <div class="page-eyebrow">Operations overview</div>
        <h1>Pkcs11Wrapper Admin Dashboard</h1>
        <p class="page-lead">Cihaz, session, audit ve recovery görünürlüğünü tek ekranda topla; sonra cihaz yönetimi, PKCS#11 Lab ve güvenlik operasyonlarına hızlı geçiş yap. Bu sayfa artık yalnızca veri toplamak için değil, operatörün durumu hızlı okuyup doğru sonraki adıma geçmesi için tasarlanıyor.</p>
        <div class="page-hero-tags">
            <span class="page-tag">Device governance</span>
            <span class="page-tag">Session health</span>
            <span class="page-tag">Audit integrity</span>
            @if (_isOperator)
            {
                <span class="page-tag">Controlled diagnostics</span>
            }
            @if (_isAdmin)
            {
                <span class="page-tag">Recovery administration</span>
            }
        </div>
    </div>
    <div class="page-hero-side">
        <div class="hero-panel">
            <div class="hero-panel-title">Console focus</div>
            <div class="hero-panel-value">Recovery-first</div>
            <div class="hero-panel-copy">Sessions, audit, configuration safety, and controlled PKCS#11 diagnostics are meant to stay visible from the first screen.</div>
        </div>
        <div class="hero-panel">
            <div class="hero-panel-title">Current role</div>
            <div class="hero-panel-value">@(_isAdmin ? "Admin" : _isOperator ? "Operator" : "Viewer")</div>
            <div class="hero-panel-copy">Role-aware surfaces stay on the server side with local auth and protected operational flows.</div>
        </div>
    </div>
</section>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_summary is null)
{
    <p>Loading dashboard...</p>
}
else
{
    <div class="page-toolbar">
        <div class="hero-panel flex-grow-1">
            <div class="hero-panel-title">Last refresh</div>
            <div class="hero-panel-value">@(_lastLoadedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "n/a")</div>
            <div class="hero-panel-copy">Reload this view after operational changes to refresh health, audit, and recovery widgets.</div>
        </div>
        <button class="btn btn-outline-secondary" @onclick="LoadAsync">Refresh dashboard</button>
    </div>

    @if (AttentionItems.Count != 0)
    {
        <div class="alert @(AttentionLevel == "danger" ? "alert-danger" : "alert-warning")">
            <div class="fw-semibold">Operational attention needed</div>
            <ul class="mb-0 ps-3 small">
                @foreach (string item in AttentionItems)
                {
                    <li>@item</li>
                }
            </ul>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <div class="fw-semibold">Operational health looks clean</div>
            <div class="small">Audit integrity is valid, no tracked session is marked invalidated, and the recent audit window contains no failure outcome.</div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Configured devices</div>
                    <div class="display-6 metric-meta">@_summary.DeviceCount</div>
                    <div class="small metric-note">Enabled: @_summary.EnabledDeviceCount / Disabled: @_summary.DisabledDeviceCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Tracked sessions</div>
                    <div class="display-6 metric-meta">@_summary.ActiveSessionCount</div>
                    <div class="small metric-note">Healthy: @_summary.HealthySessionCount / Invalidated: @_summary.InvalidatedSessionCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Recent audit window</div>
                    <div class="display-6 metric-meta">@_summary.RecentAuditCount</div>
                    <div class="small metric-note">Failures: @_summary.RecentAuditFailureCount</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Audit integrity</div>
                    <div class="display-6 metric-meta">@(_summary.AuditIntegrityValid ? "OK" : "WARN")</div>
                    <div class="small metric-note text-truncate">@_summary.AuditIntegritySummary</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Config backup</div>
                    <div class="display-6 metric-meta">@BackupStatusLabel</div>
                    <div class="small metric-note">@BackupStatusDescription</div>
                </div>
            </div>
        </div>
        <div class="col-xl-2 col-md-4 col-sm-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Next operator step</div>
                    <div class="display-6 metric-meta">@(_summary.ActiveSessionCount == 0 ? "Lab" : "Sessions")</div>
                    <div class="small metric-note">Start diagnostics in the Lab or review tracked-session health.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-7">
            <div class="card shadow-sm h-100 feature-card">
                <div class="card-header">Quick actions</div>
                <div class="card-body d-flex flex-column gap-4">
                    <div>
                        <div class="fw-semibold mb-2">Core operator flow</div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary" href="devices">Devices</a>
                            <a class="btn btn-outline-primary" href="slots">Slots</a>
                            <a class="btn btn-outline-primary" href="keys">Keys / Objects</a>
                            @if (_isOperator)
                            {
                                <a class="btn btn-outline-dark" href="lab">PKCS#11 Lab</a>
                            }
                            <a class="btn btn-outline-secondary" href="telemetry">PKCS#11 Telemetry</a>
                            <a class="btn btn-outline-secondary" href="sessions">Sessions</a>
                            <a class="btn btn-outline-secondary" href="audit">Audit Logs</a>
                        </div>
                    </div>

                    @if (_isAdmin)
                    {
                        <div>
                            <div class="fw-semibold mb-2">Admin recovery / maintenance</div>
                            <div class="d-flex flex-wrap gap-2">
                                <a class="btn btn-outline-warning" href="configuration">Configuration Transfer</a>
                                <a class="btn btn-outline-warning" href="users">Users</a>
                            </div>
                            <div class="small text-muted mt-2">Use Configuration for backup/migration and Users for bootstrap notice retirement, password rotation, and local role changes.</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="card shadow-sm h-100 feature-card">
                <div class="card-header">Ops / recovery checklist</div>
                <div class="card-body">
                    <ol class="small ps-3 mb-0 d-flex flex-column gap-2">
                        <li>Before risky changes, export the current device-profile bundle from <a href="configuration">Configuration</a>.</li>
                        <li>If tracked sessions show as invalidated or broken, open <a href="sessions">Sessions</a>, inspect the reason, then close stale tracked entries.</li>
                        <li>If audit integrity shows warning state, open <a href="audit">Audit Logs</a> and review the chain summary before continuing write operations.</li>
                        @if (_isAdmin)
                        {
                            <li>Rotate local passwords and retire the bootstrap notice from <a href="users">Users</a> after initial setup is complete.</li>
                        }
                        @if (_isOperator)
                        {
                            <li>Use <a href="lab">PKCS#11 Lab</a> for diagnostics and controlled experiments instead of ad-hoc raw PKCS#11 shelling.</li>
                        }
                        <li>If a device/slot/mechanism path misbehaves, open <a href="telemetry">PKCS#11 Telemetry</a> to correlate redacted PKCS#11 calls before assuming the higher-level workflow is at fault.</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-4">
            <div class="card shadow-sm h-100 feature-card">
                <div class="card-header">Failure categories</div>
                <div class="card-body">
                    @if (FailureCategories.Count == 0)
                    {
                        <div class="text-muted small">No non-success audit category appears in the loaded audit window.</div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (DashboardFailureCategoryItem item in FailureCategories)
                            {
                                <div class="surface-item small">
                                    <div class="d-flex justify-content-between align-items-center gap-2">
                                        <div class="fw-semibold">@item.Category</div>
                                        <span class="badge text-bg-danger">@item.Count</span>
                                    </div>
                                    <div class="text-muted">Latest: @item.LatestAction → @item.LatestTarget</div>
                                    <div class="text-muted">@item.LatestTimestampUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card shadow-sm h-100 feature-card">
                <div class="card-header">Invalidated sessions by device</div>
                <div class="card-body">
                    @if (InvalidatedDevices.Count == 0)
                    {
                        <div class="text-muted small">No invalidated tracked session is currently grouped under any device.</div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (DashboardInvalidatedDeviceItem item in InvalidatedDevices)
                            {
                                <div class="surface-item small">
                                    <div class="d-flex justify-content-between align-items-center gap-2">
                                        <div class="fw-semibold">@item.DeviceName</div>
                                        <span class="badge text-bg-danger">@item.Count</span>
                                    </div>
                                    <div class="text-muted">Latest reason: @item.LatestReason</div>
                                    <div class="text-muted">Last touched: @item.LatestTouchedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card shadow-sm h-100 feature-card">
                <div class="card-header">Recovery widgets</div>
                <div class="card-body d-flex flex-column gap-3">
                    @if (_isAdmin)
                    {
                        <div class="surface-item small">
                            <div class="fw-semibold">Local admin hardening</div>
                            <div>Total users: @(_securitySnapshot?.Users.Count ?? 0)</div>
                            <div>Admin-capable users: @AdminUserCount</div>
                            <div>Bootstrap notice: @BootstrapStatusLabel</div>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state small">Local-user hardening widgets are shown to admin accounts only.</div>
                    }

                    @if (_isOperator)
                    {
                        <div class="surface-item small">
                            <div class="fw-semibold">Saved Lab templates</div>
                            <div>Total templates: @_templates.Count</div>
                            @if (RecentTemplateNames.Count == 0)
                            {
                                <div class="text-muted">No saved template yet.</div>
                            }
                            else
                            {
                                <div class="text-muted">Recent: @string.Join(", ", RecentTemplateNames)</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state small">Lab template widgets are shown to operator/admin accounts.</div>
                    }

                    <div class="surface-item small">
                        <div class="fw-semibold">Configuration export freshness</div>
                        <div>@BackupStatusDescription</div>
                        <div class="text-muted">Keep a recent bundle before large import/replace or host migration work.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (_recentLogs.Count != 0)
{
    <div class="card shadow-sm feature-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Recent audit events</span>
            <a class="btn btn-sm btn-outline-secondary" href="audit">Open full audit view</a>
        </div>
        <div class="table-responsive table-shell">
            <table class="table table-sm table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Category</th>
                        <th>Action</th>
                        <th>Target</th>
                        <th>Outcome</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (AdminAuditLogEntry log in _recentLogs)
                    {
                        <tr>
                            <td>@log.TimestampUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@log.Category</td>
                            <td>@log.Action</td>
                            <td>@log.Target</td>
                            <td>
                                <span class="badge @(string.Equals(log.Outcome, "Success", StringComparison.OrdinalIgnoreCase) ? "text-bg-success" : "text-bg-danger")">@log.Outcome</span>
                            </td>
                            <td>@log.Details</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private DashboardSummary? _summary;
    private IReadOnlyList<AdminAuditLogEntry> _auditWindowLogs = [];
    private IReadOnlyList<AdminAuditLogEntry> _recentLogs = [];
    private IReadOnlyList<AdminSessionSnapshot> _sessions = [];
    private IReadOnlyList<Pkcs11LabSavedTemplate> _templates = [];
    private LocalAdminSecuritySnapshot? _securitySnapshot;
    private string? _error;
    private DateTimeOffset? _lastLoadedUtc;
    private bool _isAdmin;
    private bool _isOperator;

    private IReadOnlyList<DashboardFailureCategoryItem> FailureCategories => AdminDashboardView.BuildFailureCategories(_auditWindowLogs);

    private IReadOnlyList<DashboardInvalidatedDeviceItem> InvalidatedDevices => AdminDashboardView.BuildInvalidatedDevices(_sessions);

    private IReadOnlyList<string> RecentTemplateNames => AdminDashboardView.GetRecentTemplateNames(_templates);

    private DateTimeOffset? LastConfigurationExportUtc => AdminDashboardView.GetLastSuccessfulConfigurationExportUtc(_auditWindowLogs);

    private int AdminUserCount => _securitySnapshot?.Users.Count(user => user.Roles.Contains(AdminRoles.Admin, StringComparer.OrdinalIgnoreCase)) ?? 0;

    private string BootstrapStatusLabel => _securitySnapshot?.BootstrapStatus.NoticeExists == true ? "Open" : "Retired";

    private string BackupStatusLabel
        => LastConfigurationExportUtc is null
            ? "Never"
            : (DateTimeOffset.UtcNow - LastConfigurationExportUtc.Value) <= TimeSpan.FromDays(7)
                ? "Fresh"
                : "Stale";

    private string BackupStatusDescription
        => LastConfigurationExportUtc is null
            ? "No successful configuration export was found in the loaded audit window."
            : $"Last successful export: {LastConfigurationExportUtc.Value.ToLocalTime():yyyy-MM-dd HH:mm:ss}";

    private IReadOnlyList<string> AttentionItems
    {
        get
        {
            List<string> items = [];
            if (_summary is null)
            {
                return items;
            }

            if (!_summary.AuditIntegrityValid)
            {
                items.Add($"Audit integrity needs review: {_summary.AuditIntegritySummary}");
            }

            if (_summary.InvalidatedSessionCount > 0)
            {
                items.Add($"{_summary.InvalidatedSessionCount} invalidated tracked session(s) should be reviewed and closed from the Sessions page.");
            }

            if (_summary.RecentAuditFailureCount > 0)
            {
                items.Add($"{_summary.RecentAuditFailureCount} recent audit event(s) ended in failure. Check the Audit page for the exact operations.");
            }

            if (_isAdmin && LastConfigurationExportUtc is null)
            {
                items.Add("No recent successful configuration export is visible in the loaded audit window. Export a bundle before risky migration or replace-all work.");
            }
            else if (_isAdmin && LastConfigurationExportUtc is DateTimeOffset exportedUtc && (DateTimeOffset.UtcNow - exportedUtc) > TimeSpan.FromDays(7))
            {
                items.Add($"Last successful configuration export is older than 7 days ({exportedUtc.ToLocalTime():yyyy-MM-dd HH:mm:ss}). Refresh the backup bundle if the environment is still active.");
            }

            if (_isAdmin && _securitySnapshot?.BootstrapStatus.NoticeExists == true)
            {
                items.Add("Bootstrap credential notice is still present. Retire it from Users after the first-run hardening is complete.");
            }

            return items;
        }
    }

    private string AttentionLevel => _summary?.AuditIntegrityValid == false ? "danger" : "warning";

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAdmin = state.User.IsInRole(AdminRoles.Admin);
        _isOperator = _isAdmin || state.User.IsInRole(AdminRoles.Operator);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _summary = await Admin.GetDashboardAsync();
            _auditWindowLogs = await Admin.GetAuditLogsAsync(50);
            _recentLogs = _auditWindowLogs.Take(10).ToArray();
            _sessions = Admin.GetSessions();
            _templates = _isOperator ? await TemplateStore.GetAllAsync() : [];
            _securitySnapshot = _isAdmin ? await Security.GetSnapshotAsync() : null;
            _lastLoadedUtc = DateTimeOffset.UtcNow;
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
