@page "/keys"
@attribute [Authorize(Policy = AdminRoles.Viewer)]
@inject HsmAdminService Admin
@inject ProtectedPinStore PinStore
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Keys</PageTitle>

<section class="page-hero page-hero-keys">
    <div class="page-hero-copy">
        <div class="page-eyebrow">Object operations</div>
        <h1>Keys / Objects</h1>
        <p class="page-lead">Slot içindeki objeleri listele, capability-aware üret/import akışlarını çalıştır, desteklenen attribute’ları düzenle, obje kopyala ve destroy işlemlerinde typed confirmation kullan. Bu ekranın amacı operatöre hem güçlü işlev hem de temiz, güvenilir bir operasyon deneyimi vermek.</p>
        <div class="page-hero-tags">
            <span class="page-tag">Capability-aware flows</span>
            <span class="page-tag">Server-side object actions</span>
            <span class="page-tag">Safer destructive operations</span>
            <span class="page-tag">Lab handoff presets</span>
        </div>
    </div>
    <div class="page-hero-side">
        <div class="hero-panel">
            <div class="hero-panel-title">Primary usage</div>
            <div class="hero-panel-value">Provision + inspect</div>
            <div class="hero-panel-copy">Select a device and slot, load objects, then move into generation, import, update, copy, or lab-assisted diagnostics.</div>
        </div>
        <div class="hero-panel">
            <div class="hero-panel-title">Security posture</div>
            <div class="hero-panel-value">Server-side</div>
            <div class="hero-panel-copy">PKCS#11 access, object inspection, and PIN-backed actions stay inside the Blazor Server application boundary.</div>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert @(_statusIsError ? "alert-danger" : "alert-success")">@_statusMessage</div>
}

<div class="card shadow-sm mb-4 panel-toolbar-card feature-card">
    <div class="card-body row g-3 align-items-end">
        <div class="col-lg-3">
            <label class="form-label">Device</label>
            <select class="form-select" @bind="_selectedDeviceId" @bind:after="OnSelectedDeviceChangedAsync">
                <option value="">Select device...</option>
                @foreach (HsmDeviceProfile device in _devices)
                {
                    <option value="@device.Id">@device.Name</option>
                }
            </select>
        </div>
        <div class="col-lg-2">
            <label class="form-label">Slot</label>
            <select class="form-select" @bind="_selectedSlotId" @bind:after="OnSelectedSlotChangedAsync">
                <option value="">Select slot...</option>
                @foreach (HsmSlotSummary slot in _slots)
                {
                    <option value="@slot.SlotId">@slot.SlotId - @slot.TokenLabel</option>
                }
            </select>
        </div>
        <div class="col-lg-2">
            <label class="form-label">Load-time Label Filter</label>
            <input class="form-control" @bind="_labelFilter" />
            <div class="form-text">Sent to the server-side PKCS#11 search before the object list is loaded.</div>
        </div>
        <div class="col-lg-2">
            <label class="form-label">User PIN</label>
            <input class="form-control" type="password" @bind="_userPin" />
            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" @bind="_rememberPin" />
                <label class="form-check-label">Remember in protected local storage</label>
            </div>
        </div>
        <div class="col-lg-3 d-flex gap-2">
            <button class="btn btn-primary" @onclick="LoadKeysAsync" disabled="@(!CanLoadKeys)">Load Keys</button>
            <button class="btn btn-outline-secondary" @onclick="ReloadSlotsAsync" disabled="@string.IsNullOrWhiteSpace(_selectedDeviceId)">Refresh Slots</button>
        </div>
    </div>
</div>

@if (_slotCapabilities is not null)
{
    <div class="card shadow-sm mb-4 feature-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Selected slot capability snapshot</span>
            <span class="small text-muted">Slot @_slotCapabilities.SlotId</span>
        </div>
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="badge @( _slotCapabilities.TokenPresent ? "text-bg-success" : "text-bg-danger")">@(_slotCapabilities.TokenPresent ? "Token present" : "No token")</span>
                <span class="badge @(_slotCapabilities.SupportsAesKeyGeneration ? "text-bg-success" : "text-bg-secondary")">AES generate</span>
                <span class="badge @(_slotCapabilities.SupportsAesObjectImport ? "text-bg-success" : "text-bg-secondary")">AES import/create</span>
                <span class="badge @(_slotCapabilities.SupportsRsaKeyPairGeneration ? "text-bg-success" : "text-bg-secondary")">RSA keypair generate</span>
            </div>

            @if (_slotCapabilities.Warnings.Count != 0)
            {
                <div class="alert alert-warning small">
                    <ul class="mb-0 ps-3">
                        @foreach (string warning in _slotCapabilities.Warnings)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-3 small">
                @foreach (SlotMechanismSupport mechanism in _slotCapabilities.Mechanisms)
                {
                    <div class="col-xl-4 col-md-6">
                        <div class="surface-item h-100">
                            <div class="fw-semibold">@mechanism.Name</div>
                            <div class="text-muted"><code>@mechanism.TypeHex</code></div>
                            <div class="mt-1">@(mechanism.Available ? mechanism.Summary : "Not exposed by slot")</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-xl-4">
        <div class="card shadow-sm h-100 workflow-card feature-card">
            <div class="card-header">Generate AES key</div>
            <div class="card-body row g-3">
                @RenderOperationWarnings(GetAesWarnings())
                <div class="col-md-6">
                    <label class="form-label">Label</label>
                    <input class="form-control" @bind="_aesRequest.Label" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">ID (hex)</label>
                    <input class="form-control" @bind="_aesRequest.IdHex" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Size</label>
                    <select class="form-select" @bind="_aesRequest.SizeBytes">
                        <option value="16">128-bit</option>
                        <option value="24">192-bit</option>
                        <option value="32">256-bit</option>
                        <option value="48">384-bit</option>
                        <option value="64">512-bit</option>
                    </select>
                </div>
                <div class="col-md-8 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _aesRequest.AllowEncrypt, value => _aesRequest.AllowEncrypt = value, "Encrypt")
                    @CapabilityCheckbox(() => _aesRequest.AllowDecrypt, value => _aesRequest.AllowDecrypt = value, "Decrypt")
                    @CapabilityCheckbox(() => _aesRequest.AllowWrap, value => _aesRequest.AllowWrap = value, "Wrap")
                    @CapabilityCheckbox(() => _aesRequest.AllowUnwrap, value => _aesRequest.AllowUnwrap = value, "Unwrap")
                </div>
                <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _aesRequest.Token, value => _aesRequest.Token = value, "Token object")
                    @CapabilityCheckbox(() => _aesRequest.Private, value => _aesRequest.Private = value, "Private")
                    @CapabilityCheckbox(() => _aesRequest.Sensitive, value => _aesRequest.Sensitive = value, "Sensitive")
                    @CapabilityCheckbox(() => _aesRequest.Extractable, value => _aesRequest.Extractable = value, "Extractable")
                </div>
                <div class="col-12">
                    <button class="btn btn-success" @onclick="GenerateAesAsync" disabled="@(!_isOperator || !CanGenerateAes)">Generate AES Key</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card shadow-sm h-100 workflow-card feature-card">
            <div class="card-header">Import AES key</div>
            <div class="card-body row g-3">
                @RenderOperationWarnings(GetImportWarnings())
                <div class="col-md-6">
                    <label class="form-label">Label</label>
                    <input class="form-control" @bind="_importAesRequest.Label" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">ID (hex)</label>
                    <input class="form-control" @bind="_importAesRequest.IdHex" />
                </div>
                <div class="col-12">
                    <label class="form-label">Key Value (hex)</label>
                    <textarea class="form-control font-monospace" rows="4" @bind="_importAesRequest.ValueHex"></textarea>
                    <div class="form-text">Raw key import uses <code>C_CreateObject</code> with AES secret-key attributes. Keep this field local and short-lived.</div>
                </div>
                <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _importAesRequest.AllowEncrypt, value => _importAesRequest.AllowEncrypt = value, "Encrypt")
                    @CapabilityCheckbox(() => _importAesRequest.AllowDecrypt, value => _importAesRequest.AllowDecrypt = value, "Decrypt")
                    @CapabilityCheckbox(() => _importAesRequest.AllowWrap, value => _importAesRequest.AllowWrap = value, "Wrap")
                    @CapabilityCheckbox(() => _importAesRequest.AllowUnwrap, value => _importAesRequest.AllowUnwrap = value, "Unwrap")
                </div>
                <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _importAesRequest.Token, value => _importAesRequest.Token = value, "Token object")
                    @CapabilityCheckbox(() => _importAesRequest.Private, value => _importAesRequest.Private = value, "Private")
                    @CapabilityCheckbox(() => _importAesRequest.Sensitive, value => _importAesRequest.Sensitive = value, "Sensitive")
                    @CapabilityCheckbox(() => _importAesRequest.Extractable, value => _importAesRequest.Extractable = value, "Extractable")
                </div>
                <div class="col-12">
                    <button class="btn btn-warning" @onclick="ImportAesAsync" disabled="@(!_isOperator || !CanImportAes)">Import AES Key</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card shadow-sm h-100 workflow-card feature-card">
            <div class="card-header">Generate RSA key pair</div>
            <div class="card-body row g-3">
                @RenderOperationWarnings(GetRsaWarnings())
                <div class="col-md-6">
                    <label class="form-label">Label</label>
                    <input class="form-control" @bind="_rsaRequest.Label" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">ID (hex)</label>
                    <input class="form-control" @bind="_rsaRequest.IdHex" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Modulus bits</label>
                    <select class="form-select" @bind="_rsaRequest.ModulusBits">
                        <option value="1024">1024</option>
                        <option value="2048">2048</option>
                        <option value="3072">3072</option>
                        <option value="4096">4096</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Public exponent</label>
                    <input class="form-control" @bind="_rsaRequest.PublicExponentHex" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    @CapabilityCheckbox(() => _rsaRequest.Token, value => _rsaRequest.Token = value, "Token objects")
                </div>
                <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _rsaRequest.AllowSign, value => _rsaRequest.AllowSign = value, "Sign")
                    @CapabilityCheckbox(() => _rsaRequest.AllowVerify, value => _rsaRequest.AllowVerify = value, "Verify")
                    @CapabilityCheckbox(() => _rsaRequest.AllowEncrypt, value => _rsaRequest.AllowEncrypt = value, "Encrypt")
                    @CapabilityCheckbox(() => _rsaRequest.AllowDecrypt, value => _rsaRequest.AllowDecrypt = value, "Decrypt")
                    @CapabilityCheckbox(() => _rsaRequest.Sensitive, value => _rsaRequest.Sensitive = value, "Sensitive private key")
                    @CapabilityCheckbox(() => _rsaRequest.Extractable, value => _rsaRequest.Extractable = value, "Extractable private key")
                </div>
                <div class="col-12">
                    <button class="btn btn-success" @onclick="GenerateRsaAsync" disabled="@(!_isOperator || !CanGenerateRsa)">Generate RSA Key Pair</button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (HasLoadedPage)
{
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Objects on page</div>
                    <div class="display-6 metric-meta">@_keys.Count</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Summary reads</div>
                    <div class="display-6 metric-meta">@(_keyPage?.SummaryReadCount ?? 0)</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Secret keys (page)</div>
                    <div class="display-6 metric-meta">@CountByClass("secretkey")</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Asymmetric keys (page)</div>
                    <div class="display-6 metric-meta">@(CountByClass("privatekey") + CountByClass("publickey"))</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4 panel-toolbar-card feature-card">
        <div class="card-body row g-3 align-items-end">
            <div class="col-xl-4 col-lg-5 col-md-6">
                <label class="form-label">Search</label>
                <input class="form-control" @bind="_searchText" @bind:event="oninput" @bind:after="OnKeyViewChangedAsync" placeholder="handle, label, id, class, key type..." />
            </div>
            <div class="col-xl-2 col-lg-3 col-md-6">
                <label class="form-label">Class</label>
                <select class="form-select" @bind="_classFilter" @bind:after="OnKeyViewChangedAsync">
                    <option value="all">All classes</option>
                    <option value="secretkey">Secret Key</option>
                    <option value="privatekey">Private Key</option>
                    <option value="publickey">Public Key</option>
                    <option value="data">Data</option>
                </select>
            </div>
            <div class="col-xl-2 col-lg-4 col-md-6">
                <label class="form-label">Capability</label>
                <select class="form-select" @bind="_capabilityFilter" @bind:after="OnKeyViewChangedAsync">
                    <option value="all">All capabilities</option>
                    <option value="encrypt">Encrypt</option>
                    <option value="decrypt">Decrypt</option>
                    <option value="sign">Sign</option>
                    <option value="verify">Verify</option>
                    <option value="wrap">Wrap</option>
                    <option value="unwrap">Unwrap</option>
                </select>
            </div>
            <div class="col-xl-2 col-lg-4 col-md-6">
                <label class="form-label">Sort</label>
                <select class="form-select" @bind="_sortMode" @bind:after="OnKeyViewChangedAsync">
                    <option value="handle">Handle</option>
                    <option value="label">Label</option>
                    <option value="class">Class</option>
                    <option value="capability">Capability count</option>
                </select>
            </div>
            <div class="col-xl-2 col-lg-4 col-md-6">
                <label class="form-label">Page size</label>
                <select class="form-select" @bind="_pageSize" @bind:after="OnPageSizeChangedAsync">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
            <div class="col-12 small text-muted">Showing @CurrentRangeStart-@CurrentRangeEnd on page @CurrentPageIndex. Server returned @_keys.Count object(s) after @(_keyPage?.SummaryReadCount ?? 0) summary read(s) and scanned @(_keyPage?.ScannedHandleCount ?? 0) handle(s).</div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-7">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="small text-muted">Page @CurrentPageIndex · @PageModeDescription</div>
                <div class="small text-muted">PIN is only used for protected reads/writes; no session is persisted here.</div>
            </div>
            @if (CurrentPageKeys.Count == 0)
            {
                <div class="empty-state">No objects matched the current filters.</div>
            }
            else
            {
                <div class="table-responsive table-shell">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Handle</th>
                                <th>Label</th>
                                <th>ID</th>
                                <th>Class</th>
                                <th>Key Type</th>
                                <th>Capabilities</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (HsmKeyObjectSummary key in CurrentPageKeys)
                            {
                                <tr class="@(_selectedDetailHandle == key.Handle ? "table-active" : null)">
                                    <td><span class="table-pill table-pill-code">@key.Handle</span></td>
                                    <td>
                                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(key.Label) ? "Unlabeled object" : key.Label)</div>
                                    </td>
                                    <td><span class="table-pill table-pill-code">@key.IdHex</span></td>
                                    <td><span class="table-pill">@key.ObjectClass</span></td>
                                    <td><span class="table-pill">@(string.IsNullOrWhiteSpace(key.KeyType) ? "n/a" : key.KeyType)</span></td>
                                    <td class="small capability-text">@CapabilitySummary(key)</td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => ShowDetailAsync(key)">Details</button>
                                            <button class="btn btn-outline-dark" @onclick="() => OpenLabInspect(key)" disabled="@(!_isOperator)">Lab</button>
                                            <button class="btn btn-outline-secondary" @onclick="() => BeginEdit(key)" disabled="@(!_isOperator)">Edit</button>
                                            <button class="btn btn-outline-info" @onclick="() => BeginCopy(key)" disabled="@(!_isOperator)">Copy</button>
                                            <button class="btn btn-outline-danger" @onclick="() => BeginDestroy(key)" disabled="@(!_isOperator)">Destroy</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-3">
                    <button class="btn btn-outline-secondary" @onclick="PreviousPageAsync" disabled="@(!HasPreviousPage)">Previous</button>
                    <div class="small text-muted">Page @CurrentPageIndex @(HasNextPage ? "· more available" : string.Empty)</div>
                    <button class="btn btn-outline-secondary" @onclick="NextPageAsync" disabled="@(!HasNextPage)">Next</button>
                </div>
            }
        </div>

        <div class="col-xl-5">
            @if (_selectedDetail is null && _destroyTarget is null && _editRequest is null && _copyRequest is null)
            {
                <div class="empty-state">Bir obje seçip detaylarını, edit/copy panelini veya destroy confirmation panelini aç.</div>
            }

            @if (_selectedDetail is not null)
            {
                <div class="card shadow-sm mb-4 feature-card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Object detail</span>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-dark" @onclick="() => OpenLabInspect(_selectedDetail)" disabled="@(!_isOperator)">Lab inspect</button>
                            <button class="btn btn-outline-secondary" @onclick="() => BeginEditFromDetail(_selectedDetail)">Edit attributes</button>
                            <button class="btn btn-outline-info" @onclick="() => BeginCopyFromDetail(_selectedDetail)">Copy object</button>
                            <button class="btn btn-outline-secondary" @onclick="ClearDetail">Close</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0 detail-grid">
                            <dt class="col-sm-4">Handle</dt><dd class="col-sm-8">@_selectedDetail.Handle</dd>
                            <dt class="col-sm-4">Label</dt><dd class="col-sm-8">@_selectedDetail.Label</dd>
                            <dt class="col-sm-4">ID</dt><dd class="col-sm-8"><code>@_selectedDetail.IdHex</code></dd>
                            <dt class="col-sm-4">Class</dt><dd class="col-sm-8">@_selectedDetail.ObjectClass</dd>
                            <dt class="col-sm-4">Key Type</dt><dd class="col-sm-8">@_selectedDetail.KeyType</dd>
                            <dt class="col-sm-4">Object Size</dt><dd class="col-sm-8">@FormatNullable(_selectedDetail.SizeBytes)</dd>
                            <dt class="col-sm-4">Value Length</dt><dd class="col-sm-8">@FormatNullable(_selectedDetail.ValueLength)</dd>
                            <dt class="col-sm-4">Modulus Bits</dt><dd class="col-sm-8">@FormatNullable(_selectedDetail.ModulusBits)</dd>
                            <dt class="col-sm-4">Flags</dt><dd class="col-sm-8">@string.Join(", ", GetFlags(_selectedDetail))</dd>
                        </dl>

                        @if (_selectedDetail.EditCapabilities.Warnings.Count != 0)
                        {
                            <div class="alert alert-warning small mt-3 mb-0">
                                <ul class="mb-0 ps-3">
                                    @foreach (string warning in _selectedDetail.EditCapabilities.Warnings)
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (_isOperator)
                        {
                            <hr />
                            <h2 class="h6">Lab presets</h2>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <button class="btn btn-sm btn-outline-dark" @onclick="() => OpenLabInspect(_selectedDetail)">Inspect</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick='() => OpenLabAttributePreset(_selectedDetail, "0x3")'>Raw Label</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick='() => OpenLabAttributePreset(_selectedDetail, "0x102")'>Raw ID</button>
                                @if (TryGetSignPreset(_selectedDetail, out string? signMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenLabCryptoPreset(_selectedDetail, Pkcs11LabOperation.SignData, signMechanism!)">Sign preset</button>
                                }
                                @if (TryGetVerifyPreset(_selectedDetail, out string? verifyMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenLabCryptoPreset(_selectedDetail, Pkcs11LabOperation.VerifySignature, verifyMechanism!)">Verify preset</button>
                                }
                                @if (TryGetEncryptPreset(_selectedDetail, out string? encryptMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => OpenLabCryptoPreset(_selectedDetail, Pkcs11LabOperation.EncryptData, encryptMechanism!)">Encrypt preset</button>
                                }
                                @if (TryGetEncryptOaepPreset(_selectedDetail, out string? encryptOaepMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => OpenLabRsaPreset(_selectedDetail, Pkcs11LabOperation.EncryptData, encryptOaepMechanism!, Pkcs11LabMechanismParameterProfile.RsaOaep, Pkcs11LabRsaHashProfile.Sha256)">Encrypt OAEP</button>
                                }
                                @if (TryGetDecryptPreset(_selectedDetail, out string? decryptMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => OpenLabCryptoPreset(_selectedDetail, Pkcs11LabOperation.DecryptData, decryptMechanism!)">Decrypt preset</button>
                                }
                                @if (TryGetDecryptOaepPreset(_selectedDetail, out string? decryptOaepMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => OpenLabRsaPreset(_selectedDetail, Pkcs11LabOperation.DecryptData, decryptOaepMechanism!, Pkcs11LabMechanismParameterProfile.RsaOaep, Pkcs11LabRsaHashProfile.Sha256)">Decrypt OAEP</button>
                                }
                                @if (TryGetSignPssPreset(_selectedDetail, out string? signPssMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenLabRsaPreset(_selectedDetail, Pkcs11LabOperation.SignData, signPssMechanism!, Pkcs11LabMechanismParameterProfile.RsaPss, Pkcs11LabRsaHashProfile.Sha256, pssSaltLength: 32)">Sign PSS</button>
                                }
                                @if (TryGetVerifyPssPreset(_selectedDetail, out string? verifyPssMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenLabRsaPreset(_selectedDetail, Pkcs11LabOperation.VerifySignature, verifyPssMechanism!, Pkcs11LabMechanismParameterProfile.RsaPss, Pkcs11LabRsaHashProfile.Sha256, pssSaltLength: 32)">Verify PSS</button>
                                }
                                @if (TryGetWrapPreset(_selectedDetail, out string? wrapMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => OpenLabWrapPreset(_selectedDetail, wrapMechanism!)">Wrap preset</button>
                                }
                                @if (TryGetUnwrapPreset(_selectedDetail, out string? unwrapMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => OpenLabUnwrapPreset(_selectedDetail, unwrapMechanism!)">Unwrap preset</button>
                                }
                            </div>
                        }

                        <hr />
                        <h2 class="h6">Readable attributes</h2>
                        <ul class="list-group list-group-flush">
                            @foreach (HsmObjectAttributeView detailAttribute in _selectedDetail.Attributes)
                            {
                                <li class="list-group-item d-flex justify-content-between gap-3 px-0">
                                    <span class="fw-semibold">@detailAttribute.Name</span>
                                    <span class="text-break @(detailAttribute.IsSensitive ? "text-warning" : null)">@detailAttribute.Value</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }

            @if (_editRequest is not null)
            {
                <div class="card border-secondary shadow-sm mb-4 feature-card workflow-card accent-card-secondary">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Edit supported attributes</span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">Close</button>
                    </div>
                    <div class="card-body row g-3">
                        @RenderOperationWarnings(GetEditWarnings())
                        <div class="col-md-6">
                            <label class="form-label">Handle</label>
                            <input class="form-control" value="@_editRequest.Handle" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Current Label</label>
                            <input class="form-control" value="@_editRequest.CurrentLabel" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">New Label</label>
                            <input class="form-control" @bind="_editRequest.Label" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">ID (hex)</label>
                            <input class="form-control" @bind="_editRequest.IdHex" />
                        </div>
                        <div class="col-12">
                            <div class="alert alert-warning small mb-0">Only attributes supported by both PKCS#11 and the token are updated. Disabled toggles below are obviously unsupported for the selected object type or because the object is not modifiable.</div>
                        </div>
                        <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                            @NullableCheckbox(() => _editRequest.Token, value => _editRequest.Token = value, "Token", CanEdit(x => x.CanEditToken))
                            @NullableCheckbox(() => _editRequest.Private, value => _editRequest.Private = value, "Private", CanEdit(x => x.CanEditPrivate))
                            @NullableCheckbox(() => _editRequest.Extractable, value => _editRequest.Extractable = value, "Extractable", CanEdit(x => x.CanEditExtractable))
                        </div>
                        <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                            @NullableCheckbox(() => _editRequest.AllowEncrypt, value => _editRequest.AllowEncrypt = value, "Encrypt", CanEdit(x => x.CanEditEncrypt))
                            @NullableCheckbox(() => _editRequest.AllowDecrypt, value => _editRequest.AllowDecrypt = value, "Decrypt", CanEdit(x => x.CanEditDecrypt))
                            @NullableCheckbox(() => _editRequest.AllowSign, value => _editRequest.AllowSign = value, "Sign", CanEdit(x => x.CanEditSign))
                            @NullableCheckbox(() => _editRequest.AllowVerify, value => _editRequest.AllowVerify = value, "Verify", CanEdit(x => x.CanEditVerify))
                            @NullableCheckbox(() => _editRequest.AllowWrap, value => _editRequest.AllowWrap = value, "Wrap", CanEdit(x => x.CanEditWrap))
                            @NullableCheckbox(() => _editRequest.AllowUnwrap, value => _editRequest.AllowUnwrap = value, "Unwrap", CanEdit(x => x.CanEditUnwrap))
                            @NullableCheckbox(() => _editRequest.AllowDerive, value => _editRequest.AllowDerive = value, "Derive", CanEdit(x => x.CanEditDerive))
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button class="btn btn-primary" @onclick="SaveEditAsync" disabled="@(!_isOperator || !CanSaveEdit)">Save changes</button>
                            <button class="btn btn-outline-secondary" @onclick="ResetEditBooleans">Reset toggles to keep existing</button>
                        </div>
                    </div>
                </div>
            }

            @if (_copyRequest is not null)
            {
                <div class="card border-info shadow-sm mb-4 feature-card workflow-card accent-card-info">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Copy object</span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelCopy">Close</button>
                    </div>
                    <div class="card-body row g-3">
                        @RenderOperationWarnings(GetCopyWarnings())
                        <div class="col-md-6">
                            <label class="form-label">Source handle</label>
                            <input class="form-control" value="@_copyRequest.SourceHandle" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Source label</label>
                            <input class="form-control" value="@_copyRequest.SourceLabel" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">New Label</label>
                            <input class="form-control" @bind="_copyRequest.Label" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">ID (hex)</label>
                            <input class="form-control" @bind="_copyRequest.IdHex" />
                        </div>
                        <div class="col-12">
                            <div class="alert alert-info small mb-0">This uses PKCS#11 <code>C_CopyObject</code>. The token still decides which attributes may be overridden during the copy.</div>
                        </div>
                        <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                            @NullableCheckbox(() => _copyRequest.Token, value => _copyRequest.Token = value, "Token", true)
                            @NullableCheckbox(() => _copyRequest.Private, value => _copyRequest.Private = value, "Private", true)
                            @NullableCheckbox(() => _copyRequest.Extractable, value => _copyRequest.Extractable = value, "Extractable", true)
                        </div>
                        <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                            @NullableCheckbox(() => _copyRequest.AllowEncrypt, value => _copyRequest.AllowEncrypt = value, "Encrypt", true)
                            @NullableCheckbox(() => _copyRequest.AllowDecrypt, value => _copyRequest.AllowDecrypt = value, "Decrypt", true)
                            @NullableCheckbox(() => _copyRequest.AllowSign, value => _copyRequest.AllowSign = value, "Sign", true)
                            @NullableCheckbox(() => _copyRequest.AllowVerify, value => _copyRequest.AllowVerify = value, "Verify", true)
                            @NullableCheckbox(() => _copyRequest.AllowWrap, value => _copyRequest.AllowWrap = value, "Wrap", true)
                            @NullableCheckbox(() => _copyRequest.AllowUnwrap, value => _copyRequest.AllowUnwrap = value, "Unwrap", true)
                            @NullableCheckbox(() => _copyRequest.AllowDerive, value => _copyRequest.AllowDerive = value, "Derive", true)
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button class="btn btn-info" @onclick="CopyAsync" disabled="@(!_isOperator || !CanCopyObject)">Copy object</button>
                            <button class="btn btn-outline-secondary" @onclick="ResetCopyBooleans">Reset overrides</button>
                        </div>
                    </div>
                </div>
            }

            @if (_destroyTarget is not null)
            {
                <div class="card border-danger shadow-sm feature-card workflow-card accent-card-danger">
                    <div class="card-header">Destroy object</div>
                    <div class="card-body">
                        <p class="mb-2">This permanently removes the selected object from the token.</p>
                        <ul>
                            <li><strong>Handle:</strong> @_destroyTarget.Handle</li>
                            <li><strong>Label:</strong> @_destroyTarget.Label</li>
                            <li><strong>Class:</strong> @_destroyTarget.ObjectClass</li>
                            <li><strong>Key Type:</strong> @_destroyTarget.KeyType</li>
                        </ul>
                        <div class="mb-3">
                            <label class="form-label">Type exact confirmation text</label>
                            <input class="form-control" @bind="_destroyRequest.ConfirmationText" />
                            <div class="form-text"><code>@DestroyConfirmationText</code></div>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" @bind="_destroyRequest.AcknowledgePermanentDeletion" />
                            <label class="form-check-label">I understand this deletion is permanent.</label>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-danger" @onclick="DestroyAsync" disabled="@(!_isOperator)">Destroy Now</button>
                            <button class="btn btn-outline-secondary" @onclick="CancelDestroy">Cancel</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
