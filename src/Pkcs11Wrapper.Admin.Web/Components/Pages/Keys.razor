@page "/keys"
@attribute [Authorize(Policy = AdminRoles.Viewer)]
@inject HsmAdminService Admin
@inject ProtectedPinStore PinStore
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Keys</PageTitle>

<h1>Keys / Objects</h1>
<p class="text-muted">Slot içindeki objeleri listele, capability-aware üret/import akışlarını çalıştır, desteklenen attribute’ları düzenle, obje kopyala ve destroy işlemlerinde typed confirmation kullan.</p>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert @(_statusIsError ? "alert-danger" : "alert-success")">@_statusMessage</div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body row g-3 align-items-end">
        <div class="col-lg-3">
            <label class="form-label">Device</label>
            <select class="form-select" @bind="_selectedDeviceId" @bind:after="OnSelectedDeviceChangedAsync">
                <option value="">Select device...</option>
                @foreach (HsmDeviceProfile device in _devices)
                {
                    <option value="@device.Id">@device.Name</option>
                }
            </select>
        </div>
        <div class="col-lg-2">
            <label class="form-label">Slot</label>
            <select class="form-select" @bind="_selectedSlotId" @bind:after="OnSelectedSlotChangedAsync">
                <option value="">Select slot...</option>
                @foreach (HsmSlotSummary slot in _slots)
                {
                    <option value="@slot.SlotId">@slot.SlotId - @slot.TokenLabel</option>
                }
            </select>
        </div>
        <div class="col-lg-2">
            <label class="form-label">Label Filter</label>
            <input class="form-control" @bind="_labelFilter" />
        </div>
        <div class="col-lg-2">
            <label class="form-label">User PIN</label>
            <input class="form-control" type="password" @bind="_userPin" />
            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" @bind="_rememberPin" />
                <label class="form-check-label">Remember in protected local storage</label>
            </div>
        </div>
        <div class="col-lg-3 d-flex gap-2">
            <button class="btn btn-primary" @onclick="LoadKeysAsync" disabled="@(!CanLoadKeys)">Load Keys</button>
            <button class="btn btn-outline-secondary" @onclick="ReloadSlotsAsync" disabled="@string.IsNullOrWhiteSpace(_selectedDeviceId)">Refresh Slots</button>
        </div>
    </div>
</div>

@if (_slotCapabilities is not null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Selected slot capability snapshot</span>
            <span class="small text-muted">Slot @_slotCapabilities.SlotId</span>
        </div>
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="badge @( _slotCapabilities.TokenPresent ? "text-bg-success" : "text-bg-danger")">@(_slotCapabilities.TokenPresent ? "Token present" : "No token")</span>
                <span class="badge @(_slotCapabilities.SupportsAesKeyGeneration ? "text-bg-success" : "text-bg-secondary")">AES generate</span>
                <span class="badge @(_slotCapabilities.SupportsAesObjectImport ? "text-bg-success" : "text-bg-secondary")">AES import/create</span>
                <span class="badge @(_slotCapabilities.SupportsRsaKeyPairGeneration ? "text-bg-success" : "text-bg-secondary")">RSA keypair generate</span>
            </div>

            @if (_slotCapabilities.Warnings.Count != 0)
            {
                <div class="alert alert-warning small">
                    <ul class="mb-0 ps-3">
                        @foreach (string warning in _slotCapabilities.Warnings)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                </div>
            }

            <div class="row g-3 small">
                @foreach (SlotMechanismSupport mechanism in _slotCapabilities.Mechanisms)
                {
                    <div class="col-xl-4 col-md-6">
                        <div class="border rounded p-2 h-100">
                            <div class="fw-semibold">@mechanism.Name</div>
                            <div class="text-muted"><code>@mechanism.TypeHex</code></div>
                            <div class="mt-1">@(mechanism.Available ? mechanism.Summary : "Not exposed by slot")</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="row g-4 mb-4">
    <div class="col-xl-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">Generate AES key</div>
            <div class="card-body row g-3">
                @RenderOperationWarnings(GetAesWarnings())
                <div class="col-md-6">
                    <label class="form-label">Label</label>
                    <input class="form-control" @bind="_aesRequest.Label" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">ID (hex)</label>
                    <input class="form-control" @bind="_aesRequest.IdHex" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Size</label>
                    <select class="form-select" @bind="_aesRequest.SizeBytes">
                        <option value="16">128-bit</option>
                        <option value="24">192-bit</option>
                        <option value="32">256-bit</option>
                        <option value="48">384-bit</option>
                        <option value="64">512-bit</option>
                    </select>
                </div>
                <div class="col-md-8 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _aesRequest.AllowEncrypt, value => _aesRequest.AllowEncrypt = value, "Encrypt")
                    @CapabilityCheckbox(() => _aesRequest.AllowDecrypt, value => _aesRequest.AllowDecrypt = value, "Decrypt")
                    @CapabilityCheckbox(() => _aesRequest.AllowWrap, value => _aesRequest.AllowWrap = value, "Wrap")
                    @CapabilityCheckbox(() => _aesRequest.AllowUnwrap, value => _aesRequest.AllowUnwrap = value, "Unwrap")
                </div>
                <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _aesRequest.Token, value => _aesRequest.Token = value, "Token object")
                    @CapabilityCheckbox(() => _aesRequest.Private, value => _aesRequest.Private = value, "Private")
                    @CapabilityCheckbox(() => _aesRequest.Sensitive, value => _aesRequest.Sensitive = value, "Sensitive")
                    @CapabilityCheckbox(() => _aesRequest.Extractable, value => _aesRequest.Extractable = value, "Extractable")
                </div>
                <div class="col-12">
                    <button class="btn btn-success" @onclick="GenerateAesAsync" disabled="@(!_isOperator || !CanGenerateAes)">Generate AES Key</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">Import AES key</div>
            <div class="card-body row g-3">
                @RenderOperationWarnings(GetImportWarnings())
                <div class="col-md-6">
                    <label class="form-label">Label</label>
                    <input class="form-control" @bind="_importAesRequest.Label" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">ID (hex)</label>
                    <input class="form-control" @bind="_importAesRequest.IdHex" />
                </div>
                <div class="col-12">
                    <label class="form-label">Key Value (hex)</label>
                    <textarea class="form-control font-monospace" rows="4" @bind="_importAesRequest.ValueHex"></textarea>
                    <div class="form-text">Raw key import uses <code>C_CreateObject</code> with AES secret-key attributes. Keep this field local and short-lived.</div>
                </div>
                <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _importAesRequest.AllowEncrypt, value => _importAesRequest.AllowEncrypt = value, "Encrypt")
                    @CapabilityCheckbox(() => _importAesRequest.AllowDecrypt, value => _importAesRequest.AllowDecrypt = value, "Decrypt")
                    @CapabilityCheckbox(() => _importAesRequest.AllowWrap, value => _importAesRequest.AllowWrap = value, "Wrap")
                    @CapabilityCheckbox(() => _importAesRequest.AllowUnwrap, value => _importAesRequest.AllowUnwrap = value, "Unwrap")
                </div>
                <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _importAesRequest.Token, value => _importAesRequest.Token = value, "Token object")
                    @CapabilityCheckbox(() => _importAesRequest.Private, value => _importAesRequest.Private = value, "Private")
                    @CapabilityCheckbox(() => _importAesRequest.Sensitive, value => _importAesRequest.Sensitive = value, "Sensitive")
                    @CapabilityCheckbox(() => _importAesRequest.Extractable, value => _importAesRequest.Extractable = value, "Extractable")
                </div>
                <div class="col-12">
                    <button class="btn btn-warning" @onclick="ImportAesAsync" disabled="@(!_isOperator || !CanImportAes)">Import AES Key</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card shadow-sm h-100">
            <div class="card-header">Generate RSA key pair</div>
            <div class="card-body row g-3">
                @RenderOperationWarnings(GetRsaWarnings())
                <div class="col-md-6">
                    <label class="form-label">Label</label>
                    <input class="form-control" @bind="_rsaRequest.Label" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">ID (hex)</label>
                    <input class="form-control" @bind="_rsaRequest.IdHex" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Modulus bits</label>
                    <select class="form-select" @bind="_rsaRequest.ModulusBits">
                        <option value="1024">1024</option>
                        <option value="2048">2048</option>
                        <option value="3072">3072</option>
                        <option value="4096">4096</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Public exponent</label>
                    <input class="form-control" @bind="_rsaRequest.PublicExponentHex" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    @CapabilityCheckbox(() => _rsaRequest.Token, value => _rsaRequest.Token = value, "Token objects")
                </div>
                <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                    @CapabilityCheckbox(() => _rsaRequest.AllowSign, value => _rsaRequest.AllowSign = value, "Sign")
                    @CapabilityCheckbox(() => _rsaRequest.AllowVerify, value => _rsaRequest.AllowVerify = value, "Verify")
                    @CapabilityCheckbox(() => _rsaRequest.AllowEncrypt, value => _rsaRequest.AllowEncrypt = value, "Encrypt")
                    @CapabilityCheckbox(() => _rsaRequest.AllowDecrypt, value => _rsaRequest.AllowDecrypt = value, "Decrypt")
                    @CapabilityCheckbox(() => _rsaRequest.Sensitive, value => _rsaRequest.Sensitive = value, "Sensitive private key")
                    @CapabilityCheckbox(() => _rsaRequest.Extractable, value => _rsaRequest.Extractable = value, "Extractable private key")
                </div>
                <div class="col-12">
                    <button class="btn btn-success" @onclick="GenerateRsaAsync" disabled="@(!_isOperator || !CanGenerateRsa)">Generate RSA Key Pair</button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (_keys.Count != 0)
{
    <div class="row g-4">
        <div class="col-xl-7">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="small text-muted">Loaded @_keys.Count object(s)</div>
                <div class="small text-muted">PIN is only used for protected reads/writes; no session is persisted here.</div>
            </div>
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Handle</th>
                            <th>Label</th>
                            <th>ID</th>
                            <th>Class</th>
                            <th>Key Type</th>
                            <th>Capabilities</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (HsmKeyObjectSummary key in _keys)
                        {
                            <tr class="@(_selectedDetailHandle == key.Handle ? "table-active" : null)">
                                <td>@key.Handle</td>
                                <td>@key.Label</td>
                                <td><code>@key.IdHex</code></td>
                                <td>@key.ObjectClass</td>
                                <td>@key.KeyType</td>
                                <td class="small">@CapabilitySummary(key)</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" @onclick="() => ShowDetailAsync(key)">Details</button>
                                        <button class="btn btn-outline-dark" @onclick="() => OpenLabInspect(key)" disabled="@(!_isOperator)">Lab</button>
                                        <button class="btn btn-outline-secondary" @onclick="() => BeginEdit(key)" disabled="@(!_isOperator)">Edit</button>
                                        <button class="btn btn-outline-info" @onclick="() => BeginCopy(key)" disabled="@(!_isOperator)">Copy</button>
                                        <button class="btn btn-outline-danger" @onclick="() => BeginDestroy(key)" disabled="@(!_isOperator)">Destroy</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-xl-5">
            @if (_selectedDetail is null && _destroyTarget is null && _editRequest is null && _copyRequest is null)
            {
                <div class="card shadow-sm">
                    <div class="card-body text-muted">Bir obje seçip detaylarını, edit/copy panelini veya destroy confirmation panelini aç.</div>
                </div>
            }

            @if (_selectedDetail is not null)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Object detail</span>
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-dark" @onclick="() => OpenLabInspect(_selectedDetail)" disabled="@(!_isOperator)">Lab inspect</button>
                            <button class="btn btn-outline-secondary" @onclick="() => BeginEditFromDetail(_selectedDetail)">Edit attributes</button>
                            <button class="btn btn-outline-info" @onclick="() => BeginCopyFromDetail(_selectedDetail)">Copy object</button>
                            <button class="btn btn-outline-secondary" @onclick="ClearDetail">Close</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Handle</dt><dd class="col-sm-8">@_selectedDetail.Handle</dd>
                            <dt class="col-sm-4">Label</dt><dd class="col-sm-8">@_selectedDetail.Label</dd>
                            <dt class="col-sm-4">ID</dt><dd class="col-sm-8"><code>@_selectedDetail.IdHex</code></dd>
                            <dt class="col-sm-4">Class</dt><dd class="col-sm-8">@_selectedDetail.ObjectClass</dd>
                            <dt class="col-sm-4">Key Type</dt><dd class="col-sm-8">@_selectedDetail.KeyType</dd>
                            <dt class="col-sm-4">Object Size</dt><dd class="col-sm-8">@FormatNullable(_selectedDetail.SizeBytes)</dd>
                            <dt class="col-sm-4">Value Length</dt><dd class="col-sm-8">@FormatNullable(_selectedDetail.ValueLength)</dd>
                            <dt class="col-sm-4">Modulus Bits</dt><dd class="col-sm-8">@FormatNullable(_selectedDetail.ModulusBits)</dd>
                            <dt class="col-sm-4">Flags</dt><dd class="col-sm-8">@string.Join(", ", GetFlags(_selectedDetail))</dd>
                        </dl>

                        @if (_selectedDetail.EditCapabilities.Warnings.Count != 0)
                        {
                            <div class="alert alert-warning small mt-3 mb-0">
                                <ul class="mb-0 ps-3">
                                    @foreach (string warning in _selectedDetail.EditCapabilities.Warnings)
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (_isOperator)
                        {
                            <hr />
                            <h2 class="h6">Lab presets</h2>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <button class="btn btn-sm btn-outline-dark" @onclick="() => OpenLabInspect(_selectedDetail)">Inspect</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick='() => OpenLabAttributePreset(_selectedDetail, "0x3")'>Raw Label</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick='() => OpenLabAttributePreset(_selectedDetail, "0x102")'>Raw ID</button>
                                @if (TryGetSignPreset(_selectedDetail, out string? signMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenLabCryptoPreset(_selectedDetail, Pkcs11LabOperation.SignData, signMechanism!)">Sign preset</button>
                                }
                                @if (TryGetVerifyPreset(_selectedDetail, out string? verifyMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenLabCryptoPreset(_selectedDetail, Pkcs11LabOperation.VerifySignature, verifyMechanism!)">Verify preset</button>
                                }
                                @if (TryGetEncryptPreset(_selectedDetail, out string? encryptMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => OpenLabCryptoPreset(_selectedDetail, Pkcs11LabOperation.EncryptData, encryptMechanism!)">Encrypt preset</button>
                                }
                                @if (TryGetEncryptOaepPreset(_selectedDetail, out string? encryptOaepMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => OpenLabRsaPreset(_selectedDetail, Pkcs11LabOperation.EncryptData, encryptOaepMechanism!, Pkcs11LabMechanismParameterProfile.RsaOaep, Pkcs11LabRsaHashProfile.Sha256)">Encrypt OAEP</button>
                                }
                                @if (TryGetDecryptPreset(_selectedDetail, out string? decryptMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => OpenLabCryptoPreset(_selectedDetail, Pkcs11LabOperation.DecryptData, decryptMechanism!)">Decrypt preset</button>
                                }
                                @if (TryGetDecryptOaepPreset(_selectedDetail, out string? decryptOaepMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => OpenLabRsaPreset(_selectedDetail, Pkcs11LabOperation.DecryptData, decryptOaepMechanism!, Pkcs11LabMechanismParameterProfile.RsaOaep, Pkcs11LabRsaHashProfile.Sha256)">Decrypt OAEP</button>
                                }
                                @if (TryGetSignPssPreset(_selectedDetail, out string? signPssMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenLabRsaPreset(_selectedDetail, Pkcs11LabOperation.SignData, signPssMechanism!, Pkcs11LabMechanismParameterProfile.RsaPss, Pkcs11LabRsaHashProfile.Sha256, pssSaltLength: 32)">Sign PSS</button>
                                }
                                @if (TryGetVerifyPssPreset(_selectedDetail, out string? verifyPssMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenLabRsaPreset(_selectedDetail, Pkcs11LabOperation.VerifySignature, verifyPssMechanism!, Pkcs11LabMechanismParameterProfile.RsaPss, Pkcs11LabRsaHashProfile.Sha256, pssSaltLength: 32)">Verify PSS</button>
                                }
                                @if (TryGetWrapPreset(_selectedDetail, out string? wrapMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => OpenLabWrapPreset(_selectedDetail, wrapMechanism!)">Wrap preset</button>
                                }
                                @if (TryGetUnwrapPreset(_selectedDetail, out string? unwrapMechanism))
                                {
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => OpenLabUnwrapPreset(_selectedDetail, unwrapMechanism!)">Unwrap preset</button>
                                }
                            </div>
                        }

                        <hr />
                        <h2 class="h6">Readable attributes</h2>
                        <ul class="list-group list-group-flush">
                            @foreach (HsmObjectAttributeView detailAttribute in _selectedDetail.Attributes)
                            {
                                <li class="list-group-item d-flex justify-content-between gap-3 px-0">
                                    <span class="fw-semibold">@detailAttribute.Name</span>
                                    <span class="text-break @(detailAttribute.IsSensitive ? "text-warning" : null)">@detailAttribute.Value</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }

            @if (_editRequest is not null)
            {
                <div class="card border-secondary shadow-sm mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Edit supported attributes</span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">Close</button>
                    </div>
                    <div class="card-body row g-3">
                        @RenderOperationWarnings(GetEditWarnings())
                        <div class="col-md-6">
                            <label class="form-label">Handle</label>
                            <input class="form-control" value="@_editRequest.Handle" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Current Label</label>
                            <input class="form-control" value="@_editRequest.CurrentLabel" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">New Label</label>
                            <input class="form-control" @bind="_editRequest.Label" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">ID (hex)</label>
                            <input class="form-control" @bind="_editRequest.IdHex" />
                        </div>
                        <div class="col-12">
                            <div class="alert alert-warning small mb-0">Only attributes supported by both PKCS#11 and the token are updated. Disabled toggles below are obviously unsupported for the selected object type or because the object is not modifiable.</div>
                        </div>
                        <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                            @NullableCheckbox(() => _editRequest.Token, value => _editRequest.Token = value, "Token", CanEdit(x => x.CanEditToken))
                            @NullableCheckbox(() => _editRequest.Private, value => _editRequest.Private = value, "Private", CanEdit(x => x.CanEditPrivate))
                            @NullableCheckbox(() => _editRequest.Extractable, value => _editRequest.Extractable = value, "Extractable", CanEdit(x => x.CanEditExtractable))
                        </div>
                        <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                            @NullableCheckbox(() => _editRequest.AllowEncrypt, value => _editRequest.AllowEncrypt = value, "Encrypt", CanEdit(x => x.CanEditEncrypt))
                            @NullableCheckbox(() => _editRequest.AllowDecrypt, value => _editRequest.AllowDecrypt = value, "Decrypt", CanEdit(x => x.CanEditDecrypt))
                            @NullableCheckbox(() => _editRequest.AllowSign, value => _editRequest.AllowSign = value, "Sign", CanEdit(x => x.CanEditSign))
                            @NullableCheckbox(() => _editRequest.AllowVerify, value => _editRequest.AllowVerify = value, "Verify", CanEdit(x => x.CanEditVerify))
                            @NullableCheckbox(() => _editRequest.AllowWrap, value => _editRequest.AllowWrap = value, "Wrap", CanEdit(x => x.CanEditWrap))
                            @NullableCheckbox(() => _editRequest.AllowUnwrap, value => _editRequest.AllowUnwrap = value, "Unwrap", CanEdit(x => x.CanEditUnwrap))
                            @NullableCheckbox(() => _editRequest.AllowDerive, value => _editRequest.AllowDerive = value, "Derive", CanEdit(x => x.CanEditDerive))
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button class="btn btn-primary" @onclick="SaveEditAsync" disabled="@(!_isOperator || !CanSaveEdit)">Save changes</button>
                            <button class="btn btn-outline-secondary" @onclick="ResetEditBooleans">Reset toggles to keep existing</button>
                        </div>
                    </div>
                </div>
            }

            @if (_copyRequest is not null)
            {
                <div class="card border-info shadow-sm mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Copy object</span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelCopy">Close</button>
                    </div>
                    <div class="card-body row g-3">
                        @RenderOperationWarnings(GetCopyWarnings())
                        <div class="col-md-6">
                            <label class="form-label">Source handle</label>
                            <input class="form-control" value="@_copyRequest.SourceHandle" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Source label</label>
                            <input class="form-control" value="@_copyRequest.SourceLabel" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">New Label</label>
                            <input class="form-control" @bind="_copyRequest.Label" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">ID (hex)</label>
                            <input class="form-control" @bind="_copyRequest.IdHex" />
                        </div>
                        <div class="col-12">
                            <div class="alert alert-info small mb-0">This uses PKCS#11 <code>C_CopyObject</code>. The token still decides which attributes may be overridden during the copy.</div>
                        </div>
                        <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                            @NullableCheckbox(() => _copyRequest.Token, value => _copyRequest.Token = value, "Token", true)
                            @NullableCheckbox(() => _copyRequest.Private, value => _copyRequest.Private = value, "Private", true)
                            @NullableCheckbox(() => _copyRequest.Extractable, value => _copyRequest.Extractable = value, "Extractable", true)
                        </div>
                        <div class="col-12 d-flex flex-wrap gap-3 align-items-center">
                            @NullableCheckbox(() => _copyRequest.AllowEncrypt, value => _copyRequest.AllowEncrypt = value, "Encrypt", true)
                            @NullableCheckbox(() => _copyRequest.AllowDecrypt, value => _copyRequest.AllowDecrypt = value, "Decrypt", true)
                            @NullableCheckbox(() => _copyRequest.AllowSign, value => _copyRequest.AllowSign = value, "Sign", true)
                            @NullableCheckbox(() => _copyRequest.AllowVerify, value => _copyRequest.AllowVerify = value, "Verify", true)
                            @NullableCheckbox(() => _copyRequest.AllowWrap, value => _copyRequest.AllowWrap = value, "Wrap", true)
                            @NullableCheckbox(() => _copyRequest.AllowUnwrap, value => _copyRequest.AllowUnwrap = value, "Unwrap", true)
                            @NullableCheckbox(() => _copyRequest.AllowDerive, value => _copyRequest.AllowDerive = value, "Derive", true)
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button class="btn btn-info" @onclick="CopyAsync" disabled="@(!_isOperator || !CanCopyObject)">Copy object</button>
                            <button class="btn btn-outline-secondary" @onclick="ResetCopyBooleans">Reset overrides</button>
                        </div>
                    </div>
                </div>
            }

            @if (_destroyTarget is not null)
            {
                <div class="card border-danger shadow-sm">
                    <div class="card-header bg-danger-subtle text-danger-emphasis">Destroy object</div>
                    <div class="card-body">
                        <p class="mb-2">This permanently removes the selected object from the token.</p>
                        <ul>
                            <li><strong>Handle:</strong> @_destroyTarget.Handle</li>
                            <li><strong>Label:</strong> @_destroyTarget.Label</li>
                            <li><strong>Class:</strong> @_destroyTarget.ObjectClass</li>
                            <li><strong>Key Type:</strong> @_destroyTarget.KeyType</li>
                        </ul>
                        <div class="mb-3">
                            <label class="form-label">Type exact confirmation text</label>
                            <input class="form-control" @bind="_destroyRequest.ConfirmationText" />
                            <div class="form-text"><code>@DestroyConfirmationText</code></div>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" @bind="_destroyRequest.AcknowledgePermanentDeletion" />
                            <label class="form-check-label">I understand this deletion is permanent.</label>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-danger" @onclick="DestroyAsync" disabled="@(!_isOperator)">Destroy Now</button>
                            <button class="btn btn-outline-secondary" @onclick="CancelDestroy">Cancel</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private IReadOnlyList<HsmDeviceProfile> _devices = [];
    private IReadOnlyList<HsmSlotSummary> _slots = [];
    private IReadOnlyList<HsmKeyObjectSummary> _keys = [];
    private string? _selectedDeviceId;
    private string? _selectedSlotId;
    private string? _labelFilter;
    private string? _userPin;
    private bool _rememberPin;
    private HsmObjectDetail? _selectedDetail;
    private nuint? _selectedDetailHandle;
    private HsmKeyObjectSummary? _destroyTarget;
    private DestroyObjectRequest _destroyRequest = new();
    private UpdateObjectAttributesRequest? _editRequest;
    private CopyObjectRequest? _copyRequest;
    private KeyManagementSlotCapabilities? _slotCapabilities;
    private GenerateAesKeyRequest _aesRequest = new() { Label = "aes-admin-" + Guid.NewGuid().ToString("N")[..10] };
    private ImportAesKeyRequest _importAesRequest = new() { Label = "aes-import-" + Guid.NewGuid().ToString("N")[..10] };
    private GenerateRsaKeyPairRequest _rsaRequest = new() { Label = "rsa-admin-" + Guid.NewGuid().ToString("N")[..10] };
    private string? _statusMessage;
    private bool _statusIsError;
    private bool _isOperator;

    private bool CanLoadKeys => Guid.TryParse(_selectedDeviceId, out _) && nuint.TryParse(_selectedSlotId, out _);
    private bool CanManageKeys => CanLoadKeys && !string.IsNullOrWhiteSpace(_userPin);
    private bool CanGenerateAes => CanManageKeys && _slotCapabilities?.SupportsAesKeyGeneration == true;
    private bool CanImportAes => CanManageKeys && _slotCapabilities?.SupportsAesObjectImport == true;
    private bool CanGenerateRsa => CanManageKeys && _slotCapabilities?.SupportsRsaKeyPairGeneration == true;
    private bool CanSaveEdit => CanManageKeys && _editRequest is not null && (_selectedDetail?.EditCapabilities.CanEditAnyAttributes ?? true);
    private bool CanCopyObject => CanManageKeys && _copyRequest is not null && _slotCapabilities?.TokenPresent == true;
    private string DestroyConfirmationText => _destroyTarget is null ? string.Empty : HsmAdminService.BuildDestroyConfirmationText(_destroyTarget.Handle, _destroyTarget.Label);

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isOperator = state.User.IsInRole(AdminRoles.Operator) || state.User.IsInRole(AdminRoles.Admin);
        _devices = await Admin.GetDevicesAsync();
        _selectedDeviceId = _devices.FirstOrDefault()?.Id.ToString();
        await ReloadSlotsAsync();
    }

    private async Task OnSelectedDeviceChangedAsync() => await ReloadSlotsAsync();
    private async Task OnSelectedSlotChangedAsync() => await ReloadSlotCapabilitiesAsync();

    private async Task ReloadSlotsAsync()
    {
        _keys = [];
        _selectedDetail = null;
        _selectedDetailHandle = null;
        _destroyTarget = null;
        _destroyRequest = new();
        _editRequest = null;
        _copyRequest = null;
        _slotCapabilities = null;

        if (!Guid.TryParse(_selectedDeviceId, out Guid deviceId))
        {
            _slots = [];
            return;
        }

        _slots = await Admin.GetSlotsAsync(deviceId);
        _selectedSlotId = _slots.FirstOrDefault()?.SlotId.ToString();
        await LoadProtectedPinAsync();
        await ReloadSlotCapabilitiesAsync();
    }

    private async Task LoadProtectedPinAsync()
    {
        if (TryGetSelection(out Guid deviceId, out nuint slotId))
        {
            _userPin = await PinStore.TryGetAsync(deviceId, slotId, "keys");
            _rememberPin = !string.IsNullOrWhiteSpace(_userPin);
        }
    }

    private async Task ReloadSlotCapabilitiesAsync()
    {
        _slotCapabilities = null;
        if (!TryGetSelection(out Guid deviceId, out nuint slotId))
        {
            return;
        }

        try
        {
            _slotCapabilities = await Admin.GetKeyManagementCapabilitiesAsync(deviceId, slotId);
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task LoadKeysAsync()
    {
        try
        {
            if (!TryGetSelection(out Guid deviceId, out nuint slotId))
            {
                return;
            }

            _keys = await Admin.GetKeysAsync(deviceId, slotId, _userPin, _labelFilter);
            await PersistPinAsync(deviceId, slotId);
            _destroyTarget = null;
            _destroyRequest = new();
            _selectedDetail = null;
            _selectedDetailHandle = null;
            _editRequest = null;
            _copyRequest = null;
            SetStatus($"Loaded {_keys.Count} object(s).", false);
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task ShowDetailAsync(HsmKeyObjectSummary key)
    {
        try
        {
            if (!TryGetSelection(out Guid deviceId, out nuint slotId))
            {
                return;
            }

            _selectedDetail = await Admin.GetObjectDetailAsync(deviceId, slotId, key.Handle, _userPin);
            _selectedDetailHandle = key.Handle;
            _destroyTarget = null;
            _destroyRequest = new();
            _editRequest = null;
            _copyRequest = null;
            SetStatus($"Loaded detail for handle {key.Handle}.", false);
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private void ClearDetail()
    {
        _selectedDetail = null;
        _selectedDetailHandle = null;
    }

    private void OpenLabInspect(HsmKeyObjectSummary key)
        => Navigation.NavigateTo(BuildLabUri(key.DeviceId, key.SlotId, Pkcs11LabOperation.InspectObject, primaryHandle: key.Handle));

    private void OpenLabInspect(HsmObjectDetail detail)
        => Navigation.NavigateTo(BuildLabUri(detail.DeviceId, detail.SlotId, Pkcs11LabOperation.InspectObject, primaryHandle: detail.Handle));

    private void OpenLabAttributePreset(HsmObjectDetail detail, string attributeType)
        => Navigation.NavigateTo(BuildLabUri(detail.DeviceId, detail.SlotId, Pkcs11LabOperation.ReadAttribute, primaryHandle: detail.Handle, attributeType: attributeType));

    private void OpenLabCryptoPreset(HsmObjectDetail detail, Pkcs11LabOperation operation, string mechanism)
        => Navigation.NavigateTo(BuildLabUri(detail.DeviceId, detail.SlotId, operation, primaryHandle: detail.Handle, mechanism: mechanism));

    private void OpenLabRsaPreset(HsmObjectDetail detail, Pkcs11LabOperation operation, string mechanism, Pkcs11LabMechanismParameterProfile parameterProfile, Pkcs11LabRsaHashProfile rsaHashProfile, int? pssSaltLength = null)
        => Navigation.NavigateTo(
            BuildLabUri(
                detail.DeviceId,
                detail.SlotId,
                operation,
                primaryHandle: detail.Handle,
                mechanism: mechanism,
                parameterProfile: parameterProfile,
                rsaHashProfile: rsaHashProfile,
                pssSaltLength: pssSaltLength));

    private void OpenLabWrapPreset(HsmObjectDetail detail, string mechanism)
        => Navigation.NavigateTo(BuildLabUri(detail.DeviceId, detail.SlotId, Pkcs11LabOperation.WrapKey, secondaryHandle: detail.Handle, mechanism: mechanism));

    private void OpenLabUnwrapPreset(HsmObjectDetail detail, string mechanism)
        => Navigation.NavigateTo(BuildLabUri(detail.DeviceId, detail.SlotId, Pkcs11LabOperation.UnwrapAesKey, primaryHandle: detail.Handle, mechanism: mechanism));

    private void BeginEdit(HsmKeyObjectSummary key)
    {
        _editRequest = new UpdateObjectAttributesRequest { Handle = key.Handle, CurrentLabel = key.Label, Label = key.Label ?? $"object-{key.Handle}", IdHex = key.IdHex };
        _copyRequest = null;
        _destroyTarget = null;
        _selectedDetail = null;
        _selectedDetailHandle = key.Handle;
    }

    private void BeginEditFromDetail(HsmObjectDetail detail)
    {
        _editRequest = new UpdateObjectAttributesRequest { Handle = detail.Handle, CurrentLabel = detail.Label, Label = detail.Label ?? $"object-{detail.Handle}", IdHex = detail.IdHex };
        _copyRequest = null;
        _destroyTarget = null;
    }

    private void BeginCopy(HsmKeyObjectSummary key)
    {
        _copyRequest = new CopyObjectRequest { SourceHandle = key.Handle, SourceLabel = key.Label, SourceObjectClass = key.ObjectClass, Label = $"{(key.Label ?? "object")}-copy", IdHex = key.IdHex };
        _editRequest = null;
        _destroyTarget = null;
        _selectedDetail = null;
        _selectedDetailHandle = key.Handle;
    }

    private void BeginCopyFromDetail(HsmObjectDetail detail)
    {
        _copyRequest = new CopyObjectRequest { SourceHandle = detail.Handle, SourceLabel = detail.Label, SourceObjectClass = detail.ObjectClass, Label = $"{(detail.Label ?? "object")}-copy", IdHex = detail.IdHex };
        _editRequest = null;
        _destroyTarget = null;
    }

    private void ResetEditBooleans()
    {
        if (_editRequest is null) return;
        _editRequest.Token = null;
        _editRequest.Private = null;
        _editRequest.Extractable = null;
        _editRequest.AllowEncrypt = null;
        _editRequest.AllowDecrypt = null;
        _editRequest.AllowSign = null;
        _editRequest.AllowVerify = null;
        _editRequest.AllowWrap = null;
        _editRequest.AllowUnwrap = null;
        _editRequest.AllowDerive = null;
    }

    private void ResetCopyBooleans()
    {
        if (_copyRequest is null) return;
        _copyRequest.Token = null;
        _copyRequest.Private = null;
        _copyRequest.Extractable = null;
        _copyRequest.AllowEncrypt = null;
        _copyRequest.AllowDecrypt = null;
        _copyRequest.AllowSign = null;
        _copyRequest.AllowVerify = null;
        _copyRequest.AllowWrap = null;
        _copyRequest.AllowUnwrap = null;
        _copyRequest.AllowDerive = null;
    }

    private void CancelEdit() => _editRequest = null;
    private void CancelCopy() => _copyRequest = null;

    private void BeginDestroy(HsmKeyObjectSummary key)
    {
        _destroyTarget = key;
        _selectedDetail = null;
        _selectedDetailHandle = null;
        _editRequest = null;
        _copyRequest = null;
        _destroyRequest = new DestroyObjectRequest { Handle = key.Handle, Label = key.Label, UserPin = _userPin ?? string.Empty };
    }

    private void CancelDestroy()
    {
        _destroyTarget = null;
        _destroyRequest = new();
    }

    private async Task SaveEditAsync()
    {
        try
        {
            if (_editRequest is null || !TryGetSelection(out Guid deviceId, out nuint slotId)) return;
            await PersistPinAsync(deviceId, slotId);
            KeyManagementResult result = await Admin.UpdateObjectAttributesAsync(deviceId, slotId, _editRequest, _userPin ?? string.Empty);
            SetStatus(result.Summary, false);
            _labelFilter = result.Label;
            _editRequest = null;
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task CopyAsync()
    {
        try
        {
            if (_copyRequest is null || !TryGetSelection(out Guid deviceId, out nuint slotId)) return;
            await PersistPinAsync(deviceId, slotId);
            KeyManagementResult result = await Admin.CopyObjectAsync(deviceId, slotId, _copyRequest, _userPin ?? string.Empty);
            SetStatus(result.Summary, false);
            _labelFilter = result.Label;
            _copyRequest = null;
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task DestroyAsync()
    {
        try
        {
            if (_destroyTarget is null || !TryGetSelection(out Guid deviceId, out nuint slotId)) return;
            await PersistPinAsync(deviceId, slotId);
            _destroyRequest.Handle = _destroyTarget.Handle;
            _destroyRequest.Label = _destroyTarget.Label;
            _destroyRequest.UserPin = _userPin ?? string.Empty;
            await Admin.DestroyObjectAsync(deviceId, slotId, _destroyRequest);
            SetStatus($"Destroyed object handle {_destroyTarget.Handle}.", false);
            _destroyTarget = null;
            _destroyRequest = new();
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task GenerateAesAsync()
    {
        try
        {
            if (!CanGenerateAes || !TryGetSelection(out Guid deviceId, out nuint slotId))
            {
                SetStatus(string.Join(' ', GetAesWarnings()), true);
                return;
            }

            KeyManagementResult result = await Admin.GenerateAesKeyAsync(deviceId, slotId, _aesRequest, _userPin ?? string.Empty);
            await PersistPinAsync(deviceId, slotId);
            SetStatus(result.Summary, false);
            _labelFilter = result.Label;
            _aesRequest = new GenerateAesKeyRequest { Label = "aes-admin-" + Guid.NewGuid().ToString("N")[..10], SizeBytes = _aesRequest.SizeBytes };
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task ImportAesAsync()
    {
        try
        {
            if (!CanImportAes || !TryGetSelection(out Guid deviceId, out nuint slotId))
            {
                SetStatus(string.Join(' ', GetImportWarnings()), true);
                return;
            }

            KeyManagementResult result = await Admin.ImportAesKeyAsync(deviceId, slotId, _importAesRequest, _userPin ?? string.Empty);
            await PersistPinAsync(deviceId, slotId);
            SetStatus(result.Summary, false);
            _labelFilter = result.Label;
            _importAesRequest = new ImportAesKeyRequest { Label = "aes-import-" + Guid.NewGuid().ToString("N")[..10] };
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task GenerateRsaAsync()
    {
        try
        {
            if (!CanGenerateRsa || !TryGetSelection(out Guid deviceId, out nuint slotId))
            {
                SetStatus(string.Join(' ', GetRsaWarnings()), true);
                return;
            }

            KeyManagementResult result = await Admin.GenerateRsaKeyPairAsync(deviceId, slotId, _rsaRequest, _userPin ?? string.Empty);
            await PersistPinAsync(deviceId, slotId);
            SetStatus(result.Summary, false);
            _labelFilter = result.Label;
            _rsaRequest = new GenerateRsaKeyPairRequest { Label = "rsa-admin-" + Guid.NewGuid().ToString("N")[..10], ModulusBits = _rsaRequest.ModulusBits, PublicExponentHex = _rsaRequest.PublicExponentHex };
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private bool TryGetSelection(out Guid deviceId, out nuint slotId)
    {
        bool hasDevice = Guid.TryParse(_selectedDeviceId, out deviceId);
        bool hasSlot = nuint.TryParse(_selectedSlotId, out slotId);
        return hasDevice && hasSlot;
    }

    private bool CanEdit(Func<ObjectEditCapabilities, bool> selector) => _selectedDetail is not null && selector(_selectedDetail.EditCapabilities);

    private IReadOnlyList<string> GetAesWarnings()
    {
        List<string> warnings = [];
        if (!CanLoadKeys) warnings.Add("Select a device and slot first.");
        if (string.IsNullOrWhiteSpace(_userPin)) warnings.Add("User PIN is required for key-management operations.");
        if (_slotCapabilities?.SupportsAesKeyGeneration == false) warnings.Add("Selected slot does not expose CKM_AES_KEY_GEN with generate support.");
        if (_slotCapabilities?.TokenPresent == false) warnings.Add("No token is present in the selected slot.");
        return warnings;
    }

    private IReadOnlyList<string> GetImportWarnings()
    {
        List<string> warnings = [];
        if (!CanLoadKeys) warnings.Add("Select a device and slot first.");
        if (string.IsNullOrWhiteSpace(_userPin)) warnings.Add("User PIN is required for key-management operations.");
        if (_slotCapabilities?.SupportsAesObjectImport == false) warnings.Add("Import is gated because the selected slot has no token present.");
        return warnings;
    }

    private IReadOnlyList<string> GetRsaWarnings()
    {
        List<string> warnings = [];
        if (!CanLoadKeys) warnings.Add("Select a device and slot first.");
        if (string.IsNullOrWhiteSpace(_userPin)) warnings.Add("User PIN is required for key-management operations.");
        if (_slotCapabilities?.SupportsRsaKeyPairGeneration == false) warnings.Add("Selected slot does not expose CKM_RSA_PKCS_KEY_PAIR_GEN with generate-key-pair support.");
        if (_slotCapabilities?.TokenPresent == false) warnings.Add("No token is present in the selected slot.");
        return warnings;
    }

    private IReadOnlyList<string> GetEditWarnings()
    {
        List<string> warnings = [];
        if (_selectedDetail?.EditCapabilities.CanEditAnyAttributes == false) warnings.Add("The selected object does not currently look modifiable, so SetAttributeValue is likely to fail.");
        if (string.IsNullOrWhiteSpace(_userPin)) warnings.Add("User PIN is required for write operations.");
        return warnings;
    }

    private IReadOnlyList<string> GetCopyWarnings()
    {
        List<string> warnings = [];
        if (string.IsNullOrWhiteSpace(_userPin)) warnings.Add("User PIN is required for write operations.");
        if (_slotCapabilities?.TokenPresent == false) warnings.Add("No token is present in the selected slot.");
        warnings.Add("Some tokens reject copy-time overrides for sensitive or policy-controlled attributes; unchanged fields can be left as 'keep existing'.");
        return warnings;
    }

    private RenderFragment RenderOperationWarnings(IReadOnlyList<string> warnings) => builder =>
    {
        if (warnings.Count == 0) return;
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "col-12");
        builder.OpenElement(2, "div");
        builder.AddAttribute(3, "class", "alert alert-warning small mb-0");
        builder.OpenElement(4, "ul");
        builder.AddAttribute(5, "class", "mb-0 ps-3");
        int seq = 6;
        foreach (string warning in warnings)
        {
            builder.OpenElement(seq++, "li");
            builder.AddContent(seq++, warning);
            builder.CloseElement();
        }
        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();
    };

    private void SetStatus(string message, bool isError)
    {
        _statusMessage = message;
        _statusIsError = isError;
    }

    private async Task PersistPinAsync(Guid deviceId, nuint slotId)
    {
        if (_rememberPin && !string.IsNullOrWhiteSpace(_userPin))
        {
            await PinStore.SaveAsync(deviceId, slotId, "keys", _userPin);
        }
        else
        {
            await PinStore.DeleteAsync(deviceId, slotId, "keys");
        }
    }

    private static IEnumerable<string> GetFlags(HsmObjectDetail detail)
    {
        if (detail.Token == true) yield return "token";
        if (detail.Private == true) yield return "private";
        if (detail.Modifiable == true) yield return "modifiable";
        if (detail.Sensitive == true) yield return "sensitive";
        if (detail.Extractable == true) yield return "extractable";
        if (detail.CanEncrypt == true) yield return "encrypt";
        if (detail.CanDecrypt == true) yield return "decrypt";
        if (detail.CanSign == true) yield return "sign";
        if (detail.CanVerify == true) yield return "verify";
        if (detail.CanWrap == true) yield return "wrap";
        if (detail.CanUnwrap == true) yield return "unwrap";
        if (detail.CanDerive == true) yield return "derive";
    }

    private static string FormatNullable(nuint? value) => value?.ToString() ?? "n/a";

    private static string CapabilitySummary(HsmKeyObjectSummary key)
    {
        List<string> flags = [];
        if (key.CanEncrypt == true) flags.Add("enc");
        if (key.CanDecrypt == true) flags.Add("dec");
        if (key.CanSign == true) flags.Add("sign");
        if (key.CanVerify == true) flags.Add("verify");
        if (key.CanWrap == true) flags.Add("wrap");
        if (key.CanUnwrap == true) flags.Add("unwrap");
        return flags.Count == 0 ? "n/a" : string.Join(", ", flags);
    }

    private static bool TryGetSignPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanSign == true && string.Equals(detail.KeyType, "RSA", StringComparison.OrdinalIgnoreCase)
            ? "0x1"
            : null;
        return mechanism is not null;
    }

    private static bool TryGetVerifyPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanVerify == true && string.Equals(detail.KeyType, "RSA", StringComparison.OrdinalIgnoreCase)
            ? "0x1"
            : null;
        return mechanism is not null;
    }

    private static bool TryGetEncryptPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanEncrypt == true
            ? detail.KeyType switch
            {
                "RSA" => "0x1",
                "AES" => "0x1081",
                _ => null
            }
            : null;
        return mechanism is not null;
    }

    private static bool TryGetEncryptOaepPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanEncrypt == true && string.Equals(detail.KeyType, "RSA", StringComparison.OrdinalIgnoreCase)
            ? "0x9"
            : null;
        return mechanism is not null;
    }

    private static bool TryGetDecryptPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanDecrypt == true
            ? detail.KeyType switch
            {
                "RSA" => "0x1",
                "AES" => "0x1081",
                _ => null
            }
            : null;
        return mechanism is not null;
    }

    private static bool TryGetDecryptOaepPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanDecrypt == true && string.Equals(detail.KeyType, "RSA", StringComparison.OrdinalIgnoreCase)
            ? "0x9"
            : null;
        return mechanism is not null;
    }

    private static bool TryGetSignPssPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanSign == true && string.Equals(detail.KeyType, "RSA", StringComparison.OrdinalIgnoreCase)
            ? "0x43"
            : null;
        return mechanism is not null;
    }

    private static bool TryGetVerifyPssPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanVerify == true && string.Equals(detail.KeyType, "RSA", StringComparison.OrdinalIgnoreCase)
            ? "0x43"
            : null;
        return mechanism is not null;
    }

    private static bool TryGetWrapPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanWrap == true && string.Equals(detail.KeyType, "AES", StringComparison.OrdinalIgnoreCase)
            ? "0x2109"
            : null;
        return mechanism is not null;
    }

    private static bool TryGetUnwrapPreset(HsmObjectDetail detail, out string? mechanism)
    {
        mechanism = detail.CanUnwrap == true && string.Equals(detail.KeyType, "AES", StringComparison.OrdinalIgnoreCase)
            ? "0x2109"
            : null;
        return mechanism is not null;
    }

    private static string BuildLabUri(Guid deviceId, nuint slotId, Pkcs11LabOperation operation, nuint? primaryHandle = null, string? mechanism = null, nuint? secondaryHandle = null, string? attributeType = null, Pkcs11LabMechanismParameterProfile? parameterProfile = null, Pkcs11LabRsaHashProfile? rsaHashProfile = null, int? pssSaltLength = null)
    {
        List<string> query =
        [
            $"device={Uri.EscapeDataString(deviceId.ToString())}",
            $"slot={Uri.EscapeDataString(slotId.ToString())}",
            $"op={Uri.EscapeDataString(operation.ToString())}"
        ];

        if (primaryHandle is not null)
        {
            query.Add($"handle={primaryHandle.Value}");
        }

        if (secondaryHandle is not null)
        {
            query.Add($"wrapHandle={secondaryHandle.Value}");
        }

        if (!string.IsNullOrWhiteSpace(mechanism))
        {
            query.Add($"mechanism={Uri.EscapeDataString(mechanism)}");
        }

        if (!string.IsNullOrWhiteSpace(attributeType))
        {
            query.Add($"attr={Uri.EscapeDataString(attributeType)}");
        }

        if (parameterProfile is not null)
        {
            query.Add($"profile={Uri.EscapeDataString(parameterProfile.Value.ToString())}");
        }

        if (rsaHashProfile is not null)
        {
            query.Add($"rsaHash={Uri.EscapeDataString(rsaHashProfile.Value.ToString())}");
        }

        if (pssSaltLength is not null)
        {
            query.Add($"pssSalt={pssSaltLength.Value}");
        }

        return $"/lab?{string.Join("&", query)}";
    }

    private RenderFragment CapabilityCheckbox(Func<bool> getValue, Action<bool> setValue, string label) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "form-check");
        builder.OpenElement(2, "input");
        builder.AddAttribute(3, "class", "form-check-input");
        builder.AddAttribute(4, "type", "checkbox");
        builder.AddAttribute(5, "checked", getValue());
        builder.AddAttribute(6, "onchange", EventCallback.Factory.CreateBinder<bool>(this, setValue, getValue()));
        builder.CloseElement();
        builder.OpenElement(7, "label");
        builder.AddAttribute(8, "class", "form-check-label");
        builder.AddContent(9, label);
        builder.CloseElement();
        builder.CloseElement();
    };

    private RenderFragment NullableCheckbox(Func<bool?> getValue, Action<bool?> setValue, string label, bool enabled) => builder =>
    {
        bool current = getValue() == true;
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "form-check form-switch");
        builder.OpenElement(2, "input");
        builder.AddAttribute(3, "class", "form-check-input");
        builder.AddAttribute(4, "type", "checkbox");
        builder.AddAttribute(5, "checked", current);
        builder.AddAttribute(6, "disabled", !enabled);
        builder.AddAttribute(7, "onchange", EventCallback.Factory.CreateBinder<bool>(this, value => setValue(value), current));
        builder.CloseElement();
        builder.OpenElement(8, "label");
        builder.AddAttribute(9, "class", "form-check-label");
        builder.AddContent(10, !enabled ? $"{label} (unsupported here)" : getValue() is null ? $"{label} (keep existing)" : label);
        builder.CloseElement();
        builder.CloseElement();
    };
}
