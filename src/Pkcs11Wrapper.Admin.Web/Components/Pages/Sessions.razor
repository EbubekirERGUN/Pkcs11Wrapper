@page "/sessions"
@inject HsmAdminService Admin

<PageTitle>Sessions</PageTitle>

<h1>Sessions</h1>
<p class="text-muted">Bu panelin açtığı tracked session’ları gör, detaylarını incele, login/logout yap, cancel çalıştır ve tekil/toplu kapatma işlemlerini yönet.</p>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert @(_statusIsError ? "alert-danger" : "alert-success")">@_statusMessage</div>
}

<div class="d-flex gap-2 mb-3">
    <button class="btn btn-primary" @onclick="Refresh">Refresh</button>
    <button class="btn btn-outline-danger" @onclick="CloseAllTrackedAsync" disabled="@(_sessions.Count == 0)">Close All Tracked</button>
</div>

@if (_sessions.Count == 0)
{
    <p class="text-muted">No tracked sessions.</p>
}
else
{
    <div class="row g-4">
        <div class="col-xl-7">
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Session Id</th>
                            <th>Device</th>
                            <th>Slot</th>
                            <th>Mode</th>
                            <th>State</th>
                            <th>Flags</th>
                            <th>Opened</th>
                            <th>Last Operation</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (AdminSessionSnapshot session in _sessions)
                        {
                            <tr class="@(_selectedSession?.SessionId == session.SessionId ? "table-active" : null)">
                                <td><code>@session.SessionId</code></td>
                                <td>@session.DeviceName</td>
                                <td>@session.SlotId</td>
                                <td>@(session.IsReadWrite ? "RW" : "RO")</td>
                                <td>@session.State</td>
                                <td class="small">@session.SessionFlags</td>
                                <td>@session.OpenedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@session.LastOperation</td>
                                <td>
                                    @if (session.IsHealthy)
                                    {
                                        <span class="badge text-bg-success">Healthy</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-danger">Broken</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" @onclick="() => SelectSession(session.SessionId)">Details</button>
                                        <button class="btn btn-outline-secondary" @onclick="() => CloseAsync(session.SessionId)">Close</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-xl-5">
            @if (_selectedSession is null)
            {
                <div class="card shadow-sm">
                    <div class="card-body text-muted">Bir tracked session seçip detaylarını ve operasyon kontrollerini aç.</div>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Session detail</span>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ClearSelection">Close</button>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Session Id</dt><dd class="col-sm-8"><code>@_selectedSession.SessionId</code></dd>
                            <dt class="col-sm-4">Device</dt><dd class="col-sm-8">@_selectedSession.DeviceName</dd>
                            <dt class="col-sm-4">Slot</dt><dd class="col-sm-8">@_selectedSession.SlotId</dd>
                            <dt class="col-sm-4">Mode</dt><dd class="col-sm-8">@(_selectedSession.IsReadWrite ? "Read-write" : "Read-only")</dd>
                            <dt class="col-sm-4">State</dt><dd class="col-sm-8">@_selectedSession.State</dd>
                            <dt class="col-sm-4">Flags</dt><dd class="col-sm-8">@_selectedSession.SessionFlags</dd>
                            <dt class="col-sm-4">Device Error</dt><dd class="col-sm-8">@_selectedSession.DeviceError</dd>
                            <dt class="col-sm-4">Auth</dt><dd class="col-sm-8">@AuthSummary(_selectedSession)</dd>
                            <dt class="col-sm-4">Opened</dt><dd class="col-sm-8">@_selectedSession.OpenedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd>
                            <dt class="col-sm-4">Last Touched</dt><dd class="col-sm-8">@_selectedSession.LastTouchedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd>
                            <dt class="col-sm-4">Last Operation</dt><dd class="col-sm-8">@_selectedSession.LastOperation</dd>
                            <dt class="col-sm-4">Notes</dt><dd class="col-sm-8">@_selectedSession.Notes</dd>
                        </dl>

                        <hr />
                        <h2 class="h6">Session controls</h2>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">User PIN</label>
                                <input class="form-control" type="password" @bind="_userPin" />
                                <div class="form-text">Login/logout operates on the tracked session itself so you can watch state transitions immediately.</div>
                            </div>
                            <div class="col-12 d-flex flex-wrap gap-2">
                                <button class="btn btn-success" @onclick="LoginAsync">Login User</button>
                                <button class="btn btn-outline-warning" @onclick="LogoutAsync">Logout</button>
                                <button class="btn btn-outline-secondary" @onclick="CancelAsync">Cancel Active Ops</button>
                                <button class="btn btn-outline-danger" @onclick="CloseSelectedSlotSessionsAsync">Close Slot Sessions (module)</button>
                                <button class="btn btn-danger" @onclick="CloseSelectedAsync">Close Tracked Session</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private IReadOnlyList<AdminSessionSnapshot> _sessions = [];
    private AdminSessionSnapshot? _selectedSession;
    private string? _userPin;
    private string? _statusMessage;
    private bool _statusIsError;

    protected override void OnInitialized() => Refresh();

    private void Refresh()
    {
        _sessions = Admin.GetSessions();
        if (_selectedSession is not null)
        {
            _selectedSession = _sessions.FirstOrDefault(x => x.SessionId == _selectedSession.SessionId);
        }
    }

    private void SelectSession(Guid sessionId)
    {
        Refresh();
        _selectedSession = _sessions.FirstOrDefault(x => x.SessionId == sessionId);
    }

    private void ClearSelection() => _selectedSession = null;

    private async Task LoginAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        try
        {
            _selectedSession = await Admin.LoginTrackedSessionAsync(_selectedSession.SessionId, _userPin ?? string.Empty);
            SetStatus("Tracked session logged in as CKU_USER.", false);
            Refresh();
            SelectSession(_selectedSession.SessionId);
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task LogoutAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        try
        {
            _selectedSession = await Admin.LogoutTrackedSessionAsync(_selectedSession.SessionId);
            SetStatus("Tracked session logged out.", false);
            Refresh();
            SelectSession(_selectedSession.SessionId);
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task CancelAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        try
        {
            _selectedSession = await Admin.CancelTrackedSessionOperationsAsync(_selectedSession.SessionId);
            SetStatus("Issued C_SessionCancel for the tracked session.", false);
            Refresh();
            SelectSession(_selectedSession.SessionId);
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task CloseSelectedSlotSessionsAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        try
        {
            await Admin.CloseAllSessionsAsync(_selectedSession.DeviceId, _selectedSession.SlotId);
            SetStatus($"Invoked CloseAllSessions for device slot {_selectedSession.SlotId}. Existing tracked sessions on that slot may now show invalidated state until refreshed/closed.", false);
            Refresh();
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
    }

    private async Task CloseSelectedAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        await CloseAsync(_selectedSession.SessionId);
    }

    private async Task CloseAsync(Guid sessionId)
    {
        bool closed = await Admin.CloseSessionAsync(sessionId);
        SetStatus(closed ? "Session closed." : "Session not found.", !closed);
        if (_selectedSession?.SessionId == sessionId)
        {
            _selectedSession = null;
        }
        Refresh();
    }

    private async Task CloseAllTrackedAsync()
    {
        foreach (AdminSessionSnapshot session in _sessions.ToArray())
        {
            await Admin.CloseSessionAsync(session.SessionId);
        }

        _selectedSession = null;
        SetStatus("All tracked sessions closed.", false);
        Refresh();
    }

    private void SetStatus(string message, bool isError)
    {
        _statusMessage = message;
        _statusIsError = isError;
    }

    private static string AuthSummary(AdminSessionSnapshot session)
    {
        if (session.IsSecurityOfficerAuthenticated)
        {
            return "Security officer";
        }

        if (session.IsUserAuthenticated)
        {
            return "User";
        }

        return "Public";
    }
}
