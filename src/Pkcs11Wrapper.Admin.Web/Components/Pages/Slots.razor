@page "/slots"
@attribute [Authorize(Policy = AdminRoles.Viewer)]
@inject HsmAdminService Admin
@inject ProtectedPinStore PinStore
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Slots</PageTitle>

<section class="page-hero page-hero-slots">
    <div class="page-hero-copy">
        <div class="page-eyebrow">Slot visibility</div>
        <h1>Slots</h1>
        <p class="page-lead">Seçilen cihaz için slot ve token bilgisini görüntüle. Buradan read-only/read-write session açabilir, slot seviyesinde <code>CloseAllSessions</code> çağırabilir ve loaded slot görünümünü filtreleyebilirsin. Hedef burada slot sağlığını ve token varlığını temiz, okunabilir bir operasyon yüzeyinde sunmak.</p>
        <div class="page-hero-tags">
            <span class="page-tag">Slot inventory</span>
            <span class="page-tag">Token presence</span>
            <span class="page-tag">Tracked session visibility</span>
            @if (_isOperator)
            {
                <span class="page-tag">Direct slot actions</span>
            }
        </div>
    </div>
    <div class="page-hero-side">
        <div class="hero-panel">
            <div class="hero-panel-title">Primary usage</div>
            <div class="hero-panel-value">Inspect + act</div>
            <div class="hero-panel-copy">Load device slots, verify token presence, then open sessions or close stale slot sessions without leaving the view.</div>
        </div>
        <div class="hero-panel">
            <div class="hero-panel-title">Operator model</div>
            <div class="hero-panel-value">Guided controls</div>
            <div class="hero-panel-copy">High-impact slot actions stay explicit and grouped next to the slot inventory so the page feels operational, not accidental.</div>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert @(_statusIsError ? "alert-danger" : "alert-success")" data-testid="slots-status">@_statusMessage</div>
}

<div class="card shadow-sm mb-4 panel-toolbar-card feature-card">
    <div class="card-body row g-3 align-items-end">
        <div class="col-lg-4">
            <label class="form-label">Device</label>
            <select class="form-select" @bind="_selectedDeviceId" @bind:after="OnSelectedDeviceChangedAsync" data-testid="slots-device">
                <option value="">Select device...</option>
                @foreach (HsmDeviceProfile device in _devices)
                {
                    <option value="@device.Id">@device.Name</option>
                }
            </select>
        </div>
        <div class="col-lg-4">
            <label class="form-label">Optional User PIN</label>
            <input class="form-control" type="password" @bind="_userPin" data-testid="slots-user-pin" />
            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" @bind="_rememberPin" />
                <label class="form-check-label">Remember this PIN in protected local storage</label>
            </div>
        </div>
        <div class="col-lg-4 d-flex gap-2">
            <button class="btn btn-primary" @onclick="LoadSlotsAsync" disabled="@string.IsNullOrWhiteSpace(_selectedDeviceId)" data-testid="slots-load">Load Slots</button>
            <button class="btn btn-outline-secondary" @onclick="RefreshSessions">Refresh Sessions</button>
        </div>
    </div>
</div>

<DeviceVendorHintsPanel Vendor="SelectedDevice?.Vendor" Heading="Selected device guidance" ShowWhenVendorNeutral="false" />

@if (_slots.Count != 0)
{
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Loaded slots</div>
                    <div class="display-6 metric-meta">@_slots.Count</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Token present</div>
                    <div class="display-6 metric-meta">@_slots.Count(slot => slot.TokenPresent)</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">No token</div>
                    <div class="display-6 metric-meta">@_slots.Count(slot => !slot.TokenPresent)</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100 metric-card">
                <div class="card-body">
                    <div class="metric-label">Tracked sessions</div>
                    <div class="display-6 metric-meta">@CurrentDeviceSessions.Count</div>
                    <div class="small metric-note">Selected device only</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4 panel-toolbar-card feature-card">
        <div class="card-body row g-3 align-items-end">
            <div class="col-lg-5">
                <label class="form-label">Search</label>
                <input class="form-control" @bind="_searchText" @bind:event="oninput" placeholder="slot description, token label, serial..." />
            </div>
            <div class="col-lg-3 col-md-6">
                <label class="form-label">Token filter</label>
                <select class="form-select" @bind="_tokenFilter">
                    <option value="all">All slots</option>
                    <option value="present">Token present</option>
                    <option value="missing">No token</option>
                </select>
            </div>
            <div class="col-lg-4 col-md-6">
                <label class="form-label">Sort</label>
                <select class="form-select" @bind="_sortMode">
                    <option value="slot">Slot id</option>
                    <option value="token">Token label</option>
                    <option value="mechanisms">Mechanism count</option>
                </select>
            </div>
            <div class="col-12 small text-muted">Showing @FilteredSlots.Count of @_slots.Count loaded slot(s).</div>
        </div>
    </div>

    @if (FilteredSlots.Count == 0)
    {
        <div class="empty-state mb-4">No slots matched the current filters.</div>
    }
    else
    {
        <div class="table-responsive table-shell">
            <table class="table table-striped align-middle" data-testid="slots-table">
                <thead>
                    <tr>
                        <th>Slot</th>
                        <th>Description</th>
                        <th>Token</th>
                        <th>Flags</th>
                        <th>Mechanisms</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (HsmSlotSummary slot in FilteredSlots)
                    {
                        <tr>
                            <td>
                                <div><span class="table-pill table-pill-code">@slot.SlotId</span></div>
                                <div class="small text-muted mt-1">@slot.SlotManufacturer</div>
                            </td>
                            <td>@slot.SlotDescription</td>
                            <td>
                                @if (slot.TokenPresent)
                                {
                                    <div class="fw-semibold">@slot.TokenLabel</div>
                                    <div class="small text-muted">@slot.TokenModel · @slot.TokenSerialNumber</div>
                                    <span class="badge text-bg-success mt-1">Token present</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">No token</span>
                                }
                            </td>
                            <td>
                                <div>@slot.SlotFlags</div>
                                <div class="small text-muted">@slot.TokenFlags</div>
                            </td>
                            <td><span class="table-pill">@slot.MechanismCount mechanism(s)</span></td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary" @onclick="() => OpenSessionAsync(slot, false)" disabled="@(!_isOperator)">Open RO</button>
                                    <button class="btn btn-outline-warning" @onclick="() => OpenSessionAsync(slot, true)" disabled="@(!_isOperator)">Open RW</button>
                                    <button class="btn btn-outline-danger" @onclick="() => CloseAllAsync(slot)" disabled="@(!_isOperator)">Close All</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (CurrentDeviceSessions.Count != 0)
{
    <div class="card shadow-sm feature-card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Tracked Sessions for Selected Device</span>
            <span class="small text-muted">@CurrentDeviceSessions.Count tracked session(s)</span>
        </div>
        <div class="table-responsive table-shell">
        <table class="table table-sm table-bordered align-middle">
            <thead>
                <tr>
                    <th>Session</th>
                    <th>Slot</th>
                    <th>Mode</th>
                    <th>State</th>
                    <th>Health</th>
                    <th>Last Operation</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (AdminSessionSnapshot session in CurrentDeviceSessions.OrderByDescending(session => session.LastTouchedUtc))
                {
                    <tr>
                        <td><span class="table-pill table-pill-code">@session.SessionId</span></td>
                        <td><span class="table-pill table-pill-code">@session.SlotId</span></td>
                        <td><span class="table-pill">@(session.IsReadWrite ? "RW" : "RO")</span></td>
                        <td>@session.State</td>
                        <td><span class="badge @(session.IsHealthy ? "text-bg-success" : "text-bg-danger")">@session.HealthLabel</span></td>
                        <td>@session.LastOperation</td>
                        <td class="text-end"><button class="btn btn-sm btn-outline-secondary" @onclick="() => CloseSessionAsync(session.SessionId)" disabled="@(!_isOperator)">Close</button></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
}

@code {
    private IReadOnlyList<HsmDeviceProfile> _devices = [];
    private IReadOnlyList<HsmSlotSummary> _slots = [];
    private IReadOnlyList<AdminSessionSnapshot> _sessions = [];
    private string? _selectedDeviceId;
    private string? _userPin;
    private bool _rememberPin;
    private string? _statusMessage;
    private bool _statusIsError;
    private bool _isOperator;
    private string _searchText = string.Empty;
    private string _tokenFilter = "all";
    private string _sortMode = "slot";

    private IReadOnlyList<HsmSlotSummary> FilteredSlots => ApplyOrdering(_slots.Where(MatchesFilters)).ToArray();
    private HsmDeviceProfile? SelectedDevice
        => Guid.TryParse(_selectedDeviceId, out Guid deviceId)
            ? _devices.FirstOrDefault(device => device.Id == deviceId)
            : null;

    private IReadOnlyList<AdminSessionSnapshot> CurrentDeviceSessions
        => Guid.TryParse(_selectedDeviceId, out Guid deviceId)
            ? _sessions.Where(session => session.DeviceId == deviceId).ToArray()
            : [];

    protected override async Task OnInitializedAsync()
    {
        AuthenticationState state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isOperator = state.User.IsInRole(AdminRoles.Operator) || state.User.IsInRole(AdminRoles.Admin);
        _devices = await Admin.GetDevicesAsync();
        _sessions = Admin.GetSessions();
        _selectedDeviceId = _devices.FirstOrDefault()?.Id.ToString();
        await LoadProtectedPinAsync();
    }

    private async Task OnSelectedDeviceChangedAsync()
    {
        _slots = [];
        await LoadProtectedPinAsync();
    }

    private async Task LoadProtectedPinAsync()
    {
        if (Guid.TryParse(_selectedDeviceId, out Guid deviceId))
        {
            _userPin = await PinStore.TryGetAsync(deviceId, 0, "slots");
            _rememberPin = !string.IsNullOrWhiteSpace(_userPin);
        }
        else
        {
            _userPin = null;
            _rememberPin = false;
        }
    }

    private async Task LoadSlotsAsync()
    {
        try
        {
            if (!Guid.TryParse(_selectedDeviceId, out Guid deviceId))
            {
                return;
            }

            _slots = await Admin.GetSlotsAsync(deviceId);
            await PersistPinAsync(deviceId, 0, "slots");
            _statusMessage = $"Loaded {_slots.Count} slot(s).";
            _statusIsError = false;
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
            _statusIsError = true;
        }
    }

    private async Task OpenSessionAsync(HsmSlotSummary slot, bool readWrite)
    {
        try
        {
            AdminSessionSnapshot snapshot = await Admin.OpenSessionAsync(slot.DeviceId, slot.SlotId, readWrite, _userPin);
            _sessions = Admin.GetSessions();
            _statusMessage = $"Opened {(snapshot.IsReadWrite ? "read-write" : "read-only")} session for slot {snapshot.SlotId}.";
            _statusIsError = false;
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
            _statusIsError = true;
        }
    }

    private async Task CloseAllAsync(HsmSlotSummary slot)
    {
        try
        {
            await Admin.CloseAllSessionsAsync(slot.DeviceId, slot.SlotId);
            _sessions = Admin.GetSessions();
            _statusMessage = $"CloseAllSessions invoked for slot {slot.SlotId}.";
            _statusIsError = false;
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
            _statusIsError = true;
        }
    }

    private async Task CloseSessionAsync(Guid sessionId)
    {
        await Admin.CloseSessionAsync(sessionId);
        _sessions = Admin.GetSessions();
        _statusMessage = "Session closed.";
        _statusIsError = false;
    }

    private void RefreshSessions() => _sessions = Admin.GetSessions();

    private async Task PersistPinAsync(Guid deviceId, nuint slotId, string purpose)
    {
        if (_rememberPin && !string.IsNullOrWhiteSpace(_userPin))
        {
            await PinStore.SaveAsync(deviceId, slotId, purpose, _userPin);
        }
        else
        {
            await PinStore.DeleteAsync(deviceId, slotId, purpose);
        }
    }

    private bool MatchesFilters(HsmSlotSummary slot)
    {
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            string term = _searchText.Trim();
            bool matchesSearch = Contains(slot.SlotDescription, term)
                || Contains(slot.SlotManufacturer, term)
                || Contains(slot.TokenLabel, term)
                || Contains(slot.TokenModel, term)
                || Contains(slot.TokenSerialNumber, term)
                || slot.SlotId.ToString().Contains(term, StringComparison.OrdinalIgnoreCase);
            if (!matchesSearch)
            {
                return false;
            }
        }

        return _tokenFilter switch
        {
            "present" => slot.TokenPresent,
            "missing" => !slot.TokenPresent,
            _ => true
        };
    }

    private IEnumerable<HsmSlotSummary> ApplyOrdering(IEnumerable<HsmSlotSummary> slots)
        => _sortMode switch
        {
            "token" => slots.OrderBy(slot => slot.TokenLabel ?? string.Empty, StringComparer.OrdinalIgnoreCase).ThenBy(slot => slot.SlotId),
            "mechanisms" => slots.OrderByDescending(slot => slot.MechanismCount).ThenBy(slot => slot.SlotId),
            _ => slots.OrderBy(slot => slot.SlotId)
        };

    private static bool Contains(string? value, string term)
        => value?.Contains(term, StringComparison.OrdinalIgnoreCase) == true;
}
