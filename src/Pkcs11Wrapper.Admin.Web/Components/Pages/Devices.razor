@page "/devices"
@attribute [Authorize(Policy = AdminRoles.Viewer)]
@inject HsmAdminService Admin
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Devices</PageTitle>

<h1>HSM Devices</h1>
<p class="text-muted">PKCS#11 module path'lerini tanımla, bağlantı testi yap ve admin panelinin hangi cihazlara erişeceğini yönet. Bu görünüm ikinci polish diliminde özet, arama, filtre ve sıralama ergonomisiyle güçlendirildi.</p>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert @(_statusIsError ? "alert-danger" : "alert-success")">@_statusMessage</div>
}

@if (_devices.Count != 0)
{
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Configured devices</div>
                    <div class="display-6">@_devices.Count</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Enabled devices</div>
                    <div class="display-6">@_devices.Count(device => device.IsEnabled)</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Disabled devices</div>
                    <div class="display-6">@_devices.Count(device => !device.IsEnabled)</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Filtered view</div>
                    <div class="display-6">@FilteredDevices.Count</div>
                    <div class="small text-muted">@(_editingId is null ? "No device is being edited." : "One device is currently selected for editing.")</div>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header">@(_editingId is null ? "Add Device" : "Edit Device")</div>
            <div class="card-body">
                <EditForm Model="_input" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_input.Name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">PKCS#11 Module Path</label>
                        <InputText class="form-control" @bind-Value="_input.ModulePath" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Default Token Label</label>
                        <InputText class="form-control" @bind-Value="_input.DefaultTokenLabel" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <InputTextArea class="form-control" @bind-Value="_input.Notes" />
                    </div>
                    <div class="form-check mb-3">
                        <InputCheckbox class="form-check-input" @bind-Value="_input.IsEnabled" />
                        <label class="form-check-label">Enabled</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@(!_isAdmin)">Save</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="ResetForm" disabled="@(!_isAdmin)">Reset</button>
                    </div>
                    @if (!_isAdmin)
                    {
                        <div class="form-text mt-2">Viewer/operator can inspect devices; only admin can create, edit, or delete profiles.</div>
                    }
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Configured Devices</span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">Refresh</button>
            </div>
            <div class="card-body border-bottom row g-3 align-items-end">
                <div class="col-lg-5">
                    <label class="form-label">Search</label>
                    <input class="form-control" @bind="_searchText" @bind:event="oninput" placeholder="name, path, token, notes..." />
                </div>
                <div class="col-lg-3 col-md-6">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="_statusFilter">
                        <option value="all">All devices</option>
                        <option value="enabled">Enabled</option>
                        <option value="disabled">Disabled</option>
                    </select>
                </div>
                <div class="col-lg-4 col-md-6">
                    <label class="form-label">Sort</label>
                    <select class="form-select" @bind="_sortMode">
                        <option value="name">Name (A-Z)</option>
                        <option value="updated">Recently updated</option>
                        <option value="created">Recently created</option>
                        <option value="enabled">Enabled first</option>
                    </select>
                </div>
                <div class="col-12 small text-muted">Showing @FilteredDevices.Count of @_devices.Count configured device(s).</div>
            </div>
            <div class="card-body">
                @if (_devices.Count == 0)
                {
                    <p class="text-muted mb-0">No devices configured yet.</p>
                }
                else if (FilteredDevices.Count == 0)
                {
                    <p class="text-muted mb-0">No devices matched the current filters.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Module Path</th>
                                    <th>Token</th>
                                    <th>Status</th>
                                    <th>Updated</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (HsmDeviceProfile device in FilteredDevices)
                                {
                                    <tr class="@(_editingId == device.Id ? "table-active" : null)">
                                        <td>
                                            <div class="fw-semibold">@device.Name</div>
                                            <div class="small text-muted">@device.Notes</div>
                                        </td>
                                        <td><code>@device.ModulePath</code></td>
                                        <td>@(string.IsNullOrWhiteSpace(device.DefaultTokenLabel) ? "—" : device.DefaultTokenLabel)</td>
                                        <td>
                                            @if (device.IsEnabled)
                                            {
                                                <span class="badge text-bg-success">Enabled</span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-secondary">Disabled</span>
                                            }
                                        </td>
                                        <td class="small text-muted">@device.UpdatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary" @onclick="() => Edit(device)" disabled="@(!_isAdmin)">Edit</button>
                                                <button class="btn btn-outline-success" @onclick="() => TestAsync(device.Id)" disabled="@(!_isOperator)">Test</button>
                                                <button class="btn btn-outline-danger" @onclick="() => DeleteAsync(device.Id)" disabled="@(!_isAdmin)">Delete</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly HsmDeviceProfileInput _input = new();
    private IReadOnlyList<HsmDeviceProfile> _devices = [];
    private Guid? _editingId;
    private string? _statusMessage;
    private bool _statusIsError;
    private bool _isOperator;
    private bool _isAdmin;
    private string _searchText = string.Empty;
    private string _statusFilter = "all";
    private string _sortMode = "name";

    private IReadOnlyList<HsmDeviceProfile> FilteredDevices => ApplyOrdering(_devices.Where(MatchesFilters)).ToArray();

    protected override async Task OnInitializedAsync()
    {
        await ResolveRolesAsync();
        await LoadAsync();
    }

    private async Task ResolveRolesAsync()
    {
        AuthenticationState state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAdmin = state.User.IsInRole(AdminRoles.Admin);
        _isOperator = _isAdmin || state.User.IsInRole(AdminRoles.Operator);
    }

    private async Task LoadAsync()
    {
        _devices = await Admin.GetDevicesAsync();
        if (_editingId is Guid editingId && !_devices.Any(device => device.Id == editingId))
        {
            ResetForm();
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            HsmDeviceProfile saved = await Admin.SaveDeviceAsync(_editingId, _input);
            _statusMessage = $"Saved device '{saved.Name}'.";
            _statusIsError = false;
            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
            _statusIsError = true;
        }
    }

    private void Edit(HsmDeviceProfile device)
    {
        _editingId = device.Id;
        _input.Name = device.Name;
        _input.ModulePath = device.ModulePath;
        _input.DefaultTokenLabel = device.DefaultTokenLabel;
        _input.Notes = device.Notes;
        _input.IsEnabled = device.IsEnabled;
    }

    private void ResetForm()
    {
        _editingId = null;
        _input.Name = string.Empty;
        _input.ModulePath = string.Empty;
        _input.DefaultTokenLabel = string.Empty;
        _input.Notes = string.Empty;
        _input.IsEnabled = true;
    }

    private async Task TestAsync(Guid id)
    {
        HsmConnectionTestResult result = await Admin.TestConnectionAsync(id);
        _statusMessage = result.Success
            ? $"{result.Message} Manufacturer={result.ManufacturerId}, Library={result.LibraryDescription}, InterfaceDiscovery={result.SupportsInterfaceDiscovery}."
            : $"Connection test failed: {result.Message}";
        _statusIsError = !result.Success;
    }

    private async Task DeleteAsync(Guid id)
    {
        await Admin.DeleteDeviceAsync(id);
        _statusMessage = "Device deleted.";
        _statusIsError = false;
        if (_editingId == id)
        {
            ResetForm();
        }

        await LoadAsync();
    }

    private bool MatchesFilters(HsmDeviceProfile device)
    {
        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            string term = _searchText.Trim();
            bool matchesSearch = Contains(device.Name, term)
                || Contains(device.ModulePath, term)
                || Contains(device.DefaultTokenLabel, term)
                || Contains(device.Notes, term);
            if (!matchesSearch)
            {
                return false;
            }
        }

        return _statusFilter switch
        {
            "enabled" => device.IsEnabled,
            "disabled" => !device.IsEnabled,
            _ => true
        };
    }

    private IEnumerable<HsmDeviceProfile> ApplyOrdering(IEnumerable<HsmDeviceProfile> devices)
        => _sortMode switch
        {
            "updated" => devices.OrderByDescending(device => device.UpdatedUtc).ThenBy(device => device.Name, StringComparer.OrdinalIgnoreCase),
            "created" => devices.OrderByDescending(device => device.CreatedUtc).ThenBy(device => device.Name, StringComparer.OrdinalIgnoreCase),
            "enabled" => devices.OrderByDescending(device => device.IsEnabled).ThenBy(device => device.Name, StringComparer.OrdinalIgnoreCase),
            _ => devices.OrderBy(device => device.Name, StringComparer.OrdinalIgnoreCase)
        };

    private static bool Contains(string? value, string term)
        => value?.Contains(term, StringComparison.OrdinalIgnoreCase) == true;
}
