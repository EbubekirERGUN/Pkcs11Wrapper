@page "/lab"
@attribute [Authorize(Policy = AdminRoles.Operator)]
@inject HsmAdminService Admin
@inject ProtectedPinStore PinStore

<PageTitle>PKCS#11 Lab</PageTitle>

<h1>PKCS#11 Lab</h1>
<p class="text-muted">Bağlı HSM cihazında tanı/deney amaçlı PKCS#11 operasyonlarını transient session’larla çalıştır. Bu ilk sürüm kontrollü bir diagnostic console’dur; serbest raw function execution yüzeyi değildir.</p>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert @(_statusIsError ? "alert-danger" : "alert-success")">@_statusMessage</div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body row g-3 align-items-end">
        <div class="col-xl-3 col-lg-4">
            <label class="form-label">Device</label>
            <select class="form-select" @bind="_selectedDeviceId" @bind:after="OnSelectedDeviceChangedAsync">
                <option value="">Select device...</option>
                @foreach (HsmDeviceProfile device in _devices)
                {
                    <option value="@device.Id">@device.Name</option>
                }
            </select>
        </div>

        <div class="col-xl-3 col-lg-4">
            <label class="form-label">Operation</label>
            <InputSelect class="form-select" @bind-Value="_request.Operation">
                @foreach (Pkcs11LabOperation operation in Enum.GetValues<Pkcs11LabOperation>())
                {
                    <option value="@operation">@GetOperationLabel(operation)</option>
                }
            </InputSelect>
        </div>

        @if (RequiresSlot)
        {
            <div class="col-xl-2 col-lg-4">
                <label class="form-label">Slot</label>
                <select class="form-select" @bind="_selectedSlotId" @bind:after="OnSelectedSlotChangedAsync">
                    <option value="">Select slot...</option>
                    @foreach (HsmSlotSummary slot in _slots)
                    {
                        <option value="@slot.SlotId">@slot.SlotId - @(slot.TokenLabel ?? slot.SlotDescription)</option>
                    }
                </select>
            </div>
        }

        <div class="col-xl-4 col-lg-8">
            <label class="form-label">Optional User PIN</label>
            <input class="form-control" type="password" @bind="_request.UserPin" />
            <div class="d-flex flex-wrap gap-3 mt-2">
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="_rememberPin" />
                    <label class="form-check-label">Remember in protected local storage</label>
                </div>
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="_request.LoginUserIfPinProvided" />
                    <label class="form-check-label">Login as CKU_USER when PIN is present</label>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-5">
        <div class="card shadow-sm h-100">
            <div class="card-header">Operation parameters</div>
            <div class="card-body row g-3">
                <div class="col-12">
                    <div class="small text-muted">@GetOperationDescription(_request.Operation)</div>
                </div>

                @if (_request.Operation is Pkcs11LabOperation.SessionInfo
                    or Pkcs11LabOperation.SignData
                    or Pkcs11LabOperation.VerifySignature
                    or Pkcs11LabOperation.EncryptData
                    or Pkcs11LabOperation.DecryptData
                    or Pkcs11LabOperation.WrapKey)
                {
                    <div class="col-12">
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="_request.OpenReadWriteSession" />
                            <label class="form-check-label">Open read-write session</label>
                        </div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.UnwrapAesKey)
                {
                    <div class="col-12">
                        <div class="alert alert-warning small mb-0">Unwrap operation always uses a read-write transient session because it creates a PKCS#11 object.</div>
                    </div>
                }

                @if (_request.Operation is Pkcs11LabOperation.MechanismInfo
                    or Pkcs11LabOperation.SignData
                    or Pkcs11LabOperation.VerifySignature
                    or Pkcs11LabOperation.EncryptData
                    or Pkcs11LabOperation.DecryptData
                    or Pkcs11LabOperation.WrapKey
                    or Pkcs11LabOperation.UnwrapAesKey)
                {
                    <div class="col-12">
                        <label class="form-label">Mechanism Type (hex or decimal)</label>
                        <input class="form-control font-monospace" @bind="_request.MechanismTypeText" placeholder="0x250" />
                        <div class="form-text">Örnek: <code>0x250</code> (CKM_SHA256), <code>0x1</code> (CKM_RSA_PKCS), <code>0x1082</code> (CKM_AES_ECB), <code>0x2109</code> (CKM_AES_KEY_WRAP_PAD). Not: OAEP/PSS/AES-CBC/CTR/GCM gibi parameter isteyen mekanizmalar bu turda desteklenmiyor.</div>
                    </div>
                }

                @if (_request.Operation is Pkcs11LabOperation.SignData
                    or Pkcs11LabOperation.VerifySignature
                    or Pkcs11LabOperation.EncryptData
                    or Pkcs11LabOperation.DecryptData
                    or Pkcs11LabOperation.InspectObject
                    or Pkcs11LabOperation.WrapKey
                    or Pkcs11LabOperation.UnwrapAesKey
                    or Pkcs11LabOperation.ReadAttribute)
                {
                    <div class="col-md-6">
                        <label class="form-label">@GetPrimaryHandleLabel(_request.Operation)</label>
                        <input class="form-control font-monospace" @bind="_request.KeyHandleText" placeholder="123" />
                        <div class="form-text">Handle değerini Keys ekranından veya Find Objects çıktısından alabilirsin.</div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.ReadAttribute)
                {
                    <div class="col-md-6">
                        <label class="form-label">Attribute Type (hex or decimal)</label>
                        <input class="form-control font-monospace" @bind="_request.AttributeTypeText" placeholder="0x3" />
                        <div class="form-text">Örnek: <code>0x3</code> = CKA_LABEL, <code>0x102</code> = CKA_ID, <code>0x11</code> = CKA_VALUE.</div>
                    </div>

                    <div class="col-12 d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => SetAttributePreset("0x3")'>CKA_LABEL</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => SetAttributePreset("0x102")'>CKA_ID</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => SetAttributePreset("0x0")'>CKA_CLASS</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => SetAttributePreset("0x100")'>CKA_KEY_TYPE</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => SetAttributePreset("0x161")'>CKA_VALUE_LEN</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => SetAttributePreset("0x121")'>CKA_MODULUS_BITS</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => SetAttributePreset("0x122")'>CKA_PUBLIC_EXPONENT</button>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.WrapKey)
                {
                    <div class="col-md-6">
                        <label class="form-label">Wrapping Key Handle</label>
                        <input class="form-control font-monospace" @bind="_request.SecondaryKeyHandleText" placeholder="456" />
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.GenerateRandom)
                {
                    <div class="col-12">
                        <label class="form-label">Random Length</label>
                        <InputNumber class="form-control" @bind-Value="_request.RandomLength" />
                        <div class="form-text">1 ile 4096 byte arasında bir değer gir.</div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.DigestText)
                {
                    <div class="col-12">
                        <label class="form-label">Digest Algorithm</label>
                        <InputSelect class="form-select" @bind-Value="_request.DigestAlgorithm">
                            @foreach (Pkcs11LabDigestAlgorithm algorithm in Enum.GetValues<Pkcs11LabDigestAlgorithm>())
                            {
                                <option value="@algorithm">@algorithm</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Text Input</label>
                        <textarea class="form-control" rows="6" @bind="_request.TextInput"></textarea>
                        <div class="form-text">Metin UTF-8 olarak digest edilir.</div>
                    </div>
                }

                @if (_request.Operation is Pkcs11LabOperation.SignData
                    or Pkcs11LabOperation.VerifySignature
                    or Pkcs11LabOperation.EncryptData)
                {
                    <div class="col-md-6">
                        <label class="form-label">Payload Encoding</label>
                        <InputSelect class="form-select" @bind-Value="_request.PayloadEncoding">
                            @foreach (Pkcs11LabPayloadEncoding encoding in Enum.GetValues<Pkcs11LabPayloadEncoding>())
                            {
                                <option value="@encoding">@encoding</option>
                            }
                        </InputSelect>
                    </div>

                    @if (_request.PayloadEncoding == Pkcs11LabPayloadEncoding.Utf8Text)
                    {
                        <div class="col-12">
                            <label class="form-label">Input Text</label>
                            <textarea class="form-control" rows="6" @bind="_request.TextInput"></textarea>
                            <div class="form-text">Metin UTF-8 byte dizisine çevrilip sign/verify/encrypt işlemine verilir.</div>
                        </div>
                    }
                    else
                    {
                        <div class="col-12">
                            <label class="form-label">Input Hex</label>
                            <textarea class="form-control font-monospace" rows="6" @bind="_request.DataHex"></textarea>
                            <div class="form-text">Hex payload boşluksuz veya çift karakterli biçimde girilmeli.</div>
                        </div>
                    }
                }

                @if (_request.Operation == Pkcs11LabOperation.VerifySignature)
                {
                    <div class="col-12">
                        <label class="form-label">Signature Hex</label>
                        <textarea class="form-control font-monospace" rows="4" @bind="_request.SignatureHex"></textarea>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.DecryptData)
                {
                    <div class="col-12">
                        <label class="form-label">Ciphertext Hex</label>
                        <textarea class="form-control font-monospace" rows="6" @bind="_request.DataHex"></textarea>
                        <div class="form-text">Decrypt çıktısında hem hex hem de UTF-8 yorumu gösterilir.</div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.UnwrapAesKey)
                {
                    <div class="col-12">
                        <label class="form-label">Wrapped Key Hex</label>
                        <textarea class="form-control font-monospace" rows="6" @bind="_request.DataHex"></textarea>
                        <div class="form-text">Bu dilim unwrap hedefini kontrollü tutmak için sadece AES secret-key template üretir.</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Target Label (optional)</label>
                        <input class="form-control" @bind="_request.UnwrapTargetLabel" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Target ID Hex (optional)</label>
                        <input class="form-control font-monospace" @bind="_request.UnwrapTargetIdHex" />
                    </div>

                    <div class="col-12">
                        <div class="small text-muted mb-2">Unwrapped AES target template</div>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapTokenObject" />
                                    <label class="form-check-label">Persist as token object</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapPrivateObject" />
                                    <label class="form-check-label">Private</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapSensitive" />
                                    <label class="form-check-label">Sensitive</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapExtractable" />
                                    <label class="form-check-label">Extractable</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapAllowEncrypt" />
                                    <label class="form-check-label">Allow Encrypt</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapAllowDecrypt" />
                                    <label class="form-check-label">Allow Decrypt</label>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.FindObjects)
                {
                    <div class="col-md-6">
                        <label class="form-label">Label Filter</label>
                        <input class="form-control" @bind="_request.LabelFilter" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ID Filter (hex)</label>
                        <input class="form-control font-monospace" @bind="_request.IdHex" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Object Class</label>
                        <InputSelect class="form-select" @bind-Value="_request.ObjectClassFilter">
                            @foreach (Pkcs11LabObjectClassFilter filter in Enum.GetValues<Pkcs11LabObjectClassFilter>())
                            {
                                <option value="@filter">@filter</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Max Objects</label>
                        <InputNumber class="form-control" @bind-Value="_request.MaxObjects" />
                    </div>
                }

                <div class="col-12 d-flex gap-2">
                    <button class="btn btn-primary" @onclick="RunAsync" disabled="@(!CanRun || _isRunning)">@(_isRunning ? "Running..." : "Run Operation")</button>
                    <button class="btn btn-outline-secondary" @onclick="ResetOperation">Reset Params</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="card shadow-sm h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Execution result</span>
                @if (_lastResult is not null)
                {
                    <span class="badge @(_lastResult.Success ? "text-bg-success" : "text-bg-danger")">@(_lastResult.Success ? "Success" : "Failure") · @_lastResult.DurationMilliseconds ms</span>
                }
            </div>
            <div class="card-body">
                @if (_lastResult is null)
                {
                    <div class="text-muted">Bir operation çalıştırınca sonuç burada görünecek.</div>
                }
                else
                {
                    <div class="mb-3">
                        <div class="fw-semibold">@_lastResult.Summary</div>
                        <div class="small text-muted">Operation: @_lastResult.Operation</div>
                    </div>

                    @if (_lastResult.Notes.Count > 0)
                    {
                        <div class="alert alert-info small">
                            <div class="fw-semibold mb-1">Notes</div>
                            <ul class="mb-0 ps-3">
                                @foreach (string note in _lastResult.Notes)
                                {
                                    <li>@note</li>
                                }
                            </ul>
                        </div>
                    }

                    <pre class="bg-body-tertiary border rounded p-3 small mb-0" style="max-height: 36rem; overflow: auto; white-space: pre-wrap;">@_lastResult.OutputText</pre>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "device")]
    public Guid? QueryDevice { get; set; }

    [SupplyParameterFromQuery(Name = "slot")]
    public ulong? QuerySlot { get; set; }

    [SupplyParameterFromQuery(Name = "op")]
    public string? QueryOperation { get; set; }

    [SupplyParameterFromQuery(Name = "handle")]
    public string? QueryHandle { get; set; }

    [SupplyParameterFromQuery(Name = "wrapHandle")]
    public string? QuerySecondaryHandle { get; set; }

    [SupplyParameterFromQuery(Name = "mechanism")]
    public string? QueryMechanism { get; set; }

    [SupplyParameterFromQuery(Name = "attr")]
    public string? QueryAttributeType { get; set; }

    private IReadOnlyList<HsmDeviceProfile> _devices = [];
    private IReadOnlyList<HsmSlotSummary> _slots = [];
    private string? _selectedDeviceId;
    private string? _selectedSlotId;
    private Pkcs11LabRequest _request = CreateDefaultRequest();
    private Pkcs11LabExecutionResult? _lastResult;
    private string? _statusMessage;
    private bool _statusIsError;
    private bool _rememberPin;
    private bool _isRunning;
    private string? _lastAppliedQuerySignature;

    private bool RequiresSlot => _request.Operation is Pkcs11LabOperation.MechanismList
        or Pkcs11LabOperation.MechanismInfo
        or Pkcs11LabOperation.SessionInfo
        or Pkcs11LabOperation.GenerateRandom
        or Pkcs11LabOperation.DigestText
        or Pkcs11LabOperation.FindObjects
        or Pkcs11LabOperation.SignData
        or Pkcs11LabOperation.VerifySignature
        or Pkcs11LabOperation.EncryptData
        or Pkcs11LabOperation.DecryptData
        or Pkcs11LabOperation.InspectObject
        or Pkcs11LabOperation.WrapKey
        or Pkcs11LabOperation.UnwrapAesKey
        or Pkcs11LabOperation.ReadAttribute;

    private bool CanRun => Guid.TryParse(_selectedDeviceId, out _) && (!RequiresSlot || ulong.TryParse(_selectedSlotId, out _));

    protected override async Task OnInitializedAsync()
    {
        _devices = await Admin.GetDevicesAsync();
        _selectedDeviceId = _devices.FirstOrDefault()?.Id.ToString();
        await LoadSlotsForSelectedDeviceAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_devices.Count == 0)
        {
            return;
        }

        string signature = $"{QueryDevice}|{QuerySlot}|{QueryOperation}|{QueryHandle}|{QuerySecondaryHandle}|{QueryMechanism}|{QueryAttributeType}";
        if (signature == _lastAppliedQuerySignature)
        {
            return;
        }

        _lastAppliedQuerySignature = signature;

        if (QueryDevice is Guid deviceId && _devices.Any(device => device.Id == deviceId))
        {
            _selectedDeviceId = deviceId.ToString();
            await LoadSlotsForSelectedDeviceAsync();
        }

        if (QuerySlot is ulong slotId && _slots.Any(slot => slot.SlotId == (nuint)slotId))
        {
            _selectedSlotId = slotId.ToString();
            await LoadProtectedPinAsync();
        }

        if (Enum.TryParse<Pkcs11LabOperation>(QueryOperation, ignoreCase: true, out Pkcs11LabOperation operation))
        {
            _request.Operation = operation;
        }

        if (!string.IsNullOrWhiteSpace(QueryHandle))
        {
            _request.KeyHandleText = QueryHandle;
        }

        if (!string.IsNullOrWhiteSpace(QuerySecondaryHandle))
        {
            _request.SecondaryKeyHandleText = QuerySecondaryHandle;
        }

        if (!string.IsNullOrWhiteSpace(QueryMechanism))
        {
            _request.MechanismTypeText = QueryMechanism;
        }

        if (!string.IsNullOrWhiteSpace(QueryAttributeType))
        {
            _request.AttributeTypeText = QueryAttributeType;
        }
    }

    private async Task OnSelectedDeviceChangedAsync()
    {
        _selectedSlotId = null;
        _request.UserPin = null;
        _rememberPin = false;
        await LoadSlotsForSelectedDeviceAsync();
    }

    private async Task OnSelectedSlotChangedAsync()
    {
        await LoadProtectedPinAsync();
    }

    private async Task LoadSlotsForSelectedDeviceAsync()
    {
        _slots = [];
        if (!Guid.TryParse(_selectedDeviceId, out Guid deviceId))
        {
            return;
        }

        _slots = await Admin.GetSlotsAsync(deviceId);
        _selectedSlotId = _slots.FirstOrDefault()?.SlotId.ToString();
        await LoadProtectedPinAsync();
    }

    private async Task LoadProtectedPinAsync()
    {
        if (Guid.TryParse(_selectedDeviceId, out Guid deviceId) && ulong.TryParse(_selectedSlotId, out ulong slotId))
        {
            _request.UserPin = await PinStore.TryGetAsync(deviceId, (nuint)slotId, "lab");
            _rememberPin = !string.IsNullOrWhiteSpace(_request.UserPin);
        }
    }

    private async Task RunAsync()
    {
        try
        {
            _isRunning = true;
            Pkcs11LabRequest request = BuildRequest();
            _lastResult = await Admin.ExecuteLabAsync(request);
            await PersistPinAsync(request);
            _statusMessage = _lastResult.Summary;
            _statusIsError = !_lastResult.Success;
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
            _statusIsError = true;
        }
        finally
        {
            _isRunning = false;
        }
    }

    private Pkcs11LabRequest BuildRequest()
    {
        if (!Guid.TryParse(_selectedDeviceId, out Guid deviceId))
        {
            throw new InvalidOperationException("Select a device first.");
        }

        nuint? slotId = null;
        if (RequiresSlot)
        {
            if (!ulong.TryParse(_selectedSlotId, out ulong parsedSlotId))
            {
                throw new InvalidOperationException("Selected operation requires a slot.");
            }

            slotId = (nuint)parsedSlotId;
        }

        return new Pkcs11LabRequest
        {
            DeviceId = deviceId,
            SlotId = slotId,
            Operation = _request.Operation,
            OpenReadWriteSession = _request.OpenReadWriteSession,
            LoginUserIfPinProvided = _request.LoginUserIfPinProvided,
            UserPin = _request.UserPin,
            MechanismTypeText = _request.MechanismTypeText,
            AttributeTypeText = _request.AttributeTypeText,
            KeyHandleText = _request.KeyHandleText,
            SecondaryKeyHandleText = _request.SecondaryKeyHandleText,
            DigestAlgorithm = _request.DigestAlgorithm,
            PayloadEncoding = _request.PayloadEncoding,
            TextInput = _request.TextInput,
            DataHex = _request.DataHex,
            SignatureHex = _request.SignatureHex,
            UnwrapTargetLabel = _request.UnwrapTargetLabel,
            UnwrapTargetIdHex = _request.UnwrapTargetIdHex,
            UnwrapTokenObject = _request.UnwrapTokenObject,
            UnwrapPrivateObject = _request.UnwrapPrivateObject,
            UnwrapSensitive = _request.UnwrapSensitive,
            UnwrapExtractable = _request.UnwrapExtractable,
            UnwrapAllowEncrypt = _request.UnwrapAllowEncrypt,
            UnwrapAllowDecrypt = _request.UnwrapAllowDecrypt,
            LabelFilter = _request.LabelFilter,
            IdHex = _request.IdHex,
            ObjectClassFilter = _request.ObjectClassFilter,
            RandomLength = _request.RandomLength,
            MaxObjects = _request.MaxObjects
        };
    }

    private async Task PersistPinAsync(Pkcs11LabRequest request)
    {
        if (request.SlotId is not nuint slotId)
        {
            return;
        }

        if (_rememberPin && !string.IsNullOrWhiteSpace(request.UserPin))
        {
            await PinStore.SaveAsync(request.DeviceId, slotId, "lab", request.UserPin);
        }
        else
        {
            await PinStore.DeleteAsync(request.DeviceId, slotId, "lab");
        }
    }

    private void ResetOperation()
    {
        Pkcs11LabRequest fresh = CreateDefaultRequest();
        fresh.Operation = _request.Operation;
        fresh.UserPin = _request.UserPin;
        fresh.LoginUserIfPinProvided = _request.LoginUserIfPinProvided;
        _request = fresh;
        _lastResult = null;
        _statusMessage = null;
        _statusIsError = false;
    }

    private static Pkcs11LabRequest CreateDefaultRequest()
        => new()
        {
            Operation = Pkcs11LabOperation.ModuleInfo,
            DigestAlgorithm = Pkcs11LabDigestAlgorithm.Sha256,
            PayloadEncoding = Pkcs11LabPayloadEncoding.Utf8Text,
            LoginUserIfPinProvided = true,
            RandomLength = 32,
            MaxObjects = 20
        };

    private static string GetOperationLabel(Pkcs11LabOperation operation)
        => operation switch
        {
            Pkcs11LabOperation.ModuleInfo => "Module Info",
            Pkcs11LabOperation.InterfaceDiscovery => "Interface Discovery",
            Pkcs11LabOperation.SlotSnapshot => "Slot Snapshot",
            Pkcs11LabOperation.MechanismList => "Mechanism List",
            Pkcs11LabOperation.MechanismInfo => "Mechanism Info",
            Pkcs11LabOperation.SessionInfo => "Session Info",
            Pkcs11LabOperation.GenerateRandom => "Generate Random",
            Pkcs11LabOperation.DigestText => "Digest Text",
            Pkcs11LabOperation.FindObjects => "Find Objects",
            Pkcs11LabOperation.SignData => "Sign Data",
            Pkcs11LabOperation.VerifySignature => "Verify Signature",
            Pkcs11LabOperation.EncryptData => "Encrypt Data",
            Pkcs11LabOperation.DecryptData => "Decrypt Data",
            Pkcs11LabOperation.InspectObject => "Inspect Object",
            Pkcs11LabOperation.WrapKey => "Wrap Key",
            Pkcs11LabOperation.UnwrapAesKey => "Unwrap AES Key",
            Pkcs11LabOperation.ReadAttribute => "Read Attribute",
            _ => operation.ToString()
        };

    private static string GetOperationDescription(Pkcs11LabOperation operation)
        => operation switch
        {
            Pkcs11LabOperation.ModuleInfo => "`C_GetInfo` ve module-level metadata görünümü.",
