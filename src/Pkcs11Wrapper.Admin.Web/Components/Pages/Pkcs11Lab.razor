@page "/lab"
@attribute [Authorize(Policy = AdminRoles.Operator)]
@using Pkcs11Wrapper.Admin.Web.Lab
@inject HsmAdminService Admin
@inject ProtectedPinStore PinStore
@inject Pkcs11LabTemplateStore TemplateStore

<PageTitle>PKCS#11 Lab</PageTitle>

<section class="page-hero page-hero-lab">
    <div class="page-hero-copy">
        <div class="page-eyebrow">Controlled diagnostics</div>
        <h1>PKCS#11 Lab</h1>
        <p class="page-lead">Bağlı HSM cihazında tanı ve deney amaçlı PKCS#11 operasyonlarını transient session'larla çalıştır. Bu yüzey serbest raw function execution için değil; kontrollü, tekrar edilebilir ve daha profesyonel operatör teşhisi için tasarlanıyor.</p>
        <div class="page-hero-tags">
            <span class="page-tag">Diagnostics</span>
            <span class="page-tag">Crypto experiments</span>
            <span class="page-tag">Scenario replay</span>
            <span class="page-tag">Template favorites</span>
        </div>
    </div>
    <div class="page-hero-side">
        <div class="hero-panel">
            <div class="hero-panel-title">Execution model</div>
            <div class="hero-panel-value">Controlled</div>
            <div class="hero-panel-copy">Transient sessions, validation, audit logging, and PIN-handling guardrails stay in front of every lab action.</div>
        </div>
        <div class="hero-panel">
            <div class="hero-panel-title">Best fit</div>
            <div class="hero-panel-value">Repeatable ops</div>
            <div class="hero-panel-copy">Use templates, history, and palette shortcuts when you need fast diagnostics without dropping to ad-hoc shelling.</div>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert @(_statusIsError ? "alert-danger" : "alert-success")" data-testid="lab-status">@_statusMessage</div>
}

<div class="card shadow-sm mb-4 panel-toolbar-card feature-card">
    <div class="card-body row g-3 align-items-end">
        <div class="col-xl-3 col-lg-4">
            <label class="form-label">Device</label>
            <select class="form-select" @bind="_selectedDeviceId" @bind:after="OnSelectedDeviceChangedAsync" data-testid="lab-device">
                <option value="">Select device...</option>
                @foreach (HsmDeviceProfile device in _devices)
                {
                    <option value="@device.Id">@device.Name</option>
                }
            </select>
        </div>

        <div class="col-xl-3 col-lg-4">
            <label class="form-label">Operation</label>
            <InputSelect class="form-select" @bind-Value="_request.Operation" @bind-Value:after="OnOperationChangedAsync" data-testid="lab-operation">
                @foreach (Pkcs11LabOperation operation in Enum.GetValues<Pkcs11LabOperation>())
                {
                    <option value="@operation">@GetOperationLabel(operation)</option>
                }
            </InputSelect>
        </div>

        @if (RequiresSlot)
        {
            <div class="col-xl-2 col-lg-4">
                <label class="form-label">Slot</label>
                <select class="form-select" @bind="_selectedSlotId" @bind:after="OnSelectedSlotChangedAsync" data-testid="lab-slot">
                    <option value="">Select slot...</option>
                    @foreach (HsmSlotSummary slot in _slots)
                    {
                        <option value="@slot.SlotId">@slot.SlotId - @(slot.TokenLabel ?? slot.SlotDescription)</option>
                    }
                </select>
            </div>
        }

        <div class="col-xl-4 col-lg-8">
            <label class="form-label">Optional User PIN</label>
            <input class="form-control" type="password" @bind="_request.UserPin" data-testid="lab-user-pin" />
            <div class="d-flex flex-wrap gap-3 mt-2">
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="_rememberPin" />
                    <label class="form-check-label">Remember in protected local storage</label>
                </div>
                <div class="form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="_request.LoginUserIfPinProvided" />
                    <label class="form-check-label">Login as CKU_USER when PIN is present</label>
                </div>
            </div>
        </div>
    </div>
</div>

<DeviceVendorHintsPanel Vendor="SelectedDevice?.Vendor" Heading="Selected device guidance" ShowWhenVendorNeutral="false" />

<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100 metric-card">
            <div class="card-body">
                <div class="metric-label">Configured devices</div>
                <div class="display-6 metric-meta">@_devices.Count</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100 metric-card">
            <div class="card-body">
                <div class="metric-label">Loaded slots</div>
                <div class="display-6 metric-meta">@_slots.Count</div>
                <div class="small metric-note">For the selected device</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100 metric-card">
            <div class="card-body">
                <div class="metric-label">Scenario history</div>
                <div class="display-6 metric-meta">@_history.Count</div>
                <div class="small metric-note">Success: @_history.Count(item => item.Result.Success) / Failure: @_history.Count(item => !item.Result.Success)</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100 metric-card">
            <div class="card-body">
                <div class="metric-label">Current operation group</div>
                <div class="display-6 metric-meta">@GetCategoryLabel(_operationPaletteCategory)</div>
                <div class="small metric-note">@GetOperationLabel(_request.Operation)</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4 feature-card workflow-card">
    <div class="card-header">Quick operation palette</div>
    <div class="card-body d-flex flex-column gap-3">
        <div class="d-flex flex-wrap gap-2">
            @foreach (Pkcs11LabOperationCategory category in Enum.GetValues<Pkcs11LabOperationCategory>())
            {
                <button type="button" class="btn @(category == _operationPaletteCategory ? "btn-primary" : "btn-outline-primary")" @onclick="() => SelectOperationCategory(category)">@GetCategoryLabel(category)</button>
            }
        </div>

        <div class="d-flex flex-wrap gap-2">
            @foreach (Pkcs11LabOperation operation in PaletteOperations)
            {
                <button type="button" class="btn @(operation == _request.Operation ? "btn-dark" : "btn-outline-dark")" @onclick="() => SelectOperation(operation)">@GetOperationLabel(operation)</button>
            }
        </div>

        <div class="small text-muted">Use the palette for fast switching between diagnostic, crypto, object, and raw-attribute workflows without manually hunting through the full operation dropdown every time.</div>
    </div>
</div>

<div class="card shadow-sm mb-4 feature-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Saved templates / favorites</span>
        <span class="small text-muted">Stored under App_Data · user PIN is never persisted</span>
    </div>
    <div class="card-body row g-4">
        <div class="col-xl-4">
            <div class="fw-semibold mb-2">Save current editor state</div>
            <div class="small text-muted mb-3">Save repeatable lab requests as local favorites. Device/slot/mechanism selections can be kept; the PIN is always stripped before the template is written.</div>

            <div class="mb-3">
                <label class="form-label">Template name</label>
                <input class="form-control" @bind="_templateName" placeholder="rsa-pss-sign-smoke" />
            </div>
            <div class="mb-3">
                <label class="form-label">Notes</label>
                <textarea class="form-control" rows="3" @bind="_templateNotes" placeholder="What this template is for, token assumptions, expected key usage..."></textarea>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-primary" @onclick="SaveTemplateAsync">Save template</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="ResetTemplateDraft">Clear draft</button>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="row g-3 mb-3 align-items-end">
                <div class="col-lg-7">
                    <label class="form-label small">Search templates</label>
                    <input class="form-control form-control-sm" @bind="_templateSearchText" @bind:event="oninput" placeholder="name, notes, operation..." />
                </div>
                <div class="col-lg-5">
                    <label class="form-label small">Category</label>
                    <select class="form-select form-select-sm" @bind="_templateCategoryFilter">
                        <option value="all">All categories</option>
                        <option value="diagnostics">Diagnostics</option>
                        <option value="crypto">Crypto</option>
                        <option value="objects">Objects</option>
                        <option value="attributes">Attributes</option>
                    </select>
                </div>
                <div class="col-12 small text-muted">Showing @FilteredTemplates.Count of @_templates.Count saved template(s).</div>
            </div>

            @if (_templates.Count == 0)
            {
                <div class="empty-state small">No saved templates yet. Save a favorite once and reuse it later without re-entering the full request shape.</div>
            }
            else if (FilteredTemplates.Count == 0)
            {
                <div class="empty-state small">No template matched the current filters.</div>
            }
            else
            {
                <div class="d-flex flex-column gap-2">
                    @foreach (Pkcs11LabSavedTemplate template in FilteredTemplates)
                    {
                        <div class="surface-item small">
                            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                <div>
                                    <div class="fw-semibold">@template.Name</div>
                                    <div class="text-muted">@GetOperationLabel(template.Request.Operation) · updated @template.UpdatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                                </div>
                                <div class="d-flex flex-wrap gap-2 align-items-center">
                                    <span class="badge text-bg-secondary">@GetCategoryLabel(Pkcs11LabView.GetCategory(template.Request.Operation))</span>
                                    @if (template.Request.DeviceId != Guid.Empty)
                                    {
                                        <span class="badge text-bg-info">Pinned device</span>
                                    }
                                    @if (template.Request.SlotId is not null)
                                    {
                                        <span class="badge text-bg-dark">Pinned slot</span>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(template.Notes))
                            {
                                <div class="text-muted mt-2">@template.Notes</div>
                            }

                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => ApplyTemplateAsync(template)">Apply template</button>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTemplateAsync(template.Id)">Delete</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-5">
        <div class="card shadow-sm h-100 feature-card workflow-card">
            <div class="card-header">Operation parameters</div>
            <div class="card-body row g-3">
                <div class="col-12">
                    <div class="small text-muted">@GetOperationDescription(_request.Operation)</div>
                </div>

                @if (_request.Operation is Pkcs11LabOperation.SessionInfo
                    or Pkcs11LabOperation.SignData
                    or Pkcs11LabOperation.VerifySignature
                    or Pkcs11LabOperation.EncryptData
                    or Pkcs11LabOperation.DecryptData
                    or Pkcs11LabOperation.WrapKey)
                {
                    <div class="col-12">
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" @bind-Value="_request.OpenReadWriteSession" />
                            <label class="form-check-label">Open read-write session</label>
                        </div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.UnwrapAesKey)
                {
                    <div class="col-12">
                        <div class="alert alert-warning small mb-0">Unwrap operation always uses a read-write transient session because it creates a PKCS#11 object.</div>
                    </div>
                }

                @if (_request.Operation is Pkcs11LabOperation.MechanismInfo
                    or Pkcs11LabOperation.SignData
                    or Pkcs11LabOperation.VerifySignature
                    or Pkcs11LabOperation.EncryptData
                    or Pkcs11LabOperation.DecryptData
                    or Pkcs11LabOperation.WrapKey
                    or Pkcs11LabOperation.UnwrapAesKey)
                {
                    <div class="col-12">
                        <label class="form-label">Mechanism Type (hex or decimal)</label>
                        <input class="form-control font-monospace" @bind="_request.MechanismTypeText" placeholder="0x250" />
                        <div class="form-text">Örnek: <code>0x250</code> (CKM_SHA256), <code>0x1</code> (CKM_RSA_PKCS), <code>0x1081</code> (CKM_AES_ECB), <code>0x1082</code> (CKM_AES_CBC), <code>0x1086</code> (CKM_AES_CTR), <code>0x1087</code> (CKM_AES_GCM), <code>0x2109</code> (CKM_AES_KEY_WRAP_PAD).</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Mechanism Parameter Profile</label>
                        <InputSelect class="form-select" @bind-Value="_request.MechanismParameterProfile">
                            @foreach (Pkcs11LabMechanismParameterProfile profile in Enum.GetValues<Pkcs11LabMechanismParameterProfile>())
                            {
                                <option value="@profile">@profile</option>
                            }
                        </InputSelect>
                        <div class="form-text">Parameter editor bu aşamada AES-CBC / AES-CTR / AES-GCM ile RSA OAEP / RSA PSS için aktif. Daha ileri preset wizard ve multi-step senaryolar sonraki dilimde genişletilebilir.</div>
                    </div>

                    @if (_request.MechanismParameterProfile is Pkcs11LabMechanismParameterProfile.RsaOaep or Pkcs11LabMechanismParameterProfile.RsaPss)
                    {
                        <div class="col-md-6">
                            <label class="form-label">RSA Hash Profile</label>
                            <InputSelect class="form-select" @bind-Value="_request.RsaHashProfile">
                                @foreach (Pkcs11LabRsaHashProfile hashProfile in Enum.GetValues<Pkcs11LabRsaHashProfile>())
                                {
                                    <option value="@hashProfile">@hashProfile</option>
                                }
                            </InputSelect>
                        </div>
                    }

                    @if (_request.MechanismParameterProfile is Pkcs11LabMechanismParameterProfile.AesCbcIv
                        or Pkcs11LabMechanismParameterProfile.AesCtr
                        or Pkcs11LabMechanismParameterProfile.AesGcm)
                    {
                        <div class="col-md-6">
                            <label class="form-label">IV / Counter Block Hex</label>
                            <input class="form-control font-monospace" @bind="_request.MechanismIvHex" placeholder="00112233445566778899AABBCCDDEEFF" />
                        </div>
                    }

                    @if (_request.MechanismParameterProfile == Pkcs11LabMechanismParameterProfile.AesCtr)
                    {
                        <div class="col-md-6">
                            <label class="form-label">Counter Bits</label>
                            <InputNumber class="form-control" @bind-Value="_request.MechanismCounterBits" />
                        </div>
                    }

                    @if (_request.MechanismParameterProfile == Pkcs11LabMechanismParameterProfile.AesGcm)
                    {
                        <div class="col-md-6">
                            <label class="form-label">AAD Hex (optional)</label>
                            <input class="form-control font-monospace" @bind="_request.MechanismAdditionalDataHex" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tag Bits</label>
                            <InputNumber class="form-control" @bind-Value="_request.MechanismTagBits" />
                        </div>
                    }

                    @if (_request.MechanismParameterProfile == Pkcs11LabMechanismParameterProfile.RsaOaep)
                    {
                        <div class="col-md-6">
                            <label class="form-label">OAEP Source Encoding</label>
                            <InputSelect class="form-select" @bind-Value="_request.RsaOaepSourceEncoding">
                                @foreach (Pkcs11LabPayloadEncoding encoding in Enum.GetValues<Pkcs11LabPayloadEncoding>())
                                {
                                    <option value="@encoding">@encoding</option>
                                }
                            </InputSelect>
                        </div>

                        @if (_request.RsaOaepSourceEncoding == Pkcs11LabPayloadEncoding.Utf8Text)
                        {
                            <div class="col-12">
                                <label class="form-label">OAEP Source Text (optional)</label>
                                <textarea class="form-control" rows="3" @bind="_request.RsaOaepSourceText"></textarea>
                            </div>
                        }
                        else
                        {
                            <div class="col-12">
                                <label class="form-label">OAEP Source Hex (optional)</label>
                                <textarea class="form-control font-monospace" rows="3" @bind="_request.RsaOaepSourceHex"></textarea>
                            </div>
                        }
                    }

                    @if (_request.MechanismParameterProfile == Pkcs11LabMechanismParameterProfile.RsaPss)
                    {
                        <div class="col-md-6">
                            <label class="form-label">PSS Salt Length</label>
                            <InputNumber class="form-control" @bind-Value="_request.PssSaltLength" />
                        </div>
                    }
                }

                @if (_request.Operation is Pkcs11LabOperation.SignData
                    or Pkcs11LabOperation.VerifySignature
                    or Pkcs11LabOperation.EncryptData
                    or Pkcs11LabOperation.DecryptData
                    or Pkcs11LabOperation.InspectObject
                    or Pkcs11LabOperation.WrapKey
                    or Pkcs11LabOperation.UnwrapAesKey
                    or Pkcs11LabOperation.ReadAttribute)
                {
                    <div class="col-md-6">
                        <label class="form-label">@GetPrimaryHandleLabel(_request.Operation)</label>
                        <input class="form-control font-monospace" @bind="_request.KeyHandleText" placeholder="123" />
                        <div class="form-text">Handle değerini Keys ekranından veya Find Objects çıktısından alabilirsin.</div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.ReadAttribute)
                {
                    <div class="col-md-6">
                        <label class="form-label">Attribute preset library</label>
                        <InputSelect class="form-select" @bind-Value="_selectedAttributePresetKey">
                            @foreach (KeyValuePair<string, string> preset in AttributePresetLibrary)
                            {
                                <option value="@preset.Key">@preset.Key</option>
                            }
                        </InputSelect>
                        <div class="d-flex gap-2 mt-2">
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="ApplySelectedAttributePreset">Replace with preset</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AppendSelectedAttributePreset">Append preset</button>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Attribute Type(s) (hex or decimal)</label>
                        <textarea class="form-control font-monospace" rows="4" @bind="_request.AttributeTypeText" placeholder="0x3, 0x102, 0x100"></textarea>
                        <div class="form-text">Birden fazla attribute code girebilirsin. Ayraç olarak virgül, boşluk veya yeni satır kullan.</div>
                    </div>

                    <div class="col-12 d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => AppendAttributePreset("0x3")'>CKA_LABEL</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => AppendAttributePreset("0x102")'>CKA_ID</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => AppendAttributePreset("0x0")'>CKA_CLASS</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => AppendAttributePreset("0x100")'>CKA_KEY_TYPE</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => AppendAttributePreset("0x161")'>CKA_VALUE_LEN</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => AppendAttributePreset("0x121")'>CKA_MODULUS_BITS</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='() => AppendAttributePreset("0x122")'>CKA_PUBLIC_EXPONENT</button>
                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ClearAttributePresets">Clear</button>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.WrapKey)
                {
                    <div class="col-md-6">
                        <label class="form-label">Wrapping Key Handle</label>
                        <input class="form-control font-monospace" @bind="_request.SecondaryKeyHandleText" placeholder="456" />
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.GenerateRandom)
                {
                    <div class="col-12">
                        <label class="form-label">Random Length</label>
                        <InputNumber class="form-control" @bind-Value="_request.RandomLength" />
                        <div class="form-text">1 ile 4096 byte arasında bir değer gir.</div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.DigestText)
                {
                    <div class="col-12">
                        <label class="form-label">Digest Algorithm</label>
                        <InputSelect class="form-select" @bind-Value="_request.DigestAlgorithm">
                            @foreach (Pkcs11LabDigestAlgorithm algorithm in Enum.GetValues<Pkcs11LabDigestAlgorithm>())
                            {
                                <option value="@algorithm">@algorithm</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Text Input</label>
                        <textarea class="form-control" rows="6" @bind="_request.TextInput"></textarea>
                        <div class="form-text">Metin UTF-8 olarak digest edilir.</div>
                    </div>
                }

                @if (_request.Operation is Pkcs11LabOperation.SignData
                    or Pkcs11LabOperation.VerifySignature
                    or Pkcs11LabOperation.EncryptData)
                {
                    <div class="col-md-6">
                        <label class="form-label">Payload Encoding</label>
                        <InputSelect class="form-select" @bind-Value="_request.PayloadEncoding">
                            @foreach (Pkcs11LabPayloadEncoding encoding in Enum.GetValues<Pkcs11LabPayloadEncoding>())
                            {
                                <option value="@encoding">@encoding</option>
                            }
                        </InputSelect>
                    </div>

                    @if (_request.PayloadEncoding == Pkcs11LabPayloadEncoding.Utf8Text)
                    {
                        <div class="col-12">
                            <label class="form-label">Input Text</label>
                            <textarea class="form-control" rows="6" @bind="_request.TextInput"></textarea>
                            <div class="form-text">Metin UTF-8 byte dizisine çevrilip sign/verify/encrypt işlemine verilir.</div>
                        </div>
                    }
                    else
                    {
                        <div class="col-12">
                            <label class="form-label">Input Hex</label>
                            <textarea class="form-control font-monospace" rows="6" @bind="_request.DataHex"></textarea>
                            <div class="form-text">Hex payload boşluksuz veya çift karakterli biçimde girilmeli.</div>
                        </div>
                    }
                }

                @if (_request.Operation == Pkcs11LabOperation.VerifySignature)
                {
                    <div class="col-12">
                        <label class="form-label">Signature Hex</label>
                        <textarea class="form-control font-monospace" rows="4" @bind="_request.SignatureHex"></textarea>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.DecryptData)
                {
                    <div class="col-12">
                        <label class="form-label">Ciphertext Hex</label>
                        <textarea class="form-control font-monospace" rows="6" @bind="_request.DataHex"></textarea>
                        <div class="form-text">Decrypt çıktısında hem hex hem de UTF-8 yorumu gösterilir.</div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.UnwrapAesKey)
                {
                    <div class="col-12">
                        <label class="form-label">Wrapped Key Hex</label>
                        <textarea class="form-control font-monospace" rows="6" @bind="_request.DataHex"></textarea>
                        <div class="form-text">Bu dilim unwrap hedefini kontrollü tutmak için sadece AES secret-key template üretir.</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Target Label (optional)</label>
                        <input class="form-control" @bind="_request.UnwrapTargetLabel" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Target ID Hex (optional)</label>
                        <input class="form-control font-monospace" @bind="_request.UnwrapTargetIdHex" />
                    </div>

                    <div class="col-12">
                        <div class="small text-muted mb-2">Unwrapped AES target template</div>
                        <div class="row g-2">
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapTokenObject" />
                                    <label class="form-check-label">Persist as token object</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapPrivateObject" />
                                    <label class="form-check-label">Private</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapSensitive" />
                                    <label class="form-check-label">Sensitive</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapExtractable" />
                                    <label class="form-check-label">Extractable</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapAllowEncrypt" />
                                    <label class="form-check-label">Allow Encrypt</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check">
                                    <InputCheckbox class="form-check-input" @bind-Value="_request.UnwrapAllowDecrypt" />
                                    <label class="form-check-label">Allow Decrypt</label>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (_request.Operation == Pkcs11LabOperation.FindObjects)
                {
                    <div class="col-md-6">
                        <label class="form-label">Label Filter</label>
                        <input class="form-control" @bind="_request.LabelFilter" data-testid="lab-find-label-filter" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">ID Filter (hex)</label>
                        <input class="form-control font-monospace" @bind="_request.IdHex" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Object Class</label>
                        <InputSelect class="form-select" @bind-Value="_request.ObjectClassFilter">
                            @foreach (Pkcs11LabObjectClassFilter filter in Enum.GetValues<Pkcs11LabObjectClassFilter>())
                            {
                                <option value="@filter">@filter</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Max Objects</label>
                        <InputNumber class="form-control" @bind-Value="_request.MaxObjects" />
                    </div>
                }

                <div class="col-12 d-flex gap-2">
                    <button class="btn btn-primary" @onclick="RunAsync" disabled="@(!CanRun || _isRunning)" data-testid="lab-run">@(_isRunning ? "Running..." : "Run Operation")</button>
                    <button class="btn btn-outline-secondary" @onclick="ResetOperation">Reset Params</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="card shadow-sm h-100 feature-card" data-testid="lab-result-panel">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Execution result</span>
                @if (_lastResult is not null)
                {
                    <span class="badge @(_lastResult.Success ? "text-bg-success" : "text-bg-danger")">@(_lastResult.Success ? "Success" : "Failure") · @_lastResult.DurationMilliseconds ms</span>
                }
            </div>
            <div class="card-body">
                @if (_lastResult is null)
                {
                    <div class="empty-state">Bir operation çalıştırınca sonuç burada görünecek.</div>
                }
                else
                {
                    <div class="mb-3">
                        <div class="fw-semibold">@_lastResult.Summary</div>
                        <div class="small text-muted">Operation: @_lastResult.Operation</div>
                    </div>

                    @if (_lastResult.Notes.Count > 0)
                    {
                        <div class="alert alert-info small">
                            <div class="fw-semibold mb-1">Notes</div>
                            <ul class="mb-0 ps-3">
                                @foreach (string note in _lastResult.Notes)
                                {
                                    <li>@note</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(_lastResult.CreatedHandleText))
                    {
                        <div class="alert alert-success small">
                            <div>Created handle: <code>@_lastResult.CreatedHandleText</code></div>
                            @if (!string.IsNullOrWhiteSpace(GetCreatedObjectLocatorSummary(_lastResult)))
                            {
                                <div class="mt-1 text-muted">Session-safe locator: <code>@GetCreatedObjectLocatorSummary(_lastResult)</code></div>
                            }
                            @if (Pkcs11LabRequestReuse.CanInspectCreated(_lastResult))
                            {
                                <button type="button" class="btn btn-sm btn-outline-success mt-2" @onclick="OpenInspectForCreatedHandleAsync">Inspect</button>
                            }
                            else if (!_lastResult.CreatedObjectPersistsAcrossSessions)
                            {
                                <div class="mt-2 text-muted">This object was created as a transient session object, so a fresh-session inspect handoff is intentionally unavailable.</div>
                            }
                        </div>
                    }

                    <pre class="result-console small mb-0">@_lastResult.OutputText</pre>
                }

                @if (_history.Count > 0)
                {
                    <hr />
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="fw-semibold">Scenario history</div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ClearHistory">Clear</button>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-lg-5">
                            <label class="form-label small">Search history</label>
                            <input class="form-control form-control-sm" @bind="_historySearchText" @bind:event="oninput" placeholder="operation, summary, handle, artifact..." />
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <label class="form-label small">Result</label>
                            <select class="form-select form-select-sm" @bind="_historyStatusFilter">
                                <option value="all">All</option>
                                <option value="success">Success only</option>
                                <option value="failure">Failure only</option>
                            </select>
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <label class="form-label small">Category</label>
                            <select class="form-select form-select-sm" @bind="_historyCategoryFilter">
                                <option value="all">All categories</option>
                                <option value="diagnostics">Diagnostics</option>
                                <option value="crypto">Crypto</option>
                                <option value="objects">Objects</option>
                                <option value="attributes">Attributes</option>
                            </select>
                        </div>
                        <div class="col-12 small text-muted">Showing @FilteredHistory.Count of @_history.Count recorded scenario(s).</div>
                    </div>

                    @if (FilteredHistory.Count == 0)
                    {
                        <div class="empty-state small">No scenario history item matched the current filters.</div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (LabHistoryItem item in FilteredHistory)
                            {
                                <div class="history-item small">
                                    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                        <div>
                                            <div class="fw-semibold">@item.Result.Operation</div>
                                            <div class="text-muted">@item.RecordedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") · @item.Result.Summary</div>
                                        </div>
                                        <div class="d-flex flex-wrap gap-2 align-items-center">
                                            <span class="badge text-bg-secondary">@GetCategoryLabel(Pkcs11LabView.GetCategory(item.Request.Operation))</span>
                                            <span class="badge @GetHistoryBadgeClass(item.Result)">@GetHistoryBadgeText(item.Result)</span>
                                        </div>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2 mt-2">
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => ApplyHistoryRequestAsync(item)">Reuse request</button>
                                        @if (CanPrepareVerify(item))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => PrepareVerifyFromHistoryAsync(item)">Prepare verify</button>
                                        }
                                        @if (CanPrepareDecrypt(item))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => PrepareDecryptFromHistoryAsync(item)">Prepare decrypt</button>
                                        }
                                        @if (CanPrepareUnwrap(item))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-warning" @onclick="() => PrepareUnwrapFromHistoryAsync(item)">Prepare unwrap</button>
                                        }
                                        @if (CanInspectCreated(item))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-dark" @onclick="() => PrepareInspectCreatedHandleAsync(item)">Inspect created</button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

