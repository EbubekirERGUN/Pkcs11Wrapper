    private void AppendAttributePreset(string value)
        => _request.AttributeTypeText = string.IsNullOrWhiteSpace(_request.AttributeTypeText)
            ? value
            : $"{_request.AttributeTypeText}, {value}";

    private void ClearAttributePresets()
        => _request.AttributeTypeText = null;

    private void ApplySelectedAttributePreset()
        => _request.AttributeTypeText = AttributePresetLibrary[_selectedAttributePresetKey];

    private void AppendSelectedAttributePreset()
        => _request.AttributeTypeText = string.IsNullOrWhiteSpace(_request.AttributeTypeText)
            ? AttributePresetLibrary[_selectedAttributePresetKey]
            : $"{_request.AttributeTypeText}, {AttributePresetLibrary[_selectedAttributePresetKey]}";

    private void RecordHistory(Pkcs11LabRequest request, Pkcs11LabExecutionResult result)
    {
        _history.Insert(0, new LabHistoryItem(DateTimeOffset.UtcNow, CopyRequest(request), result));
        if (_history.Count > 8)
        {
            _history.RemoveRange(8, _history.Count - 8);
        }
    }

    private void ClearHistory()
        => _history.Clear();

    private async Task ApplyHistoryRequestAsync(LabHistoryItem item)
    {
        await ApplyRequestAsync(item.Request);
        _statusMessage = "Scenario request restored into the editor.";
        _statusIsError = false;
    }

    private async Task PrepareVerifyFromHistoryAsync(LabHistoryItem item)
    {
        Pkcs11LabRequest request = CopyRequest(item.Request);
        request.Operation = Pkcs11LabOperation.VerifySignature;
        request.SignatureHex = item.Result.ArtifactHex;
        request.KeyHandleText = null;
        request.KeyLabel = item.Request.KeyLabel;
        request.KeyIdHex = item.Request.KeyIdHex;
        request.KeyType = item.Request.KeyType;
        request.KeyObjectClass = string.Equals(item.Request.KeyObjectClass, "PrivateKey", StringComparison.OrdinalIgnoreCase)
            && string.Equals(item.Request.KeyType, "RSA", StringComparison.OrdinalIgnoreCase)
            ? "PublicKey"
            : item.Request.KeyObjectClass;
        await ApplyRequestAsync(request);
        _statusMessage = "Signature and original payload were moved into Verify. Matching locator metadata was also prepared for session-safe re-resolution.";
        _statusIsError = false;
    }

    private async Task PrepareDecryptFromHistoryAsync(LabHistoryItem item)
    {
        Pkcs11LabRequest request = CopyRequest(item.Request);
        request.Operation = Pkcs11LabOperation.DecryptData;
        request.DataHex = item.Result.ArtifactHex;
        request.KeyHandleText = null;
        request.KeyLabel = item.Request.KeyLabel;
        request.KeyIdHex = item.Request.KeyIdHex;
        request.KeyType = item.Request.KeyType;
        request.KeyObjectClass = string.Equals(item.Request.KeyObjectClass, "PublicKey", StringComparison.OrdinalIgnoreCase)
            && string.Equals(item.Request.KeyType, "RSA", StringComparison.OrdinalIgnoreCase)
            ? "PrivateKey"
            : item.Request.KeyObjectClass;
        await ApplyRequestAsync(request);
        _statusMessage = "Ciphertext was moved into Decrypt. Matching locator metadata was prepared so the current session can re-resolve the decrypt key safely.";
        _statusIsError = false;
    }

    private async Task PrepareUnwrapFromHistoryAsync(LabHistoryItem item)
    {
        Pkcs11LabRequest request = CreateDefaultRequest();
        request.DeviceId = item.Request.DeviceId;
        request.SlotId = item.Request.SlotId;
        request.Operation = Pkcs11LabOperation.UnwrapAesKey;
        request.MechanismTypeText = item.Request.MechanismTypeText;
        request.MechanismParameterProfile = item.Request.MechanismParameterProfile;
        request.MechanismIvHex = item.Request.MechanismIvHex;
        request.MechanismAdditionalDataHex = item.Request.MechanismAdditionalDataHex;
        request.MechanismCounterBits = item.Request.MechanismCounterBits;
        request.MechanismTagBits = item.Request.MechanismTagBits;
        request.RsaHashProfile = item.Request.RsaHashProfile;
        request.RsaOaepSourceEncoding = item.Request.RsaOaepSourceEncoding;
        request.RsaOaepSourceText = item.Request.RsaOaepSourceText;
        request.RsaOaepSourceHex = item.Request.RsaOaepSourceHex;
        request.PssSaltLength = item.Request.PssSaltLength;
        request.KeyHandleText = item.Request.SecondaryKeyHandleText;
        request.KeyLabel = item.Request.SecondaryKeyLabel;
        request.KeyIdHex = item.Request.SecondaryKeyIdHex;
        request.KeyObjectClass = item.Request.SecondaryKeyObjectClass;
        request.KeyType = item.Request.SecondaryKeyType;
        request.DataHex = item.Result.ArtifactHex;
        await ApplyRequestAsync(request);
        _statusMessage = "Wrapped blob was moved into Unwrap AES Key and the previous wrapping key handle was reused as the unwrapping key handle.";
        _statusIsError = false;
    }

    private async Task PrepareInspectCreatedHandleAsync(LabHistoryItem item)
    {
        if (string.IsNullOrWhiteSpace(item.Result.CreatedHandleText))
        {
            return;
        }

        Pkcs11LabRequest request = CreateDefaultRequest();
        request.DeviceId = item.Request.DeviceId;
        request.SlotId = item.Request.SlotId;
        request.Operation = Pkcs11LabOperation.InspectObject;
        request.KeyHandleText = item.Result.CreatedHandleText;
        await ApplyRequestAsync(request);
        _statusMessage = $"Prepared Inspect Object for created handle {item.Result.CreatedHandleText}.";
        _statusIsError = false;
    }

    private async Task OpenInspectForCreatedHandleAsync()
    {
        if (_lastResult is null || string.IsNullOrWhiteSpace(_lastResult.CreatedHandleText))
        {
            return;
        }

        Pkcs11LabRequest request = CopyRequest(_request);
        request.Operation = Pkcs11LabOperation.InspectObject;
        request.KeyHandleText = _lastResult.CreatedHandleText;
        await ApplyRequestAsync(request);
        _statusMessage = $"Prepared Inspect Object for created handle {_lastResult.CreatedHandleText}.";
        _statusIsError = false;
    }

    private async Task ApplyRequestAsync(Pkcs11LabRequest request)
    {
        if (request.DeviceId != Guid.Empty && _devices.Any(device => device.Id == request.DeviceId))
        {
            _selectedDeviceId = request.DeviceId.ToString();
        }
        else if (string.IsNullOrWhiteSpace(_selectedDeviceId))
        {
            _selectedDeviceId = _devices.FirstOrDefault()?.Id.ToString();
        }

        await LoadSlotsForSelectedDeviceAsync();

        if (request.SlotId is nuint slotId && _slots.Any(slot => slot.SlotId == slotId))
        {
            _selectedSlotId = slotId.ToString();
            await LoadProtectedPinAsync();
        }

        _request = CopyRequest(request);
        _request.UserPin = null;
        _operationPaletteCategory = Pkcs11LabView.GetCategory(_request.Operation);
        _lastResult = null;
    }

