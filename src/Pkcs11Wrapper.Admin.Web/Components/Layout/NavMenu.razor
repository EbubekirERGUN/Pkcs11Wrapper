@using Pkcs11Wrapper.Admin.Application.Models

<nav class="app-nav">
    <AuthorizeView>
        <Authorized Context="userContext">
            <div class="app-user-panel">
                <div>
                    <div class="app-user-label">Signed in</div>
                    <div class="app-user-name">@userContext.User.Identity?.Name</div>
                </div>

                <form method="post" action="/account/logout" class="d-inline">
                    <AntiforgeryToken />
                    <button class="btn btn-sm btn-outline-light app-logout-button" type="submit">Logout</button>
                </form>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="app-user-panel">
                <div>
                    <div class="app-user-label">Access</div>
                    <div class="app-user-name">Sign in required</div>
                </div>

                <a class="btn btn-sm btn-light app-login-button" href="/login">Login</a>
            </div>
        </NotAuthorized>
    </AuthorizeView>

    <AuthorizeView Roles="viewer,operator,admin">
        <Authorized>
            <div class="app-nav-section">
                <div class="app-nav-section-title">Overview</div>

                <div class="app-nav-item">
                    <NavLink class="app-nav-link" href="" Match="NavLinkMatch.All">
                        <span class="app-nav-icon">D</span>
                        <span class="app-nav-copy">
                            <span class="app-nav-title">Dashboard</span>
                            <span class="app-nav-caption">Health, recovery, quick actions</span>
                        </span>
                    </NavLink>
                </div>
            </div>

            <div class="app-nav-section">
                <div class="app-nav-section-title">Inventory</div>

                <div class="app-nav-item">
                    <NavLink class="app-nav-link" href="devices" data-testid="nav-devices">
                        <span class="app-nav-icon">H</span>
                        <span class="app-nav-copy">
                            <span class="app-nav-title">Devices</span>
                            <span class="app-nav-caption">Profiles, module paths, enablement</span>
                        </span>
                    </NavLink>
                </div>

                <div class="app-nav-item">
                    <NavLink class="app-nav-link" href="slots" data-testid="nav-slots">
                        <span class="app-nav-icon">S</span>
                        <span class="app-nav-copy">
                            <span class="app-nav-title">Slots</span>
                            <span class="app-nav-caption">Token visibility and slot details</span>
                        </span>
                    </NavLink>
                </div>

                <div class="app-nav-item">
                    <NavLink class="app-nav-link" href="keys" data-testid="nav-keys">
                        <span class="app-nav-icon">K</span>
                        <span class="app-nav-copy">
                            <span class="app-nav-title">Keys & Objects</span>
                            <span class="app-nav-caption">Object lifecycle and capabilities</span>
                        </span>
                    </NavLink>
                </div>
            </div>

            <div class="app-nav-section">
                <div class="app-nav-section-title">Operations</div>

                <AuthorizeView Roles="operator,admin">
                    <Authorized Context="operatorContext">
                        <div class="app-nav-item">
                            <NavLink class="app-nav-link" href="lab" data-testid="nav-lab">
                                <span class="app-nav-icon">L</span>
                                <span class="app-nav-copy">
                                    <span class="app-nav-title">PKCS#11 Lab</span>
                                    <span class="app-nav-caption">Diagnostics, crypto flows, replay</span>
                                </span>
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <div class="app-nav-item">
                    <NavLink class="app-nav-link" href="telemetry" data-testid="nav-telemetry">
                        <span class="app-nav-icon">P</span>
                        <span class="app-nav-copy">
                            <span class="app-nav-title">PKCS#11 Telemetry</span>
                            <span class="app-nav-caption">Redacted device/slot/mechanism traces</span>
                        </span>
                    </NavLink>
                </div>

                <div class="app-nav-item">
                    <NavLink class="app-nav-link" href="sessions">
                        <span class="app-nav-icon">T</span>
                        <span class="app-nav-copy">
                            <span class="app-nav-title">Sessions</span>
                            <span class="app-nav-caption">Tracked session health and cleanup</span>
                        </span>
                    </NavLink>
                </div>

                <div class="app-nav-item">
                    <NavLink class="app-nav-link" href="audit">
                        <span class="app-nav-icon">A</span>
                        <span class="app-nav-copy">
                            <span class="app-nav-title">Audit Logs</span>
                            <span class="app-nav-caption">Integrity, failures, operator trace</span>
                        </span>
                    </NavLink>
                </div>
            </div>

            <AuthorizeView Roles="admin">
                <Authorized Context="adminContext">
                    <div class="app-nav-section">
                        <div class="app-nav-section-title">Administration</div>

                        <div class="app-nav-item">
                            <NavLink class="app-nav-link" href="crypto-api-access" data-testid="nav-crypto-api-access">
                                <span class="app-nav-icon">Y</span>
                                <span class="app-nav-copy">
                                    <span class="app-nav-title">Crypto API Access</span>
                                    <span class="app-nav-caption">Applications, API keys, lifecycle controls</span>
                                </span>
                            </NavLink>
                        </div>

                        <div class="app-nav-item">
                            <NavLink class="app-nav-link" href="configuration">
                                <span class="app-nav-icon">C</span>
                                <span class="app-nav-copy">
                                    <span class="app-nav-title">Configuration</span>
                                    <span class="app-nav-caption">Controlled import and export</span>
                                </span>
                            </NavLink>
                        </div>

                        <div class="app-nav-item">
                            <NavLink class="app-nav-link" href="users" data-testid="nav-users">
                                <span class="app-nav-icon">U</span>
                                <span class="app-nav-copy">
                                    <span class="app-nav-title">Users</span>
                                    <span class="app-nav-caption">Bootstrap, roles, password rotation</span>
                                </span>
                            </NavLink>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        </Authorized>
    </AuthorizeView>
</nav>
