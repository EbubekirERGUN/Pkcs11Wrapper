<div class="top-row ps-3 navbar navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Pkcs11Wrapper Admin</a>
        <AuthorizeView>
            <Authorized>
                <div class="text-white small d-flex align-items-center gap-2">
                    <span>@context.User.Identity?.Name</span>
                    <form method="post" action="/account/logout" class="d-inline">
                        <AntiforgeryToken />
                        <button class="btn btn-sm btn-outline-light" type="submit">Logout</button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <a class="btn btn-sm btn-outline-light" href="/login">Login</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView Roles="viewer,operator,admin">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="devices">
                        <span class="bi bi-hdd-network-nav-menu" aria-hidden="true"></span> Devices
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="slots">
                        <span class="bi bi-grid-3x3-gap-nav-menu" aria-hidden="true"></span> Slots
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="keys">
                        <span class="bi bi-key-fill-nav-menu" aria-hidden="true"></span> Keys
                    </NavLink>
                </div>

                <AuthorizeView Roles="operator,admin">
                    <Authorized Context="operatorContext">
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="lab">
                                <span class="bi bi-terminal-nav-menu" aria-hidden="true"></span> PKCS#11 Lab
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="sessions">
                        <span class="bi bi-activity-nav-menu" aria-hidden="true"></span> Sessions
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="audit">
                        <span class="bi bi-journal-text-nav-menu" aria-hidden="true"></span> Audit Logs
                    </NavLink>
                </div>

                <AuthorizeView Roles="admin">
                    <Authorized Context="adminContext">
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="configuration">
                                <span class="bi bi-sliders-nav-menu" aria-hidden="true"></span> Configuration
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>
